# AI Video Factory Environment Configuration
# Copy to .env and fill in your values

# ============================================
# OPENCLAW CONFIGURATION
# ============================================
OPENCLAW_GATEWAY_PORT=3000
OPENCLAW_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OPENCLAW_WHATSAPP_PHONE=your_whatsapp_phone

# ============================================
# AI PROVIDERS
# ============================================

# OpenRouter (RECOMMENDED - 300+ models, 1 API)
# Get API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default models via OpenRouter (cheaper than direct)
OPENROUTER_SCRIPT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_CHEAP_MODEL=google/gemini-2.0-flash-001
OPENROUTER_PREMIUM_MODEL=anthropic/claude-opus-4.5

# OpenAI Direct (fallback if needed)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# Anthropic Direct (fallback)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ElevenLabs (Voice synthesis)
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-default-voice-id

# D-ID (Avatar videos)
DID_API_KEY=your-did-api-key
DID_PRESENTER_ID=default-presenter

# HeyGen (Alternative avatar)
HEYGEN_API_KEY=your-heygen-key

# Pictory (B-roll videos)
PICTORY_API_KEY=your-pictory-key
PICTORY_USER_ID=your-pictory-user

# ============================================
# CLOUD STORAGE
# ============================================

# Cloudinary (Recommended)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Alternative: AWS S3
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1

# ============================================
# CONTENT MANAGEMENT
# ============================================

# Airtable
AIRTABLE_API_KEY=your-airtable-key
AIRTABLE_BASE_ID=your-base-id
AIRTABLE_TABLE_VIDEOS=Videos
AIRTABLE_TABLE_SCRIPTS=Scripts
AIRTABLE_TABLE_AFFILIATES=Affiliates

# ============================================
# SOCIAL PLATFORMS
# ============================================

# YouTube
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token

# TikTok
TIKTOK_CLIENT_KEY=your-client-key
TIKTOK_CLIENT_SECRET=your-client-secret
TIKTOK_ACCESS_TOKEN=your-access-token

# Instagram (Meta)
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret
META_ACCESS_TOKEN=your-access-token
META_IG_USER_ID=your-ig-user-id

# ============================================
# AFFILIATE TRACKING
# ============================================

# Bitly (Link shortening)
BITLY_ACCESS_TOKEN=your-bitly-token

# Pretty Links (Self-hosted alternative)
# PRETTYLINKS_API_URL=https://yourdomain.com/wp-json/prli/v1

# ============================================
# N8N CONFIGURATION
# ============================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_URL=https://your-n8n-domain.com/webhook

# ============================================
# NOTIFICATIONS
# ============================================
TELEGRAM_CHAT_ID=your-chat-id-for-notifications
