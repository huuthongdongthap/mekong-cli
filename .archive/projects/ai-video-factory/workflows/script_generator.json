{
  "name": "Script Generator Workflow",
  "nodes": [
    {
      "parameters": {},
      "id": "trigger-webhook",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "script-generator"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.airtable.com/v0/{{$env.AIRTABLE_BASE_ID}}/Scripts",
        "authentication": "headerAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.AIRTABLE_API_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "fields",
              "value": "={{ $json }}"
            }
          ]
        }
      },
      "id": "airtable-create",
      "name": "Create Airtable Record",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "headerAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.OPENROUTER_API_KEY}}"
            },
            {
              "name": "HTTP-Referer",
              "value": "https://ai-video-factory.local"
            },
            {
              "name": "X-Title",
              "value": "AI Video Factory"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.OPENROUTER_SCRIPT_MODEL || 'anthropic/claude-3.5-sonnet' }}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert short-form video scriptwriter specializing in product reviews and affiliate marketing content. Write engaging, concise scripts optimized for YouTube Shorts, TikTok, and Instagram Reels. Always include scene markers like [SCENE: talking head], [SCENE: screen recording], [SCENE: b-roll]. Keep hooks punchy and CTAs clear.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $json.prompt }}\"\n    }\n  ],\n  \"temperature\": 0.7,\n  \"max_tokens\": 1000\n}"
      },
      "id": "openrouter-generate",
      "name": "Generate Script with OpenRouter",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [680, 300]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://api.airtable.com/v0/{{$env.AIRTABLE_BASE_ID}}/Scripts/{{ $('Create Airtable Record').item.json.id }}",
        "authentication": "headerAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.AIRTABLE_API_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"fields\": {\n    \"Script\": \"{{ $json.choices[0].message.content }}\",\n    \"Status\": \"Generated\",\n    \"Generated_At\": \"{{ $now.toISO() }}\"\n  }\n}"
      },
      "id": "airtable-update",
      "name": "Update Airtable with Script",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.telegram.org/bot{{$env.TELEGRAM_BOT_TOKEN}}/sendMessage",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"chat_id\": \"{{$env.TELEGRAM_CHAT_ID}}\",\n  \"text\": \"✅ Script generated for {{ $('Webhook Trigger').item.json.product }}!\\n\\n📝 Preview:\\n{{ $json.choices[0].message.content.substring(0, 300) }}...\\n\\n👉 Reply /approve to generate video or /edit [notes] for changes\",\n  \"parse_mode\": \"HTML\"\n}"
      },
      "id": "telegram-notify",
      "name": "Notify via Telegram",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1120, 300]
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [
        [
          {
            "node": "Create Airtable Record",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create Airtable Record": {
      "main": [
        [
          {
            "node": "Generate Script with ChatGPT",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generate Script with ChatGPT": {
      "main": [
        [
          {
            "node": "Update Airtable with Script",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Update Airtable with Script": {
      "main": [
        [
          {
            "node": "Notify via Telegram",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
