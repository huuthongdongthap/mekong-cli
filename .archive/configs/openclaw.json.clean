{
  "gateway": {
    "mode": "local",
    "trustedProxies": ["127.0.0.1", "172.16.0.0/12", "10.0.0.0/8"]
  },
  "models": {
    "providers": {
      "vertexai": {
        "baseUrl": "https://us-central1-aiplatform.googleapis.com/v1",
        "apiKey": "VERTEX_AI_AUTH",
        "api": "google-generative-ai",
        "models": [
          {"id": "gemini-1.5-pro-preview-0514", "name": "Gemini 1.5 Pro (Vertex)"},
          {"id": "gemini-1.5-flash-preview-0514", "name": "Gemini 1.5 Flash (Vertex)"}
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "vertexai/gemini-1.5-pro-preview-0514",
        "fallbacks": ["vertexai/gemini-1.5-flash-preview-0514"]
      },
      "maxConcurrent": 4
    },
    "list": [
      {
        "id": "main",
        "name": "OpenClaw RaaS",
        "default": true,
        "model": "vertexai/gemini-1.5-pro-preview-0514"
      }
    ]
  }
}
