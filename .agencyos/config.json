{
  "version": "1.0.0",
  "service": "mekong-cli",
  "gateway": {
    "host": "0.0.0.0",
    "port": 8000,
    "ws_path": "/ws/missions",
    "health_path": "/health"
  },
  "proxy": {
    "anthropic_base_url": "http://localhost:9191",
    "port": 9191,
    "recovery_script": "scripts/proxy-recovery.sh",
    "fallback_direct": true
  },
  "pev_engine": {
    "max_retries": 3,
    "retry_backoff_seconds": 2,
    "rollback_on_verify_fail": true,
    "quality_gates_enabled": true
  },
  "mcu": {
    "low_balance_threshold": 10,
    "deduct_on_success_only": true,
    "refund_on_cancel": true
  },
  "database": {
    "provider": "supabase",
    "dev_fallback": "sqlite",
    "sqlite_path": ".mekong/dev.db"
  },
  "company_state": {
    "path": ".mekong/company.json",
    "tasks_dir": ".mekong/tasks/"
  },
  "tôm_hùm": {
    "worker_dir": "apps/openclaw-worker",
    "log_file": "~/tom_hum_cto.log",
    "cooling_interval_seconds": 90,
    "m1_ram_floor_mb": 200,
    "m1_load_ceiling": 8
  },
  "language": "vi",
  "session_bootstrap": [
    "read_company_json",
    "check_proxy_health",
    "load_active_tasks",
    "print_ready_message"
  ]
}
