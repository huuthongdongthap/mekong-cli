{
  "version": "1.0.0",
  "agents": [
    {
      "id": "planner",
      "name": "Planner",
      "namespace": "company/agent",
      "description": "LLM-powered task decomposition. Breaks goals into PEV recipe steps with dependencies.",
      "model_preference": ["qwen3.5-plus", "qwen3-max", "qwq-plus"],
      "mcu_overhead": 0,
      "enabled_by_default": true,
      "capabilities": ["task_decomposition", "dependency_mapping", "recipe_generation"]
    },
    {
      "id": "fullstack-developer",
      "name": "Fullstack Developer",
      "namespace": "company/agent",
      "description": "Implements features across frontend and backend. Owns src/ file changes.",
      "model_preference": ["qwen3-coder-plus", "qwen3-coder-next", "qwen3-coder-480b-a35b-instruct"],
      "mcu_overhead": 0,
      "enabled_by_default": true,
      "capabilities": ["code_generation", "refactoring", "api_integration", "frontend", "backend"]
    },
    {
      "id": "code-reviewer",
      "name": "Code Reviewer",
      "namespace": "company/agent",
      "description": "Reviews code for quality, security, and standards compliance. Read-only access.",
      "model_preference": ["kimi-k2.5", "glm-5", "glm-4.7"],
      "mcu_overhead": 0,
      "enabled_by_default": true,
      "capabilities": ["code_review", "security_audit", "type_check", "style_enforcement"]
    },
    {
      "id": "tester",
      "name": "Tester",
      "namespace": "company/agent",
      "description": "Writes and runs tests. Owns test files only — never edits implementation files.",
      "model_preference": ["glm-5", "qwen3-14b", "qwen3-32b"],
      "mcu_overhead": 0,
      "enabled_by_default": true,
      "capabilities": ["unit_tests", "integration_tests", "e2e_tests", "coverage_reporting"]
    },
    {
      "id": "researcher",
      "name": "Researcher",
      "namespace": "company/agent",
      "description": "Conducts technical research in parallel. Feeds findings to planner.",
      "model_preference": ["MiniMax-M2.5", "qwen3.5-flash", "qwen-plus"],
      "mcu_overhead": 0,
      "enabled_by_default": true,
      "capabilities": ["web_search", "docs_lookup", "competitive_analysis", "technical_research"]
    },
    {
      "id": "docs-manager",
      "name": "Docs Manager",
      "namespace": "company/agent",
      "description": "Keeps docs/ directory up to date after every implementation. Owns docs/ files.",
      "model_preference": ["MiniMax-M2.5-highspeed", "qwen3.5-flash"],
      "mcu_overhead": 0,
      "enabled_by_default": false,
      "capabilities": ["docs_update", "changelog", "roadmap", "architecture_docs"]
    },
    {
      "id": "debugger",
      "name": "Debugger",
      "namespace": "company/agent",
      "description": "Analyzes CI/CD failures, runtime errors, and test failures. Produces root-cause reports.",
      "model_preference": ["qwq-plus", "qwen3.5-plus", "glm-5"],
      "mcu_overhead": 0,
      "enabled_by_default": true,
      "capabilities": ["log_analysis", "stack_trace", "root_cause", "fix_recommendation"]
    },
    {
      "id": "ui-ux-designer",
      "name": "UI/UX Designer",
      "namespace": "company/agent",
      "description": "Designs and validates UI components. Uses vision models for visual verification.",
      "model_preference": ["qwen-vl-max", "kimi-k2.5"],
      "mcu_overhead": 0,
      "enabled_by_default": false,
      "capabilities": ["ui_design", "ux_review", "screenshot_analysis", "accessibility_audit"]
    }
  ],
  "orchestration": {
    "sequential": ["planner", "fullstack-developer", "tester", "code-reviewer"],
    "parallel_research": ["researcher", "researcher", "researcher"],
    "debug_flow": ["debugger", "fullstack-developer", "tester"],
    "model_rotation": "round_robin_by_index"
  }
}
