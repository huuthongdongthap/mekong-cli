# ── PRIMARY LLM: Qwen3 32B via Ollama ──
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3:32b
LLM_MODE=byok

# ── Ollama endpoints ──
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:32b
OLLAMA_HOST=http://localhost:11434

# ── FALLBACK: MLX local (DeepSeek-R1-Distill-Qwen-32B) ──
LOCAL_LLM_URL=http://localhost:11435/v1
LOCAL_LLM_MODEL=mlx-community/DeepSeek-R1-Distill-Qwen-32B-4bit

# ── Antigravity Proxy (CC CLI) ──
ANTIGRAVITY_PROXY_URL=http://localhost:11434/v1
ANTHROPIC_BASE_URL=http://localhost:18789
ANTHROPIC_AUTH_TOKEN=test
ANTHROPIC_MODEL=qwen3:32b

# ── 9-Tier Fallback Chain ──
# Priority: Ollama(Qwen3) → MLX(DeepSeek) → DashScope → DeepSeek API → Anthropic → OpenAI → Google → Offline
# OPENROUTER_API_KEY=
DASHSCOPE_API_KEY=
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# ── API Gateway ──
MEKONG_API_TOKEN=mekong-local-dev-token
