# ── PRIMARY LLM: Antigravity Proxy ──
LLM_BASE_URL=http://localhost:18789/v1
LLM_API_KEY=test
LLM_MODEL=claude-sonnet-4-20250514
LLM_MODE=byok

# ── LOCAL LLM: MLX (DeepSeek-R1-Distill-Qwen-32B) ──
LOCAL_LLM_URL=http://localhost:11435/v1
LOCAL_LLM_MODEL=mlx-community/DeepSeek-R1-Distill-Qwen-32B-4bit

# ── Antigravity Proxy (CC CLI) ──
ANTIGRAVITY_PROXY_URL=http://localhost:18789/v1
ANTHROPIC_BASE_URL=http://localhost:18789
ANTHROPIC_AUTH_TOKEN=test
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Fallback Chain ──
# Priority: Antigravity Proxy → MLX Local → DashScope → DeepSeek API → Offline
# OPENROUTER_API_KEY=
DASHSCOPE_API_KEY=
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# ── API Gateway ──
MEKONG_API_TOKEN=mekong-local-dev-token
API_PORT=8000

# ── Database ──
# DATABASE_URL=postgresql://user:pass@localhost/mekong
RAAS_DB_PATH=~/.mekong/raas/tenants.db

# ── Telegram Commander ──
# MEKONG_TELEGRAM_TOKEN=your-telegram-bot-token

# ── Mekong Home ──
MEKONG_HOME=/Users/mac/mekong-cli
