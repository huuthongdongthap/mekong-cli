{
  "name": "mekong-cli",
  "version": "5.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "description": "RaaS Agency Operating System - Powered by Binh Phap & ClaudeKit DNA",
  "author": "Binh Phap Venture Studio",
  "license": "MIT",
  "homepage": "https://agencyos.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/longtho638-jpg/mekong-cli.git"
  },
  "bugs": {
    "url": "https://github.com/longtho638-jpg/mekong-cli/issues"
  },
  "workspaces": [
    "packages/*",
    "packages/core/*",
    "packages/integrations/*",
    "packages/business/*",
    "packages/ui/*",
    "packages/tooling/*",
    "apps/admin",
    "apps/agencyos-landing",
    "apps/agencyos-web",
    "apps/agi-sops",
    "apps/algo-trader",
    "apps/analytics",
    "apps/anima119",
    "apps/antigravity-cli",
    "apps/apex-os",
    "apps/api",
    "apps/com-anh-duong-10x",
    "apps/dashboard",
    "apps/developers",
    "apps/docs",
    "apps/engine",
    "apps/gemini-proxy-clone",
    "apps/landing",
    "apps/openclaw-worker",
    "apps/project",
    "apps/raas-demo",
    "apps/raas-gateway",
    "apps/raas-gateway-cli",
    "apps/sa-dec-flower-hunt",
    "apps/saas-dashboard",
    "apps/sophia-proposal",
    "apps/starter-template",
    "apps/tasks",
    "apps/vibe-coding-cafe",
    "apps/web",
    "apps/well"
  ],
  "scripts": {
    "dev": "npx turbo run dev",
    "dev:web": "cd apps/web && pnpm dev",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "build": "npx turbo run build --concurrency=4",
    "test": "npx turbo run test --concurrency=5",
    "lint": "npx turbo run lint --concurrency=1",
    "format": "npx turbo run format --concurrency=10",
    "type-check": "tsc --noEmit",
    "gws": "npx -y @googleworkspace/cli",
    "postinstall": "bash scripts/setup-dev.sh --quick 2>/dev/null || true",
    "health": "bash scripts/health-check.sh"
  },
  "devDependencies": {
    "@types/node": "25.3.3",
    "concurrently": "^9.2.1",
    "turbo": "^2.8.12",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
