{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "FNB_DEBUG": "readonly",
    "confirm": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "no-debugger": "warn",
    "no-var": "warn",
    "prefer-const": "warn",
    "no-undef": "warn",
    "curly": "error",
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "no-eval": "error",
    "no-implied-eval": "error"
  },
  "overrides": [
    {
      "files": ["js/sw.js", "sw.js", "public/sw.js"],
      "env": { "serviceworker": true },
      "globals": { "self": "readonly", "caches": "readonly", "clients": "readonly" }
    },
    {
      "files": ["worker/**/*.js"],
      "env": { "node": true },
      "globals": { "FNB_DEBUG": "readonly" }
    }
  ],
  "ignorePatterns": [
    "node_modules/",
    "*.min.js",
    "coverage/",
    ".wrangler/",
    "public/*.min.js",
    "js/*.min.js",
    "dashboard/*.min.js"
  ]
}
