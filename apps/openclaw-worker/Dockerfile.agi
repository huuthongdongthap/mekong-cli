FROM node:20-bullseye

# Install system dependencies
# tmux: for Brain session management
# procps: for pgrep/pkill
# git: for git operations
# vim: for debugging
RUN apt-get update && apt-get install -y \
    tmux \
    procps \
    git \
    vim \
    && rm -rf /var/lib/apt/lists/*

# Install ClaudeKit globally
RUN npm install -g claudekit

# Set working directory
WORKDIR /app

# Copy package.json and install dependencies
# We assume the context is the root of mekong-cli
COPY package.json package-lock.json ./
RUN npm ci

# Copy the entire project (respecting .dockerignore if we had one)
COPY . .

# Set environment variables
ENV NODE_ENV=production
ENV PROXY_PORT=8081
ENV ANTHROPIC_BASE_URL=http://127.0.0.1:8081
ENV FORCE_COLOR=1

# Create a volume for persistence (optional, depends on provider)
VOLUME /root/.claude
VOLUME /root/.gemini

# Expose Proxy Port
EXPOSE 8081

# Copy startup script
COPY apps/openclaw-worker/start-agi.sh /usr/local/bin/start-agi.sh
RUN chmod +x /usr/local/bin/start-agi.sh

# Entrypoint
CMD ["/usr/local/bin/start-agi.sh"]
