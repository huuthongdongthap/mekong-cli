# Environment variables — copy to .env và điền giá trị thực
# KHÔNG commit file .env vào git!

# ── PostgreSQL ────────────────────────────────────────────────
PG_USER=vibe
PG_PASS=CHANGE_ME_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASS=CHANGE_ME_REDIS_PASSWORD

# ── Cal.com ───────────────────────────────────────────────────
CALCOM_AUTH_SECRET=CHANGE_ME_32_CHAR_RANDOM_STRING
CALCOM_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING

# ── MySQL (Xibo CMS) ──────────────────────────────────────────
MYSQL_ROOT_PASS=CHANGE_ME_MYSQL_ROOT_PASSWORD
MYSQL_USER=xibo
MYSQL_PASS=CHANGE_ME_MYSQL_PASSWORD

# ── Odoo ──────────────────────────────────────────────────────
ODOO_ADMIN_PASS=CHANGE_ME_ODOO_MASTER_PASSWORD

# ── Domain ────────────────────────────────────────────────────
DOMAIN=vibecafe.vn
ADMIN_EMAIL=admin@vibecafe.vn

# ── SePay VietQR ──────────────────────────────────────────────
SEPAY_API_KEY=CHANGE_ME
SEPAY_MERCHANT_ID=CHANGE_ME

# ── SMS OTP (eSMS.vn) ─────────────────────────────────────────
ESMS_API_KEY=CHANGE_ME
ESMS_SECRET_KEY=CHANGE_ME
