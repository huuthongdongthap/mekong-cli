{
  "id": "raas-create",
  "name": "RaaS Product Create",
  "description": "Full pipeline: scaffold -> features -> deploy. 5 commands, ~45 min.",
  "trigger": "/raas:create",
  "output_dir": "apps/$ARGUMENTS",
  "estimated_credits": 30,
  "estimated_minutes": 45,
  "dag": {
    "groups": [
      {
        "id": "scaffold",
        "name": "Scaffold Project",
        "mode": "sequential",
        "commands": [
          { "id": "raas-scaffold", "args": "$ARGUMENTS --type saas --stack next+cf" }
        ],
        "depends_on": []
      },
      {
        "id": "features",
        "name": "Build Core Features",
        "mode": "sequential",
        "commands": [
          { "id": "cook", "args": "Build landing page with hero, features grid, pricing for $ARGUMENTS" },
          { "id": "cook", "args": "Build dashboard with auth, stats cards, navigation for $ARGUMENTS" },
          { "id": "cook", "args": "Build billing integration with NOWPayments webhooks for $ARGUMENTS" }
        ],
        "depends_on": ["scaffold"]
      },
      {
        "id": "deploy",
        "name": "Test & Deploy",
        "mode": "sequential",
        "commands": [
          { "id": "test", "args": "--all" },
          { "id": "deploy", "args": "$ARGUMENTS --to cloudflare-pages" }
        ],
        "depends_on": ["features"]
      }
    ]
  }
}
