{
  "id": "dev-design",
  "name": "Dev Technical Design",
  "description": "Research technical options and produce a design document for the proposed solution.",
  "version": "1.0.0",
  "layer": "dev",
  "trigger": "/dev:design",
  "input": "$ARGUMENTS",
  "output_dir": "reports/dev/design",
  "estimated_credits": 3,
  "estimated_minutes": 10,
  "dag": {
    "groups": [
      {
        "id": "research",
        "name": "Research Options",
        "mode": "parallel",
        "commands": [
          { "id": "dev-audit", "args": "--output reports/dev/design/codebase-context.md" },
          { "id": "worker-scan", "args": "--types --output reports/dev/design/type-analysis.md" }
        ],
        "depends_on": []
      },
      {
        "id": "design-doc",
        "name": "Write Design Doc",
        "mode": "sequential",
        "commands": [
          { "id": "worker-code", "args": "--output reports/dev/design/design-doc.md" }
        ],
        "depends_on": ["research"]
      }
    ],
    "on_complete": {
      "compile_summary": true,
      "summary_file": "reports/dev/design/SUMMARY.md",
      "template": "Compile codebase context, type analysis, and design doc into a technical design document with: problem statement, proposed solution, architecture diagram, API contracts, edge cases, and open questions."
    }
  }
}
