{
  "id": "pm-okr",
  "name": "PM OKR Framework",
  "description": "Transform project goals into a structured OKR document with key results and tracking metrics.",
  "version": "1.0.0",
  "layer": "pm",
  "trigger": "/pm:okr",
  "input": "$ARGUMENTS",
  "output_dir": "reports/pm/okr",
  "estimated_credits": 3,
  "estimated_minutes": 10,
  "dag": {
    "groups": [
      {
        "id": "define-goals",
        "name": "Define Goals",
        "mode": "sequential",
        "commands": [
          { "id": "pm-scope", "args": "--output reports/pm/okr/goals.md" }
        ],
        "depends_on": []
      },
      {
        "id": "write-okr",
        "name": "Write OKR Document",
        "mode": "sequential",
        "commands": [
          { "id": "pm-milestone", "args": "--output reports/pm/okr/okr-doc.md" }
        ],
        "depends_on": ["define-goals"]
      }
    ],
    "on_complete": {
      "compile_summary": true,
      "summary_file": "reports/pm/okr/SUMMARY.md",
      "template": "Compile goals and milestones into a formal OKR document with: objectives, key results, measurement criteria, owner assignments, and quarterly review schedule."
    }
  }
}
