{
  "id": "pm-delegate",
  "name": "PM Task Delegation",
  "description": "Decompose project goals into atomic tasks and route each to the appropriate dev:* command.",
  "version": "1.0.0",
  "layer": "pm",
  "trigger": "/pm:delegate",
  "input": "$ARGUMENTS",
  "output_dir": "reports/pm/delegate",
  "estimated_credits": 3,
  "estimated_minutes": 10,
  "dag": {
    "groups": [
      {
        "id": "decompose",
        "name": "Decompose Goals",
        "mode": "sequential",
        "commands": [
          { "id": "pm-backlog", "args": "--output reports/pm/delegate/task-breakdown.md" }
        ],
        "depends_on": []
      },
      {
        "id": "route",
        "name": "Route to Dev Commands",
        "mode": "sequential",
        "commands": [
          { "id": "pm-sprint", "args": "--output reports/pm/delegate/assignments.md" }
        ],
        "depends_on": ["decompose"]
      }
    ],
    "on_complete": {
      "compile_summary": true,
      "summary_file": "reports/pm/delegate/SUMMARY.md",
      "template": "Compile task breakdown and assignments into a delegation plan with: task list, owner per task, command to invoke, priority, and expected outputs."
    }
  }
}
