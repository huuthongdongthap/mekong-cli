# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=agency_os
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:password@localhost:5432/agency_os?schema=public

# Redis Configuration
