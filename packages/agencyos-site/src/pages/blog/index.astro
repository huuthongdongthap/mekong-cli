---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/base-layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('vi-VN', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}
---

<BaseLayout
  title="Blog — OpenClaw"
  description="Câu chuyện, insights và bài học từ hành trình xây dựng OpenClaw — nền tảng AI vận hành doanh nghiệp tự động."
  lang="vi"
  canonical="/blog"
>
  <section class="blog-hero">
    <div class="container">
      <p class="label" style="margin-bottom:12px;">Nhật ký Founder</p>
      <h1 class="headline gradient-text" style="margin-bottom:16px;">Blog</h1>
      <p class="subheadline" style="max-width:520px;">
        Câu chuyện, insights và bài học từ hành trình xây dựng AI cho doanh nghiệp.
      </p>
    </div>
  </section>

  <section class="container blog-list">
    {posts.length === 0 && (
      <p style="color:var(--md-on-surface-muted);text-align:center;padding:64px 0;">
        Chưa có bài viết nào. Quay lại sớm nhé!
      </p>
    )}

    <div class="post-grid">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="post-card card" aria-label={post.data.title}>
          <div class="post-meta">
            <time datetime={post.data.date} style="color:var(--md-on-surface-muted);font-size:0.8rem;">
              {formatDate(post.data.date)}
            </time>
            <span style="color:var(--md-on-surface-muted);font-size:0.8rem;">·</span>
            <span style="color:var(--md-on-surface-muted);font-size:0.8rem;">{post.data.author}</span>
          </div>
          <h2 class="post-title">{post.data.title}</h2>
          <p class="post-desc">{post.data.description}</p>
          <div class="tag-list">
            {post.data.tags.slice(0, 3).map(tag => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
          <span class="read-more">Đọc tiếp →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    padding: 80px 0 48px;
    border-bottom: 1px solid var(--md-outline);
  }

  .blog-list {
    padding: 64px 0 96px;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 28px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .post-title {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--md-on-surface);
    transition: color 0.2s;
  }

  .post-card:hover .post-title {
    color: var(--md-primary);
  }

  .post-desc {
    font-size: 0.9rem;
    color: var(--md-on-surface-muted);
    line-height: 1.65;
    flex: 1;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--md-primary);
    background: rgba(0, 188, 212, 0.1);
    border: 1px solid rgba(0, 188, 212, 0.2);
    border-radius: 6px;
    padding: 2px 8px;
  }

  .read-more {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--md-primary);
    margin-top: 4px;
  }

  @media (max-width: 640px) {
    .blog-hero { padding: 48px 0 32px; }
    .post-grid { grid-template-columns: 1fr; }
  }
</style>
