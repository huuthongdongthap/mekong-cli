---
import BaseLayout from '../layouts/base-layout.astro';
---

<BaseLayout title="Doanh Nghiệp — OpenClaw Enterprise" description="Giải pháp AI agent cho doanh nghiệp lớn. On-premise, SLA 99.99%, dedicated support." lang="vi">
  <section style="background:linear-gradient(135deg,#0a0f1a,#1a0a30 60%,#0a1a30);padding:80px 0 56px;text-align:center;">
    <div class="container">
      <div class="badge animate-in" style="margin-bottom:16px;">Enterprise</div>
      <h1 class="display animate-in">
        AI Agent cho <span style="background:linear-gradient(135deg,#7C4DFF,#00BCD4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Doanh Nghiệp</span>
      </h1>
      <p style="color:var(--md-on-surface-muted);max-width:560px;margin:0 auto 32px;" class="animate-in">
        On-premise deployment. SLA 99.99%. Dedicated support manager. Custom AI model theo ngành.
      </p>
      <a href="mailto:hello@agencyos.network" class="btn-primary animate-in" style="background:linear-gradient(135deg,#7C4DFF,#00BCD4);border:none;">
        Liên hệ tư vấn Enterprise
      </a>
    </div>
  </section>

  <section style="background:var(--md-surface);padding:64px 0;">
    <div class="container" style="max-width:800px;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:24px;">
        <div class="animate-on-scroll" style="padding:28px 24px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;">
          <p style="font-size:2rem;margin:0 0 12px;">🔒</p>
          <h3 style="font-size:1rem;font-weight:700;color:var(--md-on-surface);margin:0 0 8px;">On-Premise</h3>
          <p style="color:var(--md-on-surface-muted);font-size:0.875rem;margin:0;line-height:1.6;">Deploy trên infra của bạn. Data không rời hệ thống.</p>
        </div>
        <div class="animate-on-scroll" style="padding:28px 24px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;">
          <p style="font-size:2rem;margin:0 0 12px;">⚡</p>
          <h3 style="font-size:1rem;font-weight:700;color:var(--md-on-surface);margin:0 0 8px;">SLA 99.99%</h3>
          <p style="color:var(--md-on-surface-muted);font-size:0.875rem;margin:0;line-height:1.6;">Cam kết uptime. Dedicated support 24/7.</p>
        </div>
        <div class="animate-on-scroll" style="padding:28px 24px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;">
          <p style="font-size:2rem;margin:0 0 12px;">🤖</p>
          <h3 style="font-size:1rem;font-weight:700;color:var(--md-on-surface);margin:0 0 8px;">Custom AI</h3>
          <p style="color:var(--md-on-surface-muted);font-size:0.875rem;margin:0;line-height:1.6;">Model AI fine-tune theo ngành nghề cụ thể.</p>
        </div>
        <div class="animate-on-scroll" style="padding:28px 24px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;">
          <p style="font-size:2rem;margin:0 0 12px;">🔗</p>
          <h3 style="font-size:1rem;font-weight:700;color:var(--md-on-surface);margin:0 0 8px;">API Full</h3>
          <p style="color:var(--md-on-surface-muted);font-size:0.875rem;margin:0;line-height:1.6;">REST + WebSocket API. Tích hợp mọi hệ thống.</p>
        </div>
        <div class="animate-on-scroll" style="padding:28px 24px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;">
          <p style="font-size:2rem;margin:0 0 12px;">👥</p>
          <h3 style="font-size:1rem;font-weight:700;color:var(--md-on-surface);margin:0 0 8px;">Multi-Tenant</h3>
          <p style="color:var(--md-on-surface-muted);font-size:0.875rem;margin:0;line-height:1.6;">Nhiều workspace, phân quyền chi tiết.</p>
        </div>
        <div class="animate-on-scroll" style="padding:28px 24px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;">
          <p style="font-size:2rem;margin:0 0 12px;">📊</p>
          <h3 style="font-size:1rem;font-weight:700;color:var(--md-on-surface);margin:0 0 8px;">Audit Log</h3>
          <p style="color:var(--md-on-surface-muted);font-size:0.875rem;margin:0;line-height:1.6;">Log đầy đủ cho compliance và bảo mật.</p>
        </div>
      </div>
    </div>
  </section>

  <section style="background:var(--md-surface-container);padding:64px 0;text-align:center;">
    <div class="container" style="max-width:560px;">
      <h2 class="headline animate-on-scroll" style="margin-bottom:16px;">Bắt đầu với Enterprise</h2>
      <p style="color:var(--md-on-surface-muted);margin-bottom:32px;" class="animate-on-scroll">
        Đội ngũ sẽ tư vấn giải pháp phù hợp nhất cho doanh nghiệp của bạn.
      </p>
      <a href="mailto:hello@agencyos.network" class="btn-primary animate-on-scroll" style="background:linear-gradient(135deg,#7C4DFF,#00BCD4);border:none;">
        hello@agencyos.network
      </a>
    </div>
  </section>
</BaseLayout>
