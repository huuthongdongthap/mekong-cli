---
import BaseLayout from '../../layouts/base-layout.astro';

const features = [
  {
    icon: '📝',
    title: 'AI Tạo Proposal',
    desc: 'Tự động tạo proposal chuyên nghiệp, cá nhân hóa theo từng khách hàng trong 60 giây.',
    outcome: 'Tiết kiệm 3-5 giờ/proposal → gửi đi nhanh hơn, thắng nhiều deal hơn',
  },
  {
    icon: '🎯',
    title: 'RaaS Licensing',
    desc: 'Hệ thống cấp phép MCU-based. Metering chính xác, billing minh bạch theo mức dùng thực tế.',
    outcome: 'Kiểm soát chi phí AI — trả đúng bằng lượng dùng, không lãng phí',
  },
  {
    icon: '📡',
    title: 'Outreach Đa Kênh',
    desc: 'Tự động hóa tiếp cận khách qua email, Telegram, và nhiều kênh khác cùng lúc.',
    outcome: 'Tăng 3x touchpoints với khách tiềm năng mà không cần thêm nhân sự',
  },
  {
    icon: '🗂️',
    title: 'CRM & Pipeline',
    desc: 'Quản lý toàn bộ vòng đời deal — từ lead đến close — trên một dashboard duy nhất.',
    outcome: 'Không bỏ sót deal nào. Pipeline rõ ràng, dự báo doanh thu chính xác hơn',
  },
  {
    icon: '🔒',
    title: 'GDPR & Audit',
    desc: 'Tuân thủ GDPR đầy đủ. Audit log tự động cho mọi hành động trong hệ thống.',
    outcome: 'Tự tin với khách EU/quốc tế. Không lo pháp lý khi scale',
  },
  {
    icon: '✍️',
    title: 'Content Automation',
    desc: 'AI tự động tạo content marketing, case study, và tài liệu bán hàng theo thương hiệu của bạn.',
    outcome: 'Content đều đặn, đúng giọng brand — không cần thuê thêm copywriter',
  },
];

const steps = [
  {
    num: '01',
    title: 'BYOK — Mang key của bạn',
    time: '5 phút',
    desc: 'Kết nối API key LLM của bạn (OpenAI, Anthropic, v.v.). Sophia chạy trên infra của bạn — zero secret storage.',
  },
  {
    num: '02',
    title: 'Cấu hình Agency',
    time: '15 phút',
    desc: 'Upload brand guide, template proposal, danh sách khách hàng. AI học cách viết theo giọng điệu của agency bạn.',
  },
  {
    num: '03',
    title: 'AI vận hành tự động',
    time: '24/7',
    desc: 'Từ lúc này Sophia tự động tạo proposal, theo dõi pipeline, gửi outreach và báo cáo hàng ngày.',
  },
];

const testimonials = [
  {
    name: 'Bảo Nguyễn',
    role: 'Founder, Digital Agency HCM',
    text: 'Trước mất 4 tiếng làm một proposal. Giờ Sophia làm trong 60 giây, team mình chỉ cần review và gửi đi.',
    avatar: '👨‍💼',
    result: '-90% thời gian proposal',
    verified: true,
  },
  {
    name: 'Lan Phương',
    role: 'Sales Director, Marketing Agency',
    text: 'Outreach tự động qua Telegram giúp mình reach 5x khách tiềm năng mỗi tuần mà không tốn sức.',
    avatar: '👩‍💼',
    result: '5x pipeline volume',
    verified: true,
  },
  {
    name: 'Trung Kiên',
    role: 'CTO, SaaS Company SEA',
    text: 'BYOK model là game-changer. Chúng tôi control toàn bộ data, không bao giờ lo lộ thông tin khách hàng.',
    avatar: '👨‍💻',
    result: '100% data control',
    verified: true,
  },
];

const stats = [
  { value: '60s', label: 'Tạo proposal AI' },
  { value: '3x', label: 'Tăng outreach' },
  { value: '100%', label: 'BYOK & GDPR' },
  { value: '24/7', label: 'Tự động hóa' },
];

const sophiaSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Sophia AI Factory',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description: 'AI-powered proposal & sales automation platform cho digital agencies tại Đông Nam Á. BYOK model.',
  offers: {
    '@type': 'Offer',
    price: '199',
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: 'https://agencyos.network/sophia/pricing',
  },
};
---

<BaseLayout
  title="Sophia AI Factory — Tự Động Hóa Sales & Proposal Cho Agency"
  description="AI tạo proposal chuyên nghiệp trong 60 giây. Quản lý pipeline, outreach đa kênh, GDPR-ready. BYOK — chạy trên infra của bạn."
  lang="vi"
  keywords="sophia ai factory, proposal automation, AI agency, sales automation, BYOK, SEA digital agency"
>

  <!-- Hero -->
  <section style="background:linear-gradient(135deg,#0a0f1a,#1a0a30 60%,#0a1a30);padding:96px 0 72px;text-align:center;">
    <div class="container">
      <div class="badge animate-in" style="margin-bottom:20px;background:rgba(124,77,255,0.15);border-color:rgba(124,77,255,0.3);color:#a78bfa;">
        Sophia AI Factory
      </div>
      <h1 class="display animate-in" style="margin-bottom:20px;font-size:clamp(2rem,5vw,3.5rem);line-height:1.15;">
        Tự Động Hóa <span style="background:linear-gradient(135deg,#7C4DFF,#00BCD4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Sales & Proposal</span><br/>
        Cho Agency Của Bạn
      </h1>
      <p style="color:var(--md-on-surface-muted);max-width:560px;margin:0 auto 16px;font-size:1.15rem;line-height:1.7;" class="animate-in">
        AI tạo proposal chuyên nghiệp trong <strong style="color:#a78bfa;">60 giây</strong>. Quản lý pipeline, outreach đa kênh, GDPR-ready.
      </p>
      <p style="color:var(--md-on-surface-muted);max-width:480px;margin:0 auto 40px;font-size:0.95rem;" class="animate-in">
        BYOK model — bạn mang API key, Sophia chạy trên infra của bạn. Zero secret storage, 100% data control.
      </p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;" class="animate-in">
        <a href="/sophia/pricing" class="btn-primary" style="background:linear-gradient(135deg,#7C4DFF,#00BCD4);border:none;">
          Dùng thử Sophia →
        </a>
        <a href="#how-it-works" class="btn-outline">
          Xem cách hoạt động
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section style="background:rgba(124,77,255,0.08);border-top:1px solid rgba(124,77,255,0.2);border-bottom:1px solid rgba(124,77,255,0.2);padding:32px 0;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:24px;text-align:center;">
        {stats.map(s => (
          <div class="animate-on-scroll">
            <div style="font-size:2rem;font-weight:800;background:linear-gradient(135deg,#7C4DFF,#00BCD4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">{s.value}</div>
            <div style="font-size:0.875rem;color:var(--md-on-surface-muted);margin-top:4px;">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section style="background:var(--md-surface);padding:80px 0;">
    <div class="container">
      <div style="text-align:center;margin-bottom:56px;">
        <div class="badge animate-on-scroll" style="margin-bottom:12px;">Tính năng</div>
        <h2 class="headline animate-on-scroll" style="margin-bottom:12px;">
          Mọi thứ agency cần để <span style="background:linear-gradient(135deg,#7C4DFF,#00BCD4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">scale nhanh hơn</span>
        </h2>
        <p style="color:var(--md-on-surface-muted);max-width:480px;margin:0 auto;" class="animate-on-scroll">
          Từ tạo proposal đến close deal — Sophia tự động hóa toàn bộ quy trình sales.
        </p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;">
        {features.map(f => (
          <div class="card animate-on-scroll" style="padding:28px;border:1px solid rgba(124,77,255,0.15);background:rgba(124,77,255,0.04);border-radius:12px;">
            <div style="font-size:2rem;margin-bottom:16px;">{f.icon}</div>
            <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:8px;color:var(--md-on-surface);">{f.title}</h3>
            <p style="color:var(--md-on-surface-muted);font-size:0.9rem;line-height:1.6;margin-bottom:14px;">{f.desc}</p>
            <div style="background:rgba(0,188,212,0.08);border-left:3px solid #00BCD4;padding:8px 12px;border-radius:0 6px 6px 0;">
              <p style="font-size:0.8rem;color:#67e8f9;margin:0;font-style:italic;">{f.outcome}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how-it-works" style="background:var(--md-surface-container);padding:80px 0;">
    <div class="container" style="max-width:800px;">
      <div style="text-align:center;margin-bottom:56px;">
        <div class="badge animate-on-scroll" style="margin-bottom:12px;">Cách hoạt động</div>
        <h2 class="headline animate-on-scroll">
          Chạy trong <span style="background:linear-gradient(135deg,#7C4DFF,#00BCD4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">3 bước đơn giản</span>
        </h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:32px;">
        {steps.map((step, i) => (
          <div class="animate-on-scroll" style="display:flex;gap:24px;align-items:flex-start;">
            <div style="flex-shrink:0;width:56px;height:56px;background:linear-gradient(135deg,#7C4DFF,#00BCD4);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800;color:#fff;">
              {step.num}
            </div>
            <div style="flex:1;padding-top:8px;">
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
                <h3 style="font-size:1.05rem;font-weight:700;color:var(--md-on-surface);margin:0;">{step.title}</h3>
                <span style="background:rgba(0,188,212,0.15);color:#67e8f9;font-size:0.75rem;font-weight:600;padding:3px 10px;border-radius:100px;">{step.time}</span>
              </div>
              <p style="color:var(--md-on-surface-muted);font-size:0.9rem;line-height:1.6;margin:0;">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section style="background:var(--md-surface);padding:80px 0;">
    <div class="container">
      <div style="text-align:center;margin-bottom:48px;">
        <div class="badge animate-on-scroll" style="margin-bottom:12px;">Khách hàng nói gì</div>
        <h2 class="headline animate-on-scroll">
          Agency thực tế, kết quả thực tế
        </h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;">
        {testimonials.map(t => (
          <div class="card animate-on-scroll" style="padding:28px;border:1px solid rgba(124,77,255,0.15);border-radius:12px;display:flex;flex-direction:column;gap:16px;">
            <div style="font-size:1.5rem;line-height:1.5;color:var(--md-on-surface);font-style:italic;">"{t.text}"</div>
            <div style="margin-top:auto;padding-top:16px;border-top:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:12px;">
              <div style="font-size:2rem;">{t.avatar}</div>
              <div>
                <div style="font-weight:700;font-size:0.9rem;color:var(--md-on-surface);">{t.name}</div>
                <div style="font-size:0.8rem;color:var(--md-on-surface-muted);">{t.role}</div>
              </div>
              <div style="margin-left:auto;background:rgba(124,77,255,0.15);color:#a78bfa;font-size:0.75rem;font-weight:700;padding:4px 10px;border-radius:100px;white-space:nowrap;">
                {t.result}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA footer -->
  <section style="background:linear-gradient(135deg,#1a0a30,#0a1a30);padding:80px 0;text-align:center;">
    <div class="container" style="max-width:600px;">
      <h2 class="headline animate-on-scroll" style="margin-bottom:16px;">
        Sẵn sàng để AI làm việc cho agency của bạn?
      </h2>
      <p style="color:var(--md-on-surface-muted);margin-bottom:40px;font-size:1rem;" class="animate-on-scroll">
        Bắt đầu với Sophia AI Factory ngay hôm nay. BYOK, không lock-in, huỷ bất cứ lúc nào.
      </p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;" class="animate-on-scroll">
        <a href="/sophia/pricing" class="btn-primary" style="background:linear-gradient(135deg,#7C4DFF,#00BCD4);border:none;">
          Xem bảng giá Sophia →
        </a>
        <a href="mailto:hello@agencyos.network" class="btn-outline">
          Liên hệ tư vấn
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(sophiaSchema)} />

</BaseLayout>
