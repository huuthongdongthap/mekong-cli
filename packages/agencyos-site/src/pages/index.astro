---
import BaseLayout from '../layouts/base-layout.astro';

const products = [
  {
    id: 'sophia',
    icon: '🎬',
    name: 'Sophia AI Factory',
    tagline: 'Video Factory + AI Automation',
    desc: 'Tạo video chuyên nghiệp, tự động hóa quy trình sản xuất nội dung. RaaS platform — thuê AI như thuê nhân sự.',
    href: 'https://sophia.agencyos.network',
    badge: 'RaaS',
    pricing: '$199 – $4,999/mo',
    features: ['Video production tự động', 'AI content pipeline', 'RaaS billing (MCU)'],
    gradient: 'linear-gradient(135deg, rgba(124,77,255,0.15), rgba(0,188,212,0.08))',
    border: 'rgba(124,77,255,0.3)',
    badgeColor: '#7C4DFF',
  },
  {
    id: 'cashclaw',
    icon: '📈',
    name: 'CashClaw',
    tagline: 'Prediction Market Trading Bot',
    desc: 'Trading bot cho Polymarket. Phân tích xác suất, thực thi lệnh, quản lý rủi ro tự động. Dữ liệu thực — không có backtesting ảo.',
    href: 'https://cashclaw.cc',
    badge: 'LIVE',
    pricing: '$49 – $499/mo',
    features: ['Polymarket integration', 'DeepSeek R1 analysis', 'Risk management engine'],
    gradient: 'linear-gradient(135deg, rgba(0,188,212,0.15), rgba(0,230,118,0.08))',
    border: 'rgba(0,188,212,0.3)',
    badgeColor: '#00BCD4',
  },
  {
    id: 'openclaw',
    icon: '⚡',
    name: 'OpenClaw CLI',
    tagline: '342+ Business Commands',
    desc: 'Mekong CLI mã nguồn mở. 342+ lệnh AI cho mọi tầng doanh nghiệp — từ chiến lược đến deploy. Chạy trên bất kỳ LLM nào.',
    href: 'https://github.com/longtho638-jpg/mekong-cli',
    badge: 'Open Source',
    pricing: 'Miễn phí',
    features: ['342+ CLI commands', '6 tầng doanh nghiệp', 'Universal LLM adapter'],
    gradient: 'linear-gradient(135deg, rgba(255,167,38,0.12), rgba(124,77,255,0.08))',
    border: 'rgba(255,167,38,0.3)',
    badgeColor: '#FFA726',
  },
];

const stats = [
  { value: '342+', label: 'Lệnh AI', desc: 'CLI commands sẵn dùng' },
  { value: '3', label: 'Sản phẩm', desc: 'Production-ready' },
  { value: '100%', label: 'Cloudflare', desc: 'Zero downtime infra' },
];

const ecosystemSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "AgencyOS",
  "url": "https://agencyos.network",
  "description": "Hệ sinh thái AI gồm 3 sản phẩm: Sophia AI Factory, CashClaw, OpenClaw CLI",
  "sameAs": ["https://github.com/longtho638-jpg/mekong-cli"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "AgencyOS Ecosystem",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "SoftwareApplication", "name": "Sophia AI Factory", "url": "https://sophia.agencyos.network", "applicationCategory": "VideoApplication" } },
      { "@type": "Offer", "itemOffered": { "@type": "SoftwareApplication", "name": "CashClaw", "url": "https://cashclaw.cc", "applicationCategory": "FinanceApplication" } },
      { "@type": "Offer", "itemOffered": { "@type": "SoftwareApplication", "name": "OpenClaw CLI", "url": "https://github.com/longtho638-jpg/mekong-cli", "applicationCategory": "DeveloperApplication" } }
    ]
  }
};
---

<BaseLayout
  title="AgencyOS — Hệ Sinh Thái AI: Sophia · CashClaw · OpenClaw"
  description="3 sản phẩm AI production-ready. Sophia: video + RaaS. CashClaw: Polymarket trading. OpenClaw: 342+ business commands. Tất cả trên Cloudflare."
  lang="vi"
  type="website"
  canonical="/"
  keywords="AgencyOS, Sophia AI Factory, CashClaw trading bot, OpenClaw CLI, hệ sinh thái AI, Polymarket, video automation, mekong-cli"
>

  <script type="application/ld+json" set:html={JSON.stringify(ecosystemSchema)} />

  <!-- HERO -->
  <section class="hero-section" aria-label="AgencyOS Ecosystem">
    <div class="mesh-orb orb-1" aria-hidden="true"></div>
    <div class="mesh-orb orb-2" aria-hidden="true"></div>
    <div class="mesh-orb orb-3" aria-hidden="true"></div>

    <div class="container" style="padding-top:96px;padding-bottom:80px;text-align:center;">
      <div class="hero-badge animate-in" style="margin-bottom:24px;">
        <span class="badge-icon" aria-hidden="true">🌐</span>
        <span class="badge-text">Hệ Sinh Thái AI Cho Doanh Nghiệp</span>
      </div>

      <h1 class="display animate-in" style="margin-bottom:20px;animation-delay:0.1s;">
        <span class="gradient-text">3 Sản Phẩm.</span><br />
        <span class="gradient-text-highlight">1 Tầm Nhìn.</span>
      </h1>

      <p class="hero-description animate-in" style="margin-bottom:40px;max-width:600px;margin-left:auto;margin-right:auto;">
        Sophia tạo video + RaaS. CashClaw giao dịch Polymarket. OpenClaw tự động hóa mọi quy trình.<br />
        Tất cả chạy trên Cloudflare — không downtime, không vendor lock-in.
      </p>

      <!-- Stats -->
      <div class="stats-row animate-in" style="margin-bottom:56px;" aria-label="Thống kê thực">
        {stats.map((s) => (
          <div class="stat-item">
            <div class="stat-value">{s.value}</div>
            <div class="stat-label">{s.label}</div>
            <div class="stat-desc">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section id="products" style="background:var(--md-surface-container);padding:80px 0;" aria-label="Sản phẩm">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">Sản phẩm</div>
        <h2 class="headline">Chỉ những gì <span class="gradient-text">thực sự tồn tại</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:480px;margin:16px auto 0;">
          Không hứa hẹn tính năng chưa xây. Mỗi sản phẩm đang chạy production.
        </p>
      </div>

      <div class="products-grid">
        {products.map((p, i) => (
          <a
            href={p.href}
            target={p.id === 'openclaw' ? '_blank' : '_self'}
            rel={p.id === 'openclaw' ? 'noopener noreferrer' : ''}
            class="product-card animate-on-scroll"
            style={`animation-delay:${i * 0.12}s; background:${p.gradient}; border:1px solid ${p.border};`}
            aria-label={`${p.name} — ${p.tagline}`}
          >
            <div class="product-header">
              <span class="product-icon" aria-hidden="true">{p.icon}</span>
              <span class="product-badge" style={`background:${p.badgeColor}22; color:${p.badgeColor}; border:1px solid ${p.badgeColor}44;`}>{p.badge}</span>
            </div>
            <h3 class="product-name">{p.name}</h3>
            <p class="product-tagline">{p.tagline}</p>
            <p class="product-desc">{p.desc}</p>
            <ul class="product-features" aria-label={`Tính năng ${p.name}`}>
              {p.features.map(f => (
                <li><span style={`color:${p.badgeColor};`} aria-hidden="true">✓</span> {f}</li>
              ))}
            </ul>
            <div class="product-footer">
              <span class="product-price">{p.pricing}</span>
              <span class="product-arrow" aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY CLOUDFLARE -->
  <section style="background:var(--md-surface);padding:80px 0;" aria-label="Kiến trúc">
    <div class="container" style="max-width:800px;">
      <div class="text-center animate-on-scroll" style="margin-bottom:48px;">
        <div class="badge" style="margin-bottom:16px;">Kiến trúc</div>
        <h2 class="headline">Xây trên <span class="gradient-text">Cloudflare</span> — không phải máy chủ riêng</h2>
      </div>
      <div class="arch-grid animate-on-scroll">
        <div class="arch-item">
          <span class="arch-icon" aria-hidden="true">⚡</span>
          <div>
            <strong>Zero Cold Start</strong>
            <p>Cloudflare Workers — edge computing toàn cầu, phản hồi &lt;50ms</p>
          </div>
        </div>
        <div class="arch-item">
          <span class="arch-icon" aria-hidden="true">🔒</span>
          <div>
            <strong>Bảo mật mặc định</strong>
            <p>DDoS protection, WAF, SSL tự động — không cần cấu hình thêm</p>
          </div>
        </div>
        <div class="arch-item">
          <span class="arch-icon" aria-hidden="true">💰</span>
          <div>
            <strong>Chi phí tối thiểu</strong>
            <p>Pages + Workers + D1 + KV + R2 — gần như $0 infra cost</p>
          </div>
        </div>
        <div class="arch-item">
          <span class="arch-icon" aria-hidden="true">🌍</span>
          <div>
            <strong>Global Edge</strong>
            <p>300+ PoPs — người dùng ở Việt Nam hay Mỹ đều có latency thấp</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--md-surface-container);padding:80px 0;" aria-label="Bắt đầu">
    <div class="container">
      <div class="animate-on-scroll" style="background:linear-gradient(135deg,rgba(0,188,212,0.08),rgba(124,77,255,0.1));border:1px solid rgba(0,188,212,0.2);border-radius:var(--md-radius);padding:72px 40px;text-align:center;position:relative;overflow:hidden;">
        <div style="position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(124,77,255,0.15),transparent 70%);pointer-events:none;" aria-hidden="true"></div>
        <h2 class="headline" style="margin-bottom:16px;">Bắt đầu với sản phẩm <span class="gradient-text">phù hợp nhất</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:480px;margin:0 auto 40px;">
          Chọn Sophia nếu cần tự động hóa nội dung. Chọn CashClaw nếu giao dịch Polymarket. Dùng OpenClaw CLI ngay hôm nay — miễn phí, mã nguồn mở.
        </p>
        <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
          <a href="https://sophia.agencyos.network" class="btn-primary" style="font-size:1rem;padding:14px 32px;">Sophia AI Factory →</a>
          <a href="https://cashclaw.cc" class="btn-outline" style="font-size:1rem;padding:14px 32px;">CashClaw →</a>
          <a href="https://github.com/longtho638-jpg/mekong-cli" target="_blank" rel="noopener noreferrer" class="btn-outline" style="font-size:1rem;padding:14px 32px;">OpenClaw CLI →</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Hero */
    .hero-section {
      background: linear-gradient(135deg, #0a0f1a, #1a1040 60%, #0a2030);
      position: relative;
      overflow: hidden;
    }

    .stats-row {
      display: flex;
      justify-content: center;
      gap: 48px;
      flex-wrap: wrap;
    }
    .stat-item {
      text-align: center;
    }
    .stat-value {
      font-family: 'Be Vietnam Pro', sans-serif;
      font-size: 2.2rem;
      font-weight: 800;
      background: linear-gradient(135deg, #00BCD4, #7C4DFF);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .stat-label {
      font-weight: 700;
      font-size: 0.95rem;
      margin-top: 4px;
    }
    .stat-desc {
      font-size: 0.8rem;
      color: var(--md-on-surface-muted);
      margin-top: 2px;
    }

    /* Products grid */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
    }
    .product-card {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 32px;
      border-radius: var(--md-radius);
      text-decoration: none;
      color: inherit;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      cursor: pointer;
    }
    .product-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 48px rgba(0,0,0,0.2);
    }
    .product-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 4px;
    }
    .product-icon {
      font-size: 2.4rem;
    }
    .product-badge {
      font-size: 0.72rem;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 100px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .product-name {
      font-size: 1.35rem;
      font-weight: 800;
      margin: 0;
    }
    .product-tagline {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--md-primary);
      margin: 0;
    }
    .product-desc {
      font-size: 0.9rem;
      color: var(--md-on-surface-muted);
      line-height: 1.65;
      margin: 0;
      flex: 1;
    }
    .product-features {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .product-features li {
      font-size: 0.85rem;
      color: var(--md-on-surface-muted);
      display: flex;
      gap: 8px;
      align-items: center;
    }
    .product-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 8px;
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .product-price {
      font-weight: 700;
      font-size: 0.95rem;
    }
    .product-arrow {
      font-size: 1.2rem;
      transition: transform 0.2s ease;
    }
    .product-card:hover .product-arrow {
      transform: translateX(4px);
    }

    /* Architecture */
    .arch-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 24px;
    }
    .arch-item {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      padding: 24px;
      background: var(--md-surface-container);
      border: 1px solid var(--md-outline);
      border-radius: var(--md-radius);
    }
    .arch-icon {
      font-size: 1.8rem;
      flex-shrink: 0;
    }
    .arch-item strong {
      display: block;
      font-size: 1rem;
      margin-bottom: 6px;
    }
    .arch-item p {
      font-size: 0.875rem;
      color: var(--md-on-surface-muted);
      margin: 0;
      line-height: 1.6;
    }

    @media (max-width: 640px) {
      .stats-row { gap: 24px; }
      .product-card { padding: 24px; }
    }
  </style>

</BaseLayout>
