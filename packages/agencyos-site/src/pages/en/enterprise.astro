---
import BaseLayout from '../../layouts/base-layout.astro';
---

<BaseLayout
  title="OpenClaw Enterprise — Your Own AI Team | SLA 99.9% | White-label"
  description="Unlimited MCU. SLA 99.9%. White-label. Deploy your own AI workforce. Calculate ROI now — save thousands per month vs. headcount."
  lang="en"
  type="website"
  canonical="/en/enterprise"
  keywords="enterprise AI, unlimited MCU, white-label AI, SLA 99.9%, AI for business, ROI calculator, agency AI, Southeast Asia"
  ogTitle="OpenClaw Enterprise — Your Own AI Workforce"
  ogDescription="Unlimited MCU. SLA 99.9%. White-label. Calculate ROI — save $10,000+/month vs. manual labor."
>

  <!-- HERO -->
  <section class="ent-hero">
    <div class="container">
      <div class="ent-badge">Enterprise</div>
      <h1 class="display" style="margin-bottom:20px;">
        <span class="gradient-text">OpenClaw for</span><br />Enterprise
      </h1>
      <p class="ent-subtitle">
        Unlimited MCU. SLA 99.9%. White-label.<br />
        Your own AI team — built for your company.
      </p>
      <div class="ent-cta-group">
        <a
          href="mailto:hello@agencyos.network?subject=Enterprise Demo"
          class="btn-primary btn-pulse"
        >
          Book a 15-Minute Demo →
        </a>
        <a href="#roi-calculator" class="btn-outline">Calculate ROI</a>
      </div>
    </div>
  </section>

  <!-- FEATURE CARDS -->
  <section class="ent-features">
    <div class="container">
      <div class="ent-features-grid">

        <div class="ent-card">
          <div class="ent-card-icon">∞</div>
          <h3 class="ent-card-title">Unlimited MCU</h3>
          <p class="ent-card-desc">
            No credit limits, run as much as you need. No mid-month surprises —
            AI runs continuously 24/7 without interruption.
          </p>
        </div>

        <div class="ent-card">
          <div class="ent-card-icon">🛡️</div>
          <h3 class="ent-card-title">SLA &amp; Support</h3>
          <p class="ent-card-desc">
            99.9% uptime guarantee. Dedicated Slack channel for your team.
            Under 4-hour response time — including weekends.
          </p>
        </div>

        <div class="ent-card">
          <div class="ent-card-icon">🏷️</div>
          <h3 class="ent-card-title">White-label</h3>
          <p class="ent-card-desc">
            Custom domain, branding, API keys for your entire team. Launch an AI
            product under your own brand — no one knows you use OpenClaw.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ROI CALCULATOR -->
  <section class="ent-roi" id="roi-calculator">
    <div class="container">
      <div class="ent-roi-wrapper">

        <div class="ent-roi-header">
          <h2 class="headline" style="margin-bottom:8px;">Calculate Your ROI</h2>
          <p class="ent-roi-subtitle">Adjust the inputs below to see how much you save.</p>
        </div>

        <div class="ent-roi-body">

          <!-- Inputs -->
          <div class="ent-roi-inputs">

            <div class="ent-slider-group">
              <div class="ent-slider-label">
                <span>Number of employees</span>
                <span class="ent-slider-value" id="val-employees">10</span>
              </div>
              <input
                type="range"
                id="employees"
                min="5"
                max="100"
                value="10"
                class="ent-slider"
                aria-label="Number of employees"
              />
              <div class="ent-slider-range"><span>5</span><span>100</span></div>
            </div>

            <div class="ent-slider-group">
              <div class="ent-slider-label">
                <span>Manual hours / week</span>
                <span class="ent-slider-value" id="val-hours">20</span>
              </div>
              <input
                type="range"
                id="hours"
                min="5"
                max="40"
                value="20"
                class="ent-slider"
                aria-label="Manual hours per week"
              />
              <div class="ent-slider-range"><span>5h</span><span>40h</span></div>
            </div>

            <div class="ent-slider-group">
              <div class="ent-slider-label">
                <span>Avg. hourly wage (USD)</span>
                <span class="ent-slider-value" id="val-rate">$30</span>
              </div>
              <input
                type="range"
                id="hourlyRate"
                min="10"
                max="100"
                value="30"
                class="ent-slider"
                aria-label="Average hourly wage in USD"
              />
              <div class="ent-slider-range"><span>$10</span><span>$100</span></div>
            </div>

          </div>

          <!-- Output -->
          <div class="ent-roi-output">
            <div class="ent-savings-display">
              <div class="ent-savings-label">Saved per month</div>
              <div class="ent-savings-amount" id="savings-amount">$0</div>
              <div class="ent-roi-badge" id="roi-badge">ROI: 0%</div>
            </div>

            <div class="ent-breakdown">
              <div class="ent-breakdown-row">
                <span class="ent-breakdown-label">Current labor cost / month</span>
                <span class="ent-breakdown-value negative" id="current-cost">$0</span>
              </div>
              <div class="ent-breakdown-row">
                <span class="ent-breakdown-label">OpenClaw Enterprise / month</span>
                <span class="ent-breakdown-value">$499</span>
              </div>
              <div class="ent-breakdown-row ent-breakdown-total">
                <span class="ent-breakdown-label">Net savings</span>
                <span class="ent-breakdown-value positive" id="net-savings">$0</span>
              </div>
            </div>

            <a
              href="mailto:hello@agencyos.network?subject=Enterprise Demo"
              class="btn-primary"
              style="width:100%;text-align:center;margin-top:16px;"
            >
              Book a 15-Minute Demo →
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL PLACEHOLDER -->
  <section class="ent-social">
    <div class="container">
      <p class="ent-social-text">
        Serving agencies and SaaS companies across Vietnam and Southeast Asia
      </p>
      <div class="ent-social-logos" aria-label="Markets served">
        <span class="ent-logo-chip">🇻🇳 Vietnam</span>
        <span class="ent-logo-chip">🇸🇬 Singapore</span>
        <span class="ent-logo-chip">🇹🇭 Thailand</span>
        <span class="ent-logo-chip">🇲🇾 Malaysia</span>
        <span class="ent-logo-chip">🇮🇩 Indonesia</span>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Layout helpers ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Hero ── */
  .ent-hero {
    padding: 100px 0 64px;
    text-align: center;
    position: relative;
  }
  .ent-badge {
    display: inline-block;
    background: linear-gradient(135deg, var(--md-primary), var(--md-secondary));
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }
  .gradient-text {
    background: linear-gradient(135deg, var(--md-primary) 0%, var(--md-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .ent-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: var(--md-on-surface-muted);
    line-height: 1.6;
    margin-bottom: 36px;
  }
  .ent-cta-group {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, var(--md-primary) 0%, var(--md-secondary) 100%);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 28px;
    border-radius: var(--md-radius);
    text-decoration: none;
    transition: var(--md-transition);
    border: none;
    cursor: pointer;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-2px); }
  .btn-pulse {
    animation: pulse 2.5s infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0,188,212,0.35); }
    50% { box-shadow: 0 0 0 10px rgba(0,188,212,0); }
  }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--md-on-surface);
    font-weight: 600;
    font-size: 1rem;
    padding: 14px 28px;
    border-radius: var(--md-radius);
    text-decoration: none;
    border: 1.5px solid var(--md-outline);
    transition: var(--md-transition);
  }
  .btn-outline:hover {
    border-color: var(--md-primary);
    color: var(--md-primary);
    background: rgba(0,188,212,0.06);
  }

  /* ── Feature cards ── */
  .ent-features {
    padding: 64px 0;
  }
  .ent-features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .ent-card {
    background: var(--md-surface-container);
    border: 1px solid var(--md-outline);
    border-radius: var(--md-radius);
    padding: 32px 28px;
    transition: var(--md-transition);
  }
  .ent-card:hover {
    border-color: var(--md-primary);
    box-shadow: var(--md-elevation-3);
    transform: translateY(-4px);
  }
  .ent-card-icon {
    font-size: 2rem;
    margin-bottom: 16px;
    color: var(--md-primary);
    font-weight: 700;
  }
  .ent-card-title {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--md-on-surface);
  }
  .ent-card-desc {
    font-size: 0.95rem;
    color: var(--md-on-surface-muted);
    line-height: 1.65;
  }

  /* ── ROI Calculator ── */
  .ent-roi {
    padding: 80px 0;
    background: var(--md-surface-variant);
  }
  .ent-roi-wrapper {
    max-width: 900px;
    margin: 0 auto;
  }
  .ent-roi-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .ent-roi-subtitle {
    color: var(--md-on-surface-muted);
    font-size: 1rem;
  }
  .ent-roi-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }
  @media (max-width: 680px) {
    .ent-roi-body { grid-template-columns: 1fr; }
  }

  /* Sliders */
  .ent-roi-inputs {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .ent-slider-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ent-slider-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.95rem;
    color: var(--md-on-surface);
    font-weight: 500;
  }
  .ent-slider-value {
    font-weight: 700;
    color: var(--md-primary);
    font-size: 1.05rem;
    min-width: 48px;
    text-align: right;
  }
  .ent-slider {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: 3px;
    background: var(--md-surface-container);
    outline: none;
    cursor: pointer;
    accent-color: var(--md-primary);
  }
  .ent-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--md-primary), var(--md-secondary));
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,188,212,0.4);
  }
  .ent-slider::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--md-primary), var(--md-secondary));
    cursor: pointer;
    border: none;
  }
  .ent-slider-range {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--md-on-surface-muted);
  }

  /* Output panel */
  .ent-roi-output {
    background: var(--md-surface-container);
    border: 1px solid var(--md-outline);
    border-radius: var(--md-radius);
    padding: 28px;
  }
  .ent-savings-display {
    text-align: center;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--md-outline);
  }
  .ent-savings-label {
    font-size: 0.85rem;
    color: var(--md-on-surface-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .ent-savings-amount {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: clamp(2.4rem, 5vw, 3.2rem);
    font-weight: 800;
    color: #22c55e;
    line-height: 1;
    margin-bottom: 10px;
  }
  .ent-roi-badge {
    display: inline-block;
    background: rgba(34,197,94,0.15);
    color: #22c55e;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 100px;
  }
  .ent-breakdown {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .ent-breakdown-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.88rem;
    gap: 8px;
  }
  .ent-breakdown-total {
    padding-top: 12px;
    border-top: 1px solid var(--md-outline);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .ent-breakdown-label { color: var(--md-on-surface-muted); }
  .ent-breakdown-value { font-weight: 600; color: var(--md-on-surface); white-space: nowrap; }
  .ent-breakdown-value.negative { color: #f87171; }
  .ent-breakdown-value.positive { color: #22c55e; }

  /* ── Social proof ── */
  .ent-social {
    padding: 64px 0;
    text-align: center;
  }
  .ent-social-text {
    font-size: 1.1rem;
    color: var(--md-on-surface-muted);
    margin-bottom: 28px;
  }
  .ent-social-logos {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .ent-logo-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--md-surface-container);
    border: 1px solid var(--md-outline);
    border-radius: 100px;
    padding: 6px 16px;
    font-size: 0.9rem;
    color: var(--md-on-surface);
    font-weight: 500;
  }
</style>

<script>
  // ROI Calculator — vanilla JS, Astro-compatible
  (function () {
    const employeesInput = document.getElementById('employees') as HTMLInputElement | null;
    const hoursInput = document.getElementById('hours') as HTMLInputElement | null;
    const rateInput = document.getElementById('hourlyRate') as HTMLInputElement | null;

    const valEmployees = document.getElementById('val-employees');
    const valHours = document.getElementById('val-hours');
    const valRate = document.getElementById('val-rate');

    const savingsAmountEl = document.getElementById('savings-amount');
    const roiBadgeEl = document.getElementById('roi-badge');
    const currentCostEl = document.getElementById('current-cost');
    const netSavingsEl = document.getElementById('net-savings');

    const OPENCLAW_COST = 499;

    function fmt(n: number): string {
      return '$' + Math.round(n).toLocaleString('en-US');
    }

    function calculate() {
      if (!employeesInput || !hoursInput || !rateInput) return;

      const employees = parseInt(employeesInput.value, 10);
      const hours = parseInt(hoursInput.value, 10);
      const rate = parseInt(rateInput.value, 10);

      if (valEmployees) valEmployees.textContent = String(employees);
      if (valHours) valHours.textContent = String(hours);
      if (valRate) valRate.textContent = '$' + rate;

      const currentCost = employees * hours * rate * 4.33;
      const savings = currentCost - OPENCLAW_COST;
      const roi = savings > 0 ? (savings / OPENCLAW_COST) * 100 : 0;

      if (currentCostEl) currentCostEl.textContent = fmt(currentCost);
      if (savingsAmountEl) savingsAmountEl.textContent = savings > 0 ? fmt(savings) : '$0';
      if (roiBadgeEl) roiBadgeEl.textContent = 'ROI: ' + Math.round(roi) + '%';
      if (netSavingsEl) netSavingsEl.textContent = savings > 0 ? fmt(savings) : '$0';
    }

    if (employeesInput) employeesInput.addEventListener('input', calculate);
    if (hoursInput) hoursInput.addEventListener('input', calculate);
    if (rateInput) rateInput.addEventListener('input', calculate);

    calculate();
  })();
</script>
