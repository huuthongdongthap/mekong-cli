          <td style="padding:0.75rem;border:1px solid var(--md-sys-color-outline)">Monitoring</td>
          <td style="padding:0.75rem;border:1px solid var(--md-sys-color-outline)">Production observability</td>
          <td style="padding:0.75rem;border:1px solid var(--md-sys-color-outline)">2 hrs</td>
        </tr>
