          <td style="padding:0.75rem;border:1px solid var(--md-sys-color-outline)">$49/mo</td>
          <td style="padding:0.75rem;border:1px solid var(--md-sys-color-outline)">$0.245</td>
        </tr>
        <tr>
          <td style="padding:0.75rem;border:1px solid var(--md-sys-color-outline)">Pro</td>
          <td style="padding:0.75rem;border:1px solid var(--md-sys-color-outline)">1,000 MCU</td>
          <td style="padding:0.75rem;border:1px solid var(--md-sys-color-outline)">$149/mo</td>
          <td style="padding:0.75rem;border:1px solid var(--md-sys-color-outline)">$0.149</td>
        </tr>
        <tr>
          <td style="padding:0.75rem;border:1px solid var(--md-sys-color-outline)">Enterprise</td>
          <td style="padding:0.75rem;border:1px solid var(--md-sys-color-outline)">Unlimited</td>
