---
import MainLayout from '../../../layouts/docs-layout.astro';

const articles = [
  { slug: 'ai-agents-for-business-automation', title: 'AI Agents for Business Automation', tag: 'Automation', desc: 'How AI agents fully automate business workflows end-to-end.' },
  { slug: 'robot-as-a-service-explained', title: 'Robot as a Service Explained', tag: 'RaaS', desc: 'The RaaS model — helping small businesses operate like large enterprises.' },
  { slug: 'zero-cost-saas', title: 'Zero-Cost SaaS on Cloudflare', tag: 'Engineering', desc: 'Build a full SaaS that runs free on Cloudflare Workers + Pages.' },
  { slug: 'solo-founder-automation', title: 'Solo Founder Automation Playbook', tag: 'Founder', desc: 'The automation playbook for solo founders — from sales to ops.' },
  { slug: 'building-saas-with-zero-employees', title: 'Building SaaS with Zero Employees', tag: 'Story', desc: 'Journey from 0 to $10K MRR with no employees.' },
  { slug: 'credit-based-pricing-for-saas', title: 'Credit-Based Pricing for SaaS', tag: 'Pricing', desc: 'Why MCU credit-based pricing outperforms traditional subscriptions.' },
  { slug: 'cli-vs-gui-productivity', title: 'CLI vs GUI Productivity', tag: 'Engineering', desc: 'Why CLI developers ship 10x faster than GUI users.' },
  { slug: 'developer-productivity-tools-2026', title: 'Developer Productivity Tools 2026', tag: 'Tools', desc: 'Best tools for developer productivity in 2026.' },
  { slug: 'ai-mission-execution', title: 'AI Mission Execution', tag: 'AI', desc: 'How OpenClaw executes complex multi-step missions autonomously.' },
  { slug: 'api-first-development-guide', title: 'API-First Development Guide', tag: 'Engineering', desc: 'Building products with an API-first approach for maximum flexibility.' },
  { slug: 'mekong-cli-vs-alternatives', title: 'Mekong CLI vs Alternatives', tag: 'Comparison', desc: 'How Mekong CLI compares to other developer automation tools.' },
  { slug: 'open-source-monetization', title: 'Open Source Monetization', tag: 'Business', desc: 'How to build a sustainable business around open source software.' },
  { slug: 'webhook-driven-architecture', title: 'Webhook-Driven Architecture', tag: 'Engineering', desc: 'Building real-time reactive systems with webhooks.' },
];
---

<MainLayout title="Blog — OpenClaw Docs" description="Articles, guides and insights from the OpenClaw team on AI agents, RaaS, and developer productivity.">
  <div class="guide-page" style="max-width:900px;margin:0 auto;padding:48px 24px;">
    <header style="margin-bottom:48px;">
      <a href="/docs" style="color:var(--md-sys-color-primary);text-decoration:none;font-size:0.875rem;">← Back to Docs</a>
      <h1 style="font-size:clamp(2rem,4vw,2.8rem);font-weight:800;margin:16px 0 8px;">
        <span class="gradient-text">Blog</span>
      </h1>
      <p style="color:var(--md-sys-color-on-surface-variant);font-size:1.05rem;">
        Articles, guides and insights on AI agents, RaaS, and developer productivity.
      </p>
    </header>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;">
      {articles.map(a => (
        <a href={`/docs/blog/${a.slug}`} class="glass" style="display:flex;flex-direction:column;gap:10px;padding:24px;border-radius:12px;text-decoration:none;color:inherit;transition:transform 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
          <span style="font-size:0.7rem;font-weight:600;color:var(--md-sys-color-primary);background:rgba(0,188,212,0.1);border-radius:4px;padding:2px 8px;text-transform:uppercase;letter-spacing:0.05em;align-self:flex-start;">
            {a.tag}
          </span>
          <h2 style="font-size:1.05rem;font-weight:700;line-height:1.35;margin:0;">{a.title}</h2>
          <p style="font-size:0.875rem;color:var(--md-sys-color-on-surface-variant);line-height:1.6;margin:0;flex:1;">{a.desc}</p>
          <span style="font-size:0.8rem;font-weight:600;color:var(--md-sys-color-primary);">Read more →</span>
        </a>
      ))}
    </div>
  </div>
</MainLayout>
