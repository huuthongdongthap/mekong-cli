---
import MainLayout from '../../layouts/docs-layout.astro';

interface CaseStudy {
  id: string;
  persona: string;
  company: string;
  tier: string;
  tierPrice: string;
  avatar: string;
  accentFrom: string;
  accentTo: string;
  problem: string;
  solution: string;
  results: { metric: string; label: string }[];
  quote: string;
  quoteAuthor: string;
  ctaHref: string;
}

const STUDIES: CaseStudy[] = [
  {
    id: 'solo-saas-founder',
    persona: 'Solo SaaS Founder',
    company: 'Indie Hacker',
    tier: 'Pro',
    tierPrice: '$99/mo',
    avatar: '👨‍💻',
    accentFrom: '#22d3ee',
    accentTo: '#0891b2',
    problem: 'Running 5 critical business functions alone — marketing, support, research, content, and finance — with no budget to hire.',
    solution: 'Used Mekong RaaS missions to automate content production, handle tier-1 support triage, conduct weekly competitor research, and generate financial summaries. All from a single terminal.',
    results: [
      { metric: '40h', label: 'Hours saved per week' },
      { metric: '3x', label: 'Revenue growth in 6 months' },
      { metric: '5', label: 'Business layers automated' },
    ],
    quote: "I went from working 70-hour weeks to 30. Mekong handles the operational grind while I focus on product. It's like having a full ops team in my terminal.",
    quoteAuthor: 'Daniel M., Indie SaaS Founder',
    ctaHref: '/#pricing',
  },
  {
    id: 'marketing-agency',
    persona: 'Marketing Agency',
    company: 'Content Studio',
    tier: 'Agency',
    tierPrice: '$199/mo',
    avatar: '🎯',
    accentFrom: '#a855f7',
    accentTo: '#7c3aed',
    problem: 'Client content production was a bottleneck — 3 copywriters couldn\'t keep up with demand. New client pitches were missed. Team was burning out.',
    solution: 'Deployed mission templates for blog posts, SEO audits, social media calendars, and ad copy. Every client gets a standardized weekly content drop powered by RaaS missions — reviewed and shipped in hours, not days.',
    results: [
      { metric: '10x', label: 'Content output increase' },
      { metric: '5', label: 'New clients acquired' },
      { metric: '60%', label: 'Reduction in revision cycles' },
    ],
    quote: "We doubled our client roster without hiring a single new writer. The mission templates are so good our team just reviews and approves instead of creating from scratch.",
    quoteAuthor: 'Sarah K., Creative Director',
    ctaHref: '/#pricing',
  },
  {
    id: 'enterprise-devops',
    persona: 'Enterprise DevOps Team',
    company: 'Tech Corp',
    tier: 'Master',
    tierPrice: '$399/mo',
    avatar: '⚙️',
    accentFrom: '#f59e0b',
    accentTo: '#d97706',
    problem: 'Manual code reviews were a bottleneck — senior engineers spent 30% of their time reviewing PRs instead of building. Documentation was always out of date.',
    solution: 'Integrated Mekong RaaS into the CI/CD pipeline. Every PR triggers automated code review missions that flag issues, suggest improvements, and generate inline docs. Test generation missions run nightly against new features.',
    results: [
      { metric: '60%', label: 'Faster release cycles' },
      { metric: '90%', label: 'Fewer production bugs' },
      { metric: '100%', label: 'API docs always current' },
    ],
    quote: "Senior engineers now spend their time on architecture, not PR review. The automated code review is frighteningly good — catches things humans miss.",
    quoteAuthor: 'James R., VP Engineering',
    ctaHref: '/enterprise',
  },
];
---

<MainLayout
  title="Case Studies — OpenClaw"
  description="Real results from Mekong RaaS customers. See how solo founders, agencies, and enterprise teams use AI missions to scale without headcount."
>
  <!-- Hero -->
  <section style="background:#0a0a0a;padding:72px 24px 56px;text-align:center;border-bottom:1px solid rgba(255,255,255,0.06);">
    <div style="max-width:680px;margin:0 auto;">
      <div style="display:inline-block;background:rgba(34,211,238,0.1);border:1px solid rgba(34,211,238,0.25);border-radius:20px;padding:4px 16px;font-size:0.75rem;font-weight:700;color:#22d3ee;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:24px;">
        Case Studies
      </div>
      <h1 style="font-size:clamp(1.75rem,4vw,2.75rem);font-weight:800;color:#f1f5f9;margin-bottom:16px;line-height:1.2;">
        Real teams. Real results.
      </h1>
      <p style="color:#94a3b8;font-size:1.05rem;line-height:1.7;">
        See how founders, agencies, and engineering teams use Mekong RaaS to scale operations without scaling headcount.
      </p>
    </div>
  </section>

  <!-- Case Studies -->
  <div style="max-width:1000px;margin:0 auto;padding:64px 24px;display:flex;flex-direction:column;gap:80px;">
    {STUDIES.map((study, idx) => (
      <article id={study.id} style="scroll-margin-top:80px;">
        <!-- Header -->
        <div style={`display:flex;align-items:flex-start;gap:20px;margin-bottom:32px;flex-wrap:wrap;`}>
          <div style={`width:64px;height:64px;border-radius:16px;background:linear-gradient(135deg,${study.accentFrom},${study.accentTo});display:flex;align-items:center;justify-content:center;font-size:2rem;flex-shrink:0;`}>
            {study.avatar}
          </div>
          <div style="flex:1;min-width:200px;">
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:6px;">
              <h2 style="font-size:1.4rem;font-weight:700;color:#f1f5f9;margin:0;">{study.persona}</h2>
              <span style={`background:linear-gradient(135deg,${study.accentFrom}22,${study.accentTo}22);border:1px solid ${study.accentFrom}44;color:${study.accentFrom};font-size:0.7rem;font-weight:700;padding:2px 10px;border-radius:12px;text-transform:uppercase;letter-spacing:0.06em;`}>
                {study.tier} — {study.tierPrice}
              </span>
            </div>
            <p style="color:#64748b;font-size:0.875rem;margin:0;">{study.company}</p>
          </div>
        </div>

        <!-- Content grid -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:28px;">
          <!-- Problem -->
          <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:24px;">
            <div style="font-size:0.7rem;font-weight:700;color:#ef4444;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;">The Problem</div>
            <p style="color:#94a3b8;font-size:0.9rem;line-height:1.7;margin:0;">{study.problem}</p>
          </div>
          <!-- Solution -->
          <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:24px;">
            <div style={`font-size:0.7rem;font-weight:700;color:${study.accentFrom};text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;`}>The Solution</div>
            <p style="color:#94a3b8;font-size:0.9rem;line-height:1.7;margin:0;">{study.solution}</p>
          </div>
        </div>

        <!-- Results -->
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:28px;">
          {study.results.map((r) => (
            <div style={`background:linear-gradient(135deg,${study.accentFrom}0d,${study.accentTo}0d);border:1px solid ${study.accentFrom}33;border-radius:12px;padding:20px;text-align:center;`}>
              <div style={`font-size:2rem;font-weight:800;background:linear-gradient(135deg,${study.accentFrom},${study.accentTo});-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;`}>{r.metric}</div>
              <div style="color:#94a3b8;font-size:0.8rem;margin-top:4px;">{r.label}</div>
            </div>
          ))}
        </div>

        <!-- Quote + CTA -->
        <div style="display:flex;gap:20px;align-items:flex-start;flex-wrap:wrap;">
          <blockquote style="flex:1;min-width:260px;background:rgba(255,255,255,0.02);border-left:3px solid;border-left-color:var(--accent);border-radius:0 12px 12px 0;padding:20px 24px;margin:0;" class={`border-accent-${idx}`}>
            <p style="color:#cbd5e1;font-size:0.925rem;line-height:1.75;font-style:italic;margin:0 0 12px;">&ldquo;{study.quote}&rdquo;</p>
            <cite style="color:#64748b;font-size:0.8rem;font-style:normal;font-weight:600;">— {study.quoteAuthor}</cite>
          </blockquote>
          <a
            href={study.ctaHref}
            style={`align-self:center;background:linear-gradient(135deg,${study.accentFrom},${study.accentTo});color:#0a0a0a;font-weight:700;padding:12px 24px;border-radius:8px;text-decoration:none;font-size:0.875rem;white-space:nowrap;flex-shrink:0;`}
          >
            {study.tier === 'Master' ? 'Contact Sales' : 'Get Started'}
          </a>
        </div>

        {idx < STUDIES.length - 1 && (
          <div style="border-bottom:1px solid rgba(255,255,255,0.06);margin-top:80px;"></div>
        )}
      </article>
    ))}
  </div>

  <!-- Bottom CTA -->
  <section style="background:linear-gradient(135deg,rgba(34,211,238,0.05),rgba(147,51,234,0.05));border-top:1px solid rgba(255,255,255,0.06);padding:64px 24px;text-align:center;">
    <div style="max-width:560px;margin:0 auto;">
      <h2 style="font-size:1.75rem;font-weight:800;color:#f1f5f9;margin-bottom:12px;">Ready to write your own success story?</h2>
      <p style="color:#94a3b8;margin-bottom:32px;">Start free — 10 credits, no credit card required.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/" style="background:linear-gradient(135deg,#22d3ee,#0891b2);color:#0a0a0a;font-weight:700;padding:14px 28px;border-radius:8px;text-decoration:none;font-size:0.95rem;">
          Start Free
        </a>
        <a href="/docs/pricing" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:#f1f5f9;font-weight:600;padding:14px 28px;border-radius:8px;text-decoration:none;font-size:0.95rem;">
          View Pricing
        </a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  @media (max-width: 640px) {
    article > div:nth-of-type(2) { grid-template-columns: 1fr !important; }
    article > div:nth-of-type(3) { grid-template-columns: repeat(2, 1fr) !important; }
  }
</style>
