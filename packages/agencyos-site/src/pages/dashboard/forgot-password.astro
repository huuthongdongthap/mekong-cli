---
import AuthLayout from '../../layouts/auth-layout.astro';
---
<AuthLayout>
  <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;">
    <div style="width:100%;max-width:400px;">

      <div style="text-align:center;margin-bottom:32px;">
        <a href="/" style="font-size:1.5rem;font-weight:800;text-decoration:none;color:#818cf8;">OpenClaw</a>
        <h1 style="font-size:1.25rem;font-weight:700;margin-top:16px;margin-bottom:6px;">Quên mật khẩu?</h1>
        <p style="color:#a3b0c2;font-size:13px;">Nhập email để nhận link đặt lại mật khẩu</p>
      </div>

      <div style="background:#1a1d27;border:1px solid #2e3248;border-radius:8px;padding:28px;">
        <div id="form-view">
          <div style="margin-bottom:16px;">
            <label style="display:block;font-size:13px;margin-bottom:6px;color:#e2e8f0;">Email</label>
            <input
              id="email-input"
              type="email"
              placeholder="you@example.com"
              style="width:100%;padding:10px 12px;background:#242736;border:1px solid #2e3248;border-radius:8px;color:#e2e8f0;font-size:14px;outline:none;box-sizing:border-box;"
            />
            <div id="err-msg" style="display:none;color:#ef4444;font-size:12px;margin-top:6px;">Vui lòng nhập email hợp lệ.</div>
          </div>

          <button
            id="submit-btn"
            style="width:100%;padding:11px;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;"
          >
            Gửi link đặt lại
          </button>
        </div>

        <div id="success-view" style="display:none;text-align:center;padding:8px 0;">
          <div style="font-size:40px;margin-bottom:12px;">📧</div>
          <p style="font-weight:600;margin-bottom:6px;">Kiểm tra hộp thư của bạn</p>
          <p style="color:#a3b0c2;font-size:13px;">Chúng tôi đã gửi link đặt lại mật khẩu. Kiểm tra cả thư mục spam nếu không thấy.</p>
        </div>
      </div>

      <div style="text-align:center;margin-top:20px;font-size:13px;color:#a3b0c2;">
        Nhớ mật khẩu rồi?
        <a href="/dashboard/login" style="color:#818cf8;text-decoration:none;margin-left:4px;">Đăng nhập</a>
      </div>

    </div>
  </div>

  <script>
    const emailInput = document.getElementById('email-input') as HTMLInputElement;
    const submitBtn = document.getElementById('submit-btn');
    const errMsg = document.getElementById('err-msg');
    const formView = document.getElementById('form-view');
    const successView = document.getElementById('success-view');

    submitBtn?.addEventListener('click', () => {
      const email = emailInput?.value.trim();
      const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email || '');
      if (!valid) {
        if (errMsg) errMsg.style.display = 'block';
        return;
      }
      if (errMsg) errMsg.style.display = 'none';
      // In a real app: call API to send reset email
      // For now just show success state
      if (formView) formView.style.display = 'none';
      if (successView) successView.style.display = 'block';
    });

    emailInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') submitBtn?.click();
    });
  </script>
</AuthLayout>
