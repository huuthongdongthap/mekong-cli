---
import BaseLayout from '../layouts/base-layout.astro';

const rows = [
  { feature: 'MCU / tháng',           free: '50',          starter: '200',          pro: '1.000',                growth: '3.000',              enterprise: 'Không giới hạn' },
  { feature: 'AI Receptionist',       free: '—',           starter: '24/7',         pro: '24/7 Multi-channel',  growth: '24/7 Multi-channel', enterprise: 'Dedicated AI' },
  { feature: 'Content Creator',       free: '—',           starter: '7 ngày/tuần',  pro: '7 ngày + lịch',       growth: '7 ngày + lịch',      enterprise: 'Toàn quyền tùy chỉnh' },
  { feature: 'CRM',                   free: '—',           starter: 'Không giới hạn',pro: 'Không giới hạn + API',growth: 'Không giới hạn + API',enterprise: 'Enterprise CRM' },
  { feature: 'Báo cáo',               free: '—',           starter: 'Tuần',         pro: 'Thời gian thực',      growth: 'Thời gian thực',     enterprise: 'Tuỳ chỉnh' },
  { feature: 'Hỗ trợ',                free: '—',           starter: 'Chat ưu tiên', pro: 'Chat + Phone',        growth: 'Chat + Phone',       enterprise: 'Dedicated manager' },
  { feature: 'API access',            free: '—',           starter: '—',            pro: '✓',                   growth: '✓',                  enterprise: '✓' },
  { feature: 'Phân tích nâng cao',    free: '—',           starter: '—',            pro: '—',                   growth: '✓',                  enterprise: '✓' },
  { feature: 'White-label',           free: '—',           starter: '—',            pro: '—',                   growth: '—',                  enterprise: '✓' },
  { feature: 'SLA',                   free: '—',           starter: '—',            pro: '99.9%',               growth: '99.9%',              enterprise: '99.99%' },
  { feature: 'Onboarding 1-1',        free: '—',           starter: '—',            pro: '—',                   growth: '—',                  enterprise: '✓' },
];

const plans = [
  { name: 'Free',       price: '$0',    href: '/dashboard/signup',                                     featured: false },
  { name: 'Starter',   price: '$49/mo', href: 'https://nowpayments.io/payment/?iid=6245075877',         featured: false },
  { name: 'Pro',        price: '$149/mo',href: 'https://nowpayments.io/payment/?iid=5438578229',        featured: true  },
  { name: 'Growth',     price: '$299/mo',href: 'https://nowpayments.io/payment/?iid=5821366482',        featured: false },
  { name: 'Enterprise', price: '$499/mo',href: 'mailto:hello@agencyos.network',                         featured: false },
];

// Product JSON-LD for pricing plans
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "OpenClaw",
  "description": "Nền tảng AI tự động hóa doanh nghiệp",
  "brand": {
    "@type": "Organization",
    "name": "OpenClaw",
    "url": "https://agencyos.network"
  },
  "offers": plans.map(plan => ({
    "@type": "Offer",
    "name": `${plan.name} Plan`,
    "price": plan.name === 'Free' ? '0' : plan.name === 'Starter' ? '49' : plan.name === 'Pro' ? '149' : plan.name === 'Growth' ? '299' : '499',
    "priceCurrency": "USD",
    "priceValidUntil": new Date(new Date().getFullYear() + 1, 0, 1).toISOString().split('T')[0],
    "availability": "https://schema.org/InStock",
    "url": plan.href,
    "category": "SoftwareApplication",
    "description": plan.name === 'Free' ? 'Miễn phí mãi mãi với 50 MCU/tháng' :
                  plan.name === 'Starter' ? '200 MCU/tháng, AI Receptionist 24/7' :
                  plan.name === 'Pro' ? '1.000 MCU/tháng, multi-channel, API access' :
                  plan.name === 'Growth' ? '3.000 MCU/tháng, phân tích nâng cao, ưu tiên hỗ trợ' :
                  'MCU không giới hạn, dedicated AI model, white-label'
  }))
};

// BreadcrumbList JSON-LD for pricing page
const pricingBreadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://agencyos.network"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Pricing",
      "item": "https://agencyos.network/pricing"
    }
  ]
};
---

<BaseLayout title="Bảng giá — OpenClaw" description="So sánh chi tiết các gói OpenClaw. Miễn phí đến Enterprise." lang="vi">

  <!-- Header -->
  <section style="background:linear-gradient(135deg,#0a0f1a,#1a1040 60%,#0a2030);padding:96px 0 64px;text-align:center;">
    <div class="container">
      <div class="badge animate-in" style="margin-bottom:20px;">Bảng giá</div>
      <h1 class="display animate-in" style="margin-bottom:16px;">
        So sánh <span class="gradient-text">tất cả gói</span>
      </h1>
      <p style="color:var(--md-on-surface-muted);max-width:440px;margin:0 auto 32px;" class="animate-in">
        Minh bạch 100%. Không phí ẩn. Huỷ bất cứ lúc nào. 14 ngày thử miễn phí.
      </p>
      <a href="/dashboard/signup" class="btn-primary animate-in">Bắt đầu miễn phí →</a>
    </div>
  </section>

  <!-- Comparison table -->
  <section style="background:var(--md-surface);">
    <div class="container" style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;min-width:640px;">
        <thead>
          <tr>
            <th style="text-align:left;padding:16px;color:var(--md-on-surface-muted);font-size:0.85rem;font-weight:500;border-bottom:1px solid var(--md-outline);">Tính năng</th>
            {plans.map(p => (
              <th style={`text-align:center;padding:16px;border-bottom:1px solid var(--md-outline);${p.featured ? 'background:rgba(0,188,212,0.05);' : ''}`}>
                <div style={`font-size:0.95rem;font-weight:700;margin-bottom:4px;${p.featured ? 'color:#00BCD4;' : ''}`}>{p.name}</div>
                <div style="font-size:0.82rem;color:var(--md-on-surface-muted);">{p.price}</div>
                {p.featured && <div style="margin-top:6px;display:inline-block;background:linear-gradient(135deg,#00BCD4,#7C4DFF);color:#fff;font-size:0.7rem;font-weight:700;padding:3px 10px;border-radius:100px;">Phổ biến nhất</div>}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr style={i % 2 === 0 ? 'background:rgba(255,255,255,0.015);' : ''}>
              <td style="padding:14px 16px;font-size:0.875rem;color:var(--md-on-surface-muted);border-bottom:1px solid rgba(255,255,255,0.04);">{row.feature}</td>
              {[row.free, row.starter, row.pro, row.growth, row.enterprise].map((val, ci) => (
                <td style={`text-align:center;padding:14px 16px;font-size:0.875rem;border-bottom:1px solid rgba(255,255,255,0.04);${ci===2 ? 'background:rgba(0,188,212,0.04);' : ''}color:${val==='—' ? 'var(--md-on-surface-muted)' : 'var(--md-on-surface)'};`}>
                  {val === '✓' ? <span style="color:#00BCD4;font-size:1.1rem;font-weight:700;">✓</span> : val}
                </td>
              ))}
            </tr>
          ))}
          <!-- CTA row -->
          <tr>
            <td style="padding:24px 16px;"></td>
            {plans.map(p => (
              <td style={`text-align:center;padding:24px 16px;${p.featured ? 'background:rgba(0,188,212,0.04);' : ''}`}>
                <a href={p.href} class={p.featured ? 'btn-primary' : 'btn-outline'} style="font-size:0.875rem;padding:10px 20px;justify-content:center;" target={p.href.startsWith('http') ? '_blank' : undefined} rel={p.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                  {p.name === 'Enterprise' ? 'Liên hệ' : 'Chọn gói'}
                </a>
                {p.name !== 'Free' && p.name !== 'Enterprise' && (
                  <div style="margin-top:8px;font-size:0.7rem;color:#f59e0b;font-weight:600;letter-spacing:0.03em;">Crypto / USDT</div>
                )}
              </td>
            ))}
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Divider between OpenClaw and Sophia sections -->
  <div style="background:var(--md-surface);padding:48px 0 0;">
    <div class="container" style="max-width:900px;">
      <div style="border-top:1px solid rgba(255,255,255,0.08);position:relative;text-align:center;">
        <span style="position:relative;top:-14px;background:var(--md-surface);padding:0 24px;color:var(--md-on-surface-muted);font-size:0.8rem;letter-spacing:0.08em;text-transform:uppercase;font-weight:600;">Sản phẩm khác</span>
      </div>
    </div>
  </div>

  <!-- Sophia AI Factory Section -->
  <section id="sophia-pricing" style="background:linear-gradient(180deg,var(--md-surface) 0%,#0a0f1a 100%);padding:64px 0 80px;">
    <div class="container">
      <!-- Section header -->
      <div style="text-align:center;margin-bottom:48px;">
        <div class="badge animate-on-scroll" style="margin-bottom:16px;background:rgba(124,77,255,0.12);color:#7C4DFF;border:1px solid rgba(124,77,255,0.25);">Sophia AI Factory</div>
        <h2 class="headline animate-on-scroll" style="margin-bottom:12px;">
          AI tạo proposal & <span class="gradient-text">sales automation</span>
        </h2>
        <p style="color:var(--md-on-surface-muted);max-width:480px;margin:0 auto;" class="animate-on-scroll">
          Cho agency. Tự động hoá quy trình bán hàng — từ lead đến hợp đồng ký kết.
        </p>
      </div>

      <!-- Plan cards -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;max-width:1000px;margin:0 auto;">

        <!-- Starter $199 -->
        <div class="animate-on-scroll" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:28px 24px;display:flex;flex-direction:column;gap:16px;backdrop-filter:blur(12px);">
          <div>
            <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--md-on-surface-muted);margin-bottom:8px;">Starter</div>
            <div style="font-size:2rem;font-weight:800;line-height:1;">$199<span style="font-size:0.9rem;font-weight:400;color:var(--md-on-surface-muted);">/mo</span></div>
          </div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;flex:1;">
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#00BCD4;flex-shrink:0;">✓</span>Tạo proposal tự động</li>
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#00BCD4;flex-shrink:0;">✓</span>5 dự án/tháng</li>
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#00BCD4;flex-shrink:0;">✓</span>Email follow-up AI</li>
          </ul>
          <div>
            <div style="margin-bottom:8px;font-size:0.68rem;color:#f59e0b;font-weight:700;letter-spacing:0.04em;text-align:center;">USDT TRC20</div>
            <a href="https://nowpayments.io/payment/?iid=6075842741" class="btn-outline" style="display:block;text-align:center;font-size:0.875rem;padding:10px 16px;" target="_blank" rel="noopener noreferrer">Chọn gói</a>
          </div>
        </div>

        <!-- Growth $399 — featured -->
        <div class="animate-on-scroll" style="background:linear-gradient(135deg,rgba(0,188,212,0.07),rgba(124,77,255,0.07));border:1px solid rgba(0,188,212,0.3);border-radius:16px;padding:28px 24px;display:flex;flex-direction:column;gap:16px;backdrop-filter:blur(12px);position:relative;box-shadow:0 0 32px rgba(0,188,212,0.12);">
          <div style="position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#00BCD4,#7C4DFF);color:#fff;font-size:0.7rem;font-weight:700;padding:4px 14px;border-radius:100px;white-space:nowrap;">Phổ biến nhất</div>
          <div>
            <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#00BCD4;margin-bottom:8px;">Growth</div>
            <div style="font-size:2rem;font-weight:800;line-height:1;color:#00BCD4;">$399<span style="font-size:0.9rem;font-weight:400;color:var(--md-on-surface-muted);">/mo</span></div>
          </div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;flex:1;">
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#00BCD4;flex-shrink:0;">✓</span>Tất cả tính năng Starter</li>
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#00BCD4;flex-shrink:0;">✓</span>20 dự án/tháng</li>
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#00BCD4;flex-shrink:0;">✓</span>CRM tích hợp</li>
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#00BCD4;flex-shrink:0;">✓</span>Analytics nâng cao</li>
          </ul>
          <div>
            <div style="margin-bottom:8px;font-size:0.68rem;color:#f59e0b;font-weight:700;letter-spacing:0.04em;text-align:center;">USDT TRC20</div>
            <a href="https://nowpayments.io/payment/?iid=5213459112" class="btn-primary" style="display:block;text-align:center;font-size:0.875rem;padding:10px 16px;" target="_blank" rel="noopener noreferrer">Chọn gói</a>
          </div>
        </div>

        <!-- Premium $799 -->
        <div class="animate-on-scroll" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:28px 24px;display:flex;flex-direction:column;gap:16px;backdrop-filter:blur(12px);">
          <div>
            <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--md-on-surface-muted);margin-bottom:8px;">Premium</div>
            <div style="font-size:2rem;font-weight:800;line-height:1;">$799<span style="font-size:0.9rem;font-weight:400;color:var(--md-on-surface-muted);">/mo</span></div>
          </div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;flex:1;">
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#00BCD4;flex-shrink:0;">✓</span>Tất cả tính năng Growth</li>
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#00BCD4;flex-shrink:0;">✓</span>Không giới hạn dự án</li>
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#00BCD4;flex-shrink:0;">✓</span>White-label</li>
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#00BCD4;flex-shrink:0;">✓</span>Hỗ trợ ưu tiên 24/7</li>
          </ul>
          <div>
            <div style="margin-bottom:8px;font-size:0.68rem;color:#f59e0b;font-weight:700;letter-spacing:0.04em;text-align:center;">USDT TRC20</div>
            <a href="https://nowpayments.io/payment/?iid=5321792819" class="btn-outline" style="display:block;text-align:center;font-size:0.875rem;padding:10px 16px;" target="_blank" rel="noopener noreferrer">Chọn gói</a>
          </div>
        </div>

        <!-- Master $4,999 -->
        <div class="animate-on-scroll" style="background:linear-gradient(135deg,rgba(124,77,255,0.06),rgba(255,255,255,0.02));border:1px solid rgba(124,77,255,0.2);border-radius:16px;padding:28px 24px;display:flex;flex-direction:column;gap:16px;backdrop-filter:blur(12px);">
          <div>
            <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#7C4DFF;margin-bottom:8px;">Master</div>
            <div style="font-size:2rem;font-weight:800;line-height:1;">$4,999<span style="font-size:0.9rem;font-weight:400;color:var(--md-on-surface-muted);">/mo</span></div>
          </div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;flex:1;">
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#7C4DFF;flex-shrink:0;">✓</span>Tất cả tính năng Premium</li>
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#7C4DFF;flex-shrink:0;">✓</span>Dedicated AI model</li>
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#7C4DFF;flex-shrink:0;">✓</span>Onboarding 1-1</li>
            <li style="font-size:0.85rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;"><span style="color:#7C4DFF;flex-shrink:0;">✓</span>SLA 99.99%</li>
          </ul>
          <a href="mailto:hello@agencyos.network" class="btn-outline" style="display:block;text-align:center;font-size:0.875rem;padding:10px 16px;border-color:rgba(124,77,255,0.4);color:#7C4DFF;">Liên hệ tư vấn</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Contact -->
  <section style="background:var(--md-surface-container);">
    <div class="container" style="max-width:600px;text-align:center;">
      <h2 class="headline animate-on-scroll" style="margin-bottom:16px;">Còn thắc mắc?</h2>
      <p style="color:var(--md-on-surface-muted);margin-bottom:32px;" class="animate-on-scroll">
        Đội ngũ hỗ trợ sẵn sàng tư vấn miễn phí trong vòng 24 giờ.
      </p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;" class="animate-on-scroll">
        <a href="mailto:hello@agencyos.network" class="btn-primary">Gửi email cho chúng tôi</a>
        <a href="/" class="btn-outline">← Về trang chủ</a>
      </div>
    </div>
  </section>

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify([productSchema, pricingBreadcrumbSchema])} />

</BaseLayout>
