---
import BaseLayout from '../layouts/base-layout.astro';

// Pricing redirects to each real product's own pricing page.
// We show a comparison card for each product with their actual pricing.
const products = [
  {
    icon: '🎬',
    name: 'Sophia AI Factory',
    tagline: 'Video Factory + RaaS',
    desc: 'Tự động hóa sản xuất video và nội dung. Billing theo MCU (Machine Credit Unit).',
    tiers: ['$199/mo — Starter', '$999/mo — Pro', '$4,999/mo — Enterprise'],
    href: 'https://sophia.agencyos.network',
    cta: 'Xem bảng giá Sophia →',
    gradient: 'linear-gradient(135deg, rgba(124,77,255,0.15), rgba(0,188,212,0.08))',
    border: 'rgba(124,77,255,0.3)',
    accentColor: '#7C4DFF',
    featured: false,
  },
  {
    icon: '📈',
    name: 'CashClaw',
    tagline: 'Prediction Market Trading',
    desc: 'Trading bot cho Polymarket. Tự động phân tích, đặt lệnh và quản lý rủi ro.',
    tiers: ['$49/mo — Basic', '$149/mo — Pro', '$499/mo — Unlimited'],
    href: 'https://cashclaw.cc',
    cta: 'Xem bảng giá CashClaw →',
    gradient: 'linear-gradient(135deg, rgba(0,188,212,0.18), rgba(0,230,118,0.08))',
    border: 'rgba(0,188,212,0.4)',
    accentColor: '#00BCD4',
    featured: true,
  },
  {
    icon: '⚡',
    name: 'OpenClaw CLI',
    tagline: 'Open Source Dev Tools',
    desc: '342+ lệnh AI cho toàn bộ quy trình doanh nghiệp. Mã nguồn mở, MIT License.',
    tiers: ['Miễn phí — MIT License', 'Tự host, tự quản lý', 'Dùng API key của bạn'],
    href: 'https://github.com/longtho638-jpg/mekong-cli',
    cta: 'Xem trên GitHub →',
    gradient: 'linear-gradient(135deg, rgba(255,167,38,0.12), rgba(124,77,255,0.08))',
    border: 'rgba(255,167,38,0.3)',
    accentColor: '#FFA726',
    featured: false,
  },
];
---

<BaseLayout
  title="Bảng giá — AgencyOS Ecosystem"
  description="Giá thực của 3 sản phẩm: Sophia AI Factory ($199-$4,999/mo), CashClaw ($49-$499/mo), OpenClaw CLI (miễn phí). Không có pricing ảo."
  lang="vi"
  canonical="/pricing"
>

  <!-- Header -->
  <section style="background:linear-gradient(135deg,#0a0f1a,#1a1040 60%,#0a2030);padding:96px 0 64px;text-align:center;">
    <div class="container">
      <div class="badge animate-in" style="margin-bottom:20px;">Bảng giá</div>
      <h1 class="headline animate-in" style="margin-bottom:16px;">
        Giá thực của <span class="gradient-text">3 sản phẩm thực</span>
      </h1>
      <p style="color:var(--md-on-surface-muted);max-width:480px;margin:0 auto;" class="animate-in">
        Mỗi sản phẩm có trang giá riêng với chi tiết đầy đủ. Không có pricing ảo hay tính năng chưa xây.
      </p>
    </div>
  </section>

  <!-- Product Pricing Cards -->
  <section style="background:var(--md-surface-container);padding:80px 0;">
    <div class="container">
      <div class="pricing-grid">
        {products.map((p, i) => (
          <div
            class={`pricing-card animate-on-scroll${p.featured ? ' pricing-featured' : ''}`}
            style={`animation-delay:${i * 0.12}s; background:${p.gradient}; border:1px solid ${p.border};`}
          >
            {p.featured && (
              <div class="pricing-featured-badge" style={`background:${p.accentColor};`}>Phổ biến</div>
            )}
            <div style="margin-bottom:16px;">
              <span style="font-size:2.2rem;" aria-hidden="true">{p.icon}</span>
            </div>
            <h2 style="font-size:1.3rem;font-weight:800;margin:0 0 4px;">{p.name}</h2>
            <p style={`font-size:0.85rem;font-weight:600;color:${p.accentColor};margin:0 0 12px;`}>{p.tagline}</p>
            <p style="font-size:0.875rem;color:var(--md-on-surface-muted);line-height:1.65;margin:0 0 24px;">{p.desc}</p>

            <ul style="list-style:none;margin:0 0 28px;padding:0;display:flex;flex-direction:column;gap:10px;">
              {p.tiers.map(tier => (
                <li style="display:flex;align-items:center;gap:10px;font-size:0.875rem;">
                  <span style={`color:${p.accentColor};font-weight:600;flex-shrink:0;`} aria-hidden="true">✓</span>
                  {tier}
                </li>
              ))}
            </ul>

            <a
              href={p.href}
              target={p.name === 'OpenClaw CLI' ? '_blank' : '_self'}
              rel={p.name === 'OpenClaw CLI' ? 'noopener noreferrer' : ''}
              class={p.featured ? 'btn-primary' : 'btn-outline'}
              style="display:flex;justify-content:center;width:100%;"
            >
              {p.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Note -->
  <section style="background:var(--md-surface);padding:48px 0;text-align:center;">
    <div class="container" style="max-width:640px;">
      <p style="color:var(--md-on-surface-muted);font-size:0.875rem;line-height:1.8;">
        Mỗi sản phẩm được vận hành độc lập với trang giá riêng và quy trình thanh toán riêng.
        Nếu có câu hỏi, liên hệ <a href="mailto:support@agencyos.network" style="color:var(--md-primary);">support@agencyos.network</a>
      </p>
    </div>
  </section>

  <style>
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      align-items: start;
    }
    .pricing-card {
      position: relative;
      padding: 32px;
      border-radius: var(--md-radius);
    }
    .pricing-featured {
      box-shadow: 0 8px 32px rgba(0,188,212,0.2);
    }
    .pricing-featured-badge {
      position: absolute;
      top: -14px;
      left: 50%;
      transform: translateX(-50%);
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      padding: 4px 14px;
      border-radius: 100px;
      white-space: nowrap;
    }
  </style>

</BaseLayout>
