---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'OpenClaw RaaS — AI Vận Hành Doanh Nghiệp',
  description = 'Trả lời khách 24/7. Tạo content tự động. CRM thông minh. Chỉ /tháng.',
} = Astro.props;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- CSS imported via Astro frontmatter -->
  </head>
  <body>
    <nav style="position:sticky;top:0;z-index:100;background:rgba(10,10,10,0.9);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,0.06);padding:14px 0;">
      <div class="container" style="display:flex;align-items:center;justify-content:space-between;">
        <a href="/" style="font-weight:700;font-size:1.1rem;color:#e0e0e0;">
          <span class="gradient-text">OpenClaw</span> RaaS
        </a>
        <div style="display:flex;gap:20px;align-items:center;">
          <a href="#features" style="color:#888;font-size:0.9rem;">Tính năng</a>
          <a href="#pricing" style="color:#888;font-size:0.9rem;">Bảng giá</a>
          <a href="#faq" style="color:#888;font-size:0.9rem;">FAQ</a>
          <a href="https://app.agencyos.network/signup" class="btn-primary" style="padding:8px 20px;font-size:0.9rem;">Dùng thử</a>
          <span style="color:#555;font-size:0.8rem;border-left:1px solid #333;padding-left:12px;margin-left:4px;">
            <a href="/" style="color:#aaa;font-size:0.8rem;">VI</a> | <a href="/en/" style="color:#aaa;font-size:0.8rem;">EN</a>
          </span>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <script>
      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          e.preventDefault();
          const target = document.querySelector((e.currentTarget as HTMLAnchorElement).getAttribute('href')!);
          target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    </script>
  </body>
</html>
