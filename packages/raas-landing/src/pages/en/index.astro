---
import BaseLayout from '../../layouts/base-layout.astro';

const features = [
  { icon: '🤖', title: 'AI Receptionist', desc: 'Replies to Zalo & Facebook 24/7, never missing a message. Response under 3 seconds.' },
  { icon: '✍️', title: 'Content Creator', desc: 'AI drafts 7 days of content on schedule. You just review and post.' },
  { icon: '📊', title: 'Smart CRM', desc: 'Auto-saves customer profiles, classifies leads, retargets at the right moment.' },
  { icon: '📈', title: 'Real-time Reports', desc: 'Visual dashboard. AI analyzes and suggests actions every week.' },
];

const steps = [
  { num: '01', title: 'Sign Up', time: '2 min', desc: 'Create a free account — no credit card required.' },
  { num: '02', title: 'Connect Zalo / FB', time: '5 min', desc: 'Link your sales channels with just a few clicks.' },
  { num: '03', title: 'AI starts running', time: '24/7', desc: 'System learns, replies and reports automatically from minute one.' },
];

const plans = [
  { name: 'Free',       price: '$0',   period: '/mo', tag: '', features: ['50 credits/month', 'Basic AI Receptionist', '3 days content/month', 'CRM: 50 contacts'], cta: 'Get started free', href: 'https://app.agencyos.network/signup', featured: false },
  { name: 'Starter',   price: '$8',   period: '/mo', tag: '', features: ['500 credits/month', '24/7 AI Receptionist', '7 days content/week', 'Unlimited CRM', 'Weekly reports'], cta: 'Try free 14 days', href: 'https://app.agencyos.network/signup?plan=starter', featured: false },
  { name: 'Pro',        price: '$20',  period: '/mo', tag: 'Most popular', features: ['2,000 credits/month', 'Multi-channel (Zalo+FB+Web)', 'Industry-tuned AI', 'API access', 'SLA 99.9%'], cta: 'Choose Pro', href: 'https://app.agencyos.network/signup?plan=pro', featured: true },
  { name: 'Enterprise', price: '$120', period: '/mo', tag: '', features: ['Unlimited credits', 'Dedicated AI model', 'White-label', '1-on-1 onboarding', 'SLA 99.99%'], cta: 'Contact sales', href: 'mailto:hello@agencyos.network', featured: false },
];

const faqs = [
  { q: 'Do I need to know how to code?', a: 'No. The interface is fully visual — anyone can get started within 5 minutes.' },
  { q: 'Which industries are supported?', a: 'Cafes, restaurants, spas, salons, gyms, fashion shops, convenience stores and most retail businesses.' },
  { q: 'What payment methods are accepted?', a: 'Payment via Polar.sh with Visa/Mastercard. Global support, USD pricing.' },
  { q: 'Can I cancel my subscription?', a: 'Cancel anytime with no penalty. Your data is retained for 30 days after cancellation.' },
  { q: 'Is my customer data safe?', a: 'Runs on Cloudflare Workers with end-to-end encryption. Never shared with third parties.' },
];

const platformStats = [
  { value: '319', label: 'Commands', desc: 'CLI commands for every layer' },
  { value: '540', label: 'AI Skills', desc: 'Specialized skill library' },
  { value: '17', label: 'AI Agents', desc: 'Self-operating agents' },
  { value: '410', label: 'Contracts', desc: 'Ready-made machine contracts' },
  { value: '13', label: 'Hooks', desc: 'Auto-trigger pipelines' },
];

const testimonials = [
  { name: 'Minh Tuan', role: 'CEO, FoodTech Startup', text: 'Since using OpenClaw, my one-person team handles the workload of a 5-person team.' },
  { name: 'Ha Linh', role: 'Founder, Beauty Brand', text: 'AI replies to Zalo messages 24/7 — I never miss a customer, even at 2 AM.' },
  { name: 'Duc Anh', role: 'CTO, SaaS Platform', text: 'Billing + metering running zero-cost on Cloudflare Workers. Impressive.' },
];
---

<BaseLayout title="OpenClaw — AI-Powered Business Automation" description="24/7 customer replies · Auto content creation · Smart CRM. Try free for 14 days." lang="en">

  <!-- HERO -->
  <section style="background:linear-gradient(135deg,#0a0f1a 0%,#1a1040 50%,#0a2030 100%);min-height:90vh;display:flex;align-items:center;position:relative;overflow:hidden;">
    <!-- Animated mesh orbs -->
    <div style="position:absolute;top:15%;left:5%;width:380px;height:380px;border-radius:50%;background:radial-gradient(circle,rgba(0,188,212,0.12),transparent 70%);filter:blur(40px);pointer-events:none;animation:meshDrift 16s ease-in-out infinite alternate;"></div>
    <div style="position:absolute;bottom:10%;right:8%;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(124,77,255,0.1),transparent 70%);filter:blur(40px);pointer-events:none;animation:meshDrift 20s ease-in-out infinite alternate-reverse;"></div>
    <div style="position:absolute;top:60%;left:40%;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(0,188,212,0.06),transparent 70%);filter:blur(30px);pointer-events:none;animation:meshDrift 24s ease-in-out infinite alternate;"></div>

    <div class="container" style="position:relative;z-index:1;padding:80px 24px;">
      <div style="max-width:760px;">
        <div class="badge animate-in" style="margin-bottom:28px;">✨ New — AI Receptionist for Zalo &amp; Facebook</div>
        <h1 class="display animate-in" style="margin-bottom:24px;animation-delay:0.1s;">
          <span class="gradient-text">AI-Powered</span><br />Business Automation
        </h1>
        <p style="font-size:clamp(1rem,2vw,1.2rem);color:var(--md-on-surface-muted);max-width:520px;margin-bottom:16px;" class="animate-in">
          24/7 customer replies · Auto content creation · Smart CRM
        </p>
        <!-- Stats row -->
        <div style="display:flex;gap:32px;margin-bottom:24px;flex-wrap:wrap;" class="animate-in">
          {[['500+', 'businesses'],['1M+', 'messages'],['99.9%', 'uptime']].map(([v,l]) => (
            <div>
              <div style="font-family:'Be Vietnam Pro',sans-serif;font-size:1.5rem;font-weight:800;" class="gradient-text">{v}</div>
              <div style="font-size:0.8rem;color:var(--md-on-surface-muted);">{l}</div>
            </div>
          ))}
        </div>
        <!-- Social proof badges -->
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:36px;" class="animate-in">
          <span class="proof-badge"><span class="dot"></span>Trusted by 500+ businesses</span>
          <span class="proof-badge">🏆 #1 in Vietnam 2025</span>
        </div>
        <div style="display:flex;gap:16px;flex-wrap:wrap;" class="animate-in">
          <a href="https://app.agencyos.network/signup" class="btn-primary btn-pulse" style="font-size:1.05rem;">Try free for 14 days →</a>
          <a href="#features" class="btn-outline">See features</a>
        </div>
      </div>

      <!-- Terminal mockup -->
      <div class="terminal animate-on-scroll" style="margin-top:56px;max-width:520px;">
        <div style="display:flex;gap:6px;margin-bottom:14px;">
          <span style="width:10px;height:10px;border-radius:50%;background:#FF5F56;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#FFBD2E;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#27C93F;display:inline-block;"></span>
        </div>
        <div style="color:#94a3b8;">$ <span style="color:#00BCD4;">openclaw</span> cook "Reply to customer asking about pricing"</div>
        <div style="color:#64748b;">→ Analyzing request...</div>
        <div style="color:#64748b;">→ Fetching products from CRM...</div>
        <div style="color:#94a3b8;">✓ <span style="color:#4ade80;">Replied:</span> "Starter plan: $8/mo, Pro plan: $20/mo 🚀"</div>
        <div style="color:#64748b;">→ Saved to CRM: lead interested in Pro</div>
        <div style="color:#7C4DFF;">⚡ 1.1s · 1 credit used</div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" style="background:var(--md-surface);">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">Features</div>
        <h2 class="headline">Everything you need to <span class="gradient-text">grow faster</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:480px;margin:16px auto 0;">AI handles repetitive tasks so you can focus on growth.</p>
      </div>
      <div class="grid-4">
        {features.map((f, i) => (
          <div class="card-glass animate-on-scroll" style={`animation-delay:${i*0.1}s`}>
            <div class="icon-container">{f.icon}</div>
            <h3 style="font-size:1.1rem;font-weight:600;margin-bottom:10px;">{f.title}</h3>
            <p style="color:var(--md-on-surface-muted);font-size:0.9rem;line-height:1.65;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="background:var(--md-surface-container);">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">Get Started</div>
        <h2 class="headline">Up and running in <span class="gradient-text">3 steps</span></h2>
      </div>
      <!-- Connector dots (desktop only) -->
      <div style="display:flex;align-items:center;gap:0;margin-bottom:-20px;padding:0 calc(100%/6 - 20px);position:relative;z-index:1;" class="animate-on-scroll">
        <span class="step-dot"></span><span class="step-line"></span>
        <span class="step-dot"></span><span class="step-line"></span>
        <span class="step-dot"></span>
      </div>
      <div class="grid-3">
        {steps.map((s, i) => (
          <div class="card animate-on-scroll" style={`position:relative;overflow:hidden;animation-delay:${i*0.12}s`}>
            <div style="position:absolute;top:16px;right:20px;font-family:'Be Vietnam Pro',sans-serif;font-size:3.5rem;font-weight:800;color:rgba(0,188,212,0.06);line-height:1;user-select:none;">{s.num}</div>
            <div class="badge" style="margin-bottom:16px;font-size:0.78rem;">{s.time}</div>
            <h3 style="font-size:1.2rem;font-weight:700;margin-bottom:10px;">{s.title}</h3>
            <p style="color:var(--md-on-surface-muted);font-size:0.9rem;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PLATFORM POWER -->
  <section style="background:var(--md-surface);position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(0,188,212,0.04),transparent 70%);pointer-events:none;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">Platform</div>
        <h2 class="headline">The power <span class="gradient-text">behind every command</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:500px;margin:16px auto 0;">The largest AI ecosystem for business automation — built by top engineers.</p>
      </div>
      <div style="display:flex;justify-content:center;gap:20px;flex-wrap:wrap;">
        {platformStats.map((s, i) => (
          <div class="card-glass animate-on-scroll" style={`text-align:center;min-width:160px;flex:1;max-width:200px;animation-delay:${i*0.08}s`}>
            <div style="font-family:'Be Vietnam Pro',sans-serif;font-size:2.5rem;font-weight:800;line-height:1;" class="gradient-text">{s.value}</div>
            <div style="font-size:0.9rem;font-weight:600;margin:8px 0 4px;">{s.label}</div>
            <div style="font-size:0.78rem;color:var(--md-on-surface-muted);">{s.desc}</div>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top:36px;">
        <a href="https://docs.agencyos.network/guides/all-commands" class="btn-outline" style="font-size:0.9rem;padding:10px 24px;">View all →</a>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section style="background:var(--md-surface-container);">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:48px;">
        <div class="badge" style="margin-bottom:16px;">What customers say</div>
        <h2 class="headline"><span class="gradient-text">Trusted</span> by founders</h2>
      </div>
      <div class="grid-3">
        {testimonials.map((t, i) => (
          <div class="card animate-on-scroll" style={`animation-delay:${i*0.1}s`}>
            <p style="color:var(--md-on-surface-muted);font-size:0.9rem;line-height:1.7;margin-bottom:16px;font-style:italic;">"{t.text}"</p>
            <div style="display:flex;align-items:center;gap:10px;">
              <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#00BCD4,#7C4DFF);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:#fff;">{t.name[0]}</div>
              <div>
                <div style="font-size:0.85rem;font-weight:600;">{t.name}</div>
                <div style="font-size:0.75rem;color:var(--md-on-surface-muted);">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" style="background:var(--md-surface);">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:0;">
        <div class="badge" style="margin-bottom:16px;">Pricing</div>
        <h2 class="headline">Simple, <span class="gradient-text">transparent pricing</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:400px;margin:16px auto 32px;">14-day free trial. Cancel anytime. No hidden fees.</p>
        <!-- Toggle (visual only) -->
        <div style="display:flex;justify-content:center;margin-bottom:48px;">
          <div class="pricing-toggle">
            <span class="toggle-opt active">Monthly</span>
            <span class="toggle-opt">Annual <span style="font-size:0.7rem;color:#4ade80;margin-left:4px;">-20%</span></span>
          </div>
        </div>
      </div>
      <div class="grid-4" style="align-items:start;">
        {plans.map((p, i) => (
          <div class={`animate-on-scroll${p.featured ? ' pricing-featured' : ' card'}`} style={`animation-delay:${i*0.1}s;border-radius:var(--md-radius);padding:28px;position:relative;${!p.featured ? 'background:var(--md-surface-container);border:1px solid var(--md-outline);' : ''}`}>
            {p.tag && (
              <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#00BCD4,#7C4DFF);color:#fff;font-size:0.72rem;font-weight:700;padding:4px 14px;border-radius:100px;white-space:nowrap;">{p.tag}</div>
            )}
            <div style="margin-bottom:20px;">
              <div style="font-size:0.85rem;color:var(--md-on-surface-muted);margin-bottom:6px;">{p.name}</div>
              <div style="display:flex;align-items:baseline;gap:2px;">
                <span style="font-family:'Be Vietnam Pro',sans-serif;font-size:2.2rem;font-weight:800;">{p.price}</span>
                <span style="font-size:0.85rem;color:var(--md-on-surface-muted);">{p.period}</span>
              </div>
            </div>
            <ul style="list-style:none;margin-bottom:24px;display:flex;flex-direction:column;gap:10px;">
              {p.features.map(feat => (
                <li style="font-size:0.875rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;">
                  <span style="color:#00BCD4;flex-shrink:0;font-weight:600;">✓</span>{feat}
                </li>
              ))}
            </ul>
            <a href={p.href} class={p.featured ? 'btn-primary' : 'btn-outline'} style="display:flex;justify-content:center;width:100%;text-align:center;">{p.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" style="background:var(--md-surface-container);">
    <div class="container" style="max-width:720px;">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">FAQ</div>
        <h2 class="headline">Frequently asked <span class="gradient-text">questions</span></h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px;">
        {faqs.map((f, i) => (
          <details class="card animate-on-scroll" style={`animation-delay:${i*0.08}s;padding:0;`} open={i===0}>
            <summary style="padding:20px 24px;cursor:pointer;font-weight:600;font-size:0.975rem;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:12px;">
              {f.q}
              <svg class="chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--md-primary);flex-shrink:0;transition:transform 0.25s ease;"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </summary>
            <div style="padding:0 24px 20px;color:var(--md-on-surface-muted);font-size:0.9rem;line-height:1.7;border-top:1px solid var(--md-outline);">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section style="background:var(--md-surface);">
    <div class="container">
      <div class="animate-on-scroll" style="background:linear-gradient(135deg,rgba(0,188,212,0.08),rgba(124,77,255,0.1));border:1px solid rgba(0,188,212,0.2);border-radius:var(--md-radius);padding:72px 40px;text-align:center;position:relative;overflow:hidden;">
        <div style="position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(124,77,255,0.15),transparent 70%);pointer-events:none;"></div>
        <div style="position:absolute;bottom:-40px;left:-40px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(0,188,212,0.1),transparent 70%);pointer-events:none;"></div>
        <h2 class="headline" style="margin-bottom:16px;position:relative;">Ready to let AI <span class="gradient-text">work for you?</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:440px;margin:0 auto 40px;position:relative;">
          Join 500+ businesses saving 20+ hours per week with OpenClaw.
        </p>
        <a href="https://app.agencyos.network/signup" class="btn-primary btn-pulse" style="font-size:1.05rem;padding:16px 44px;position:relative;">Start for free →</a>
      </div>
    </div>
  </section>

  <style>
    details[open] summary svg { transform: rotate(180deg); }
  </style>

</BaseLayout>
