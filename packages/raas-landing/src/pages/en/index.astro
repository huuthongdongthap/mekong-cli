---
import BaseLayout from '../../layouts/base-layout.astro';

const features = [
  { icon: '🤖', title: 'AI Receptionist', desc: 'Never miss a customer message again. AI replies on Zalo & Facebook in under 3 seconds — closing leads while you sleep.' },
  { icon: '✍️', title: 'Content Creator', desc: 'A full week of posts, drafted and scheduled automatically. Stop staring at a blank screen — just review and hit publish.' },
  { icon: '📊', title: 'Smart CRM', desc: 'Every customer auto-profiled, hot leads flagged, past buyers re-engaged at exactly the right moment. Your memory, supercharged.' },
  { icon: '📈', title: 'Real-time Reports', desc: 'No more manual reporting. See exactly which channel is making money, which week to push harder — live data, zero spreadsheets.' },
];

const steps = [
  { num: '01', title: 'Sign up free', time: '2 min', desc: 'Email in, account created. No credit card, no forms, no sales call.' },
  { num: '02', title: 'Connect your channels', time: '5 min', desc: 'Point-and-click Zalo/Facebook integration. No code, no IT ticket.' },
  { num: '03', title: 'Watch it work', time: '24/7', desc: 'AI starts replying, creating content, and reporting — automatically, from the first minute.' },
];

const plans = [
  { name: 'Free',       price: '$0',   period: '/mo', tag: '', features: ['50 credits/month', 'Basic AI Receptionist', '3 days content/month', 'CRM: 50 contacts'], cta: 'See results in 5 minutes', href: 'https://app.agencyos.network/signup', featured: false },
  { name: 'Starter',   price: '$49',  period: '/mo', tag: '', features: ['200 MCU credits/month', '24/7 AI Receptionist', '7 days content/week', 'Unlimited CRM', 'Weekly reports'], cta: 'Start free for 14 days →', href: 'https://app.agencyos.network/signup?plan=starter', featured: false },
  { name: 'Pro',        price: '$149', period: '/mo', tag: 'Most popular', features: ['1,000 MCU credits/month', 'Multi-channel (Zalo+FB+Web)', 'Industry-tuned AI', 'API access', 'SLA 99.9%'], cta: 'I want to scale →', href: 'https://app.agencyos.network/signup?plan=pro', featured: true },
  { name: 'Enterprise', price: '$499', period: '/mo', tag: '', features: ['Unlimited MCU credits', 'Your own dedicated AI model', 'Full white-label', '1-on-1 onboarding', 'SLA 99.99%'], cta: "Let's talk", href: 'mailto:hello@agencyos.network', featured: false },
];

const faqs = [
  { q: 'Do I need to know how to code?', a: 'No. Point-and-click setup. If you can use Facebook, you can use OpenClaw.' },
  { q: 'Which industries work best?', a: 'Any business where customers send messages: cafes, restaurants, spas, gyms, fashion, e-commerce, convenience stores.' },
  { q: 'How does billing work?', a: 'Visa/Mastercard via Polar.sh. Secure checkout, no card stored after trial, cancel anytime.' },
  { q: 'What happens if I cancel?', a: '1-click cancel, no questions asked, no penalty. Your data stays for 30 days so you can export it.' },
  { q: 'Who has access to my customer data?', a: 'Nobody but you. Runs on Cloudflare Workers with end-to-end encryption. We never sell or share data.' },
];

const platformStats = [
  { value: '319', label: 'Commands', desc: 'CLI commands for every layer' },
  { value: '540', label: 'AI Skills', desc: 'Specialized skill library' },
  { value: '17', label: 'AI Agents', desc: 'Self-operating agents' },
  { value: '410', label: 'Contracts', desc: 'Ready-made machine contracts' },
  { value: '13', label: 'Hooks', desc: 'Auto-trigger pipelines' },
];

const testimonials = [
  { name: 'Minh Tuan', role: 'CEO, FoodTech Startup', text: 'One-person team, 5-person output. That\'s OpenClaw in one sentence.' },
  { name: 'Ha Linh', role: 'Founder, Beauty Brand', text: 'I wake up to closed orders. AI handled the 2 AM messages so I didn\'t have to.' },
  { name: 'Duc Anh', role: 'CTO, SaaS Platform', text: 'Billing, metering, auto-replies — zero-cost on Cloudflare Workers. This thing is engineered right.' },
];

// JSON-LD Structured Data
const softwareAppSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "OpenClaw",
  "description": "AI-powered business automation platform with 24/7 customer replies, content creation, and smart CRM",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web-based",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "ratingCount": "500"
  },
  "featureList": features.map(f => f.title).join(', ')
};

const faqPageSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": "https://agencyos.network"
  }]
};
---

<BaseLayout
  title="OpenClaw — AI-Powered Business Automation | Increase 35% Revenue"
  description="AI business automation: 24/7 customer replies, auto content creation, smart CRM. Free 14-day trial. Trusted by 500+ businesses. Increase 35% revenue, save 20+ hours/week."
  lang="en"
  type="website"
  canonical="/en"
  keywords="AI automation, business automation, CRM, content creation, customer service, SaaS, enterprise AI, marketing automation, Vietnam, AI Receptionist, Zalo automation, Facebook automation, CRM software, chatbot, auto reply, increase revenue, save time, AI marketing, business automation Vietnam, customer engagement"
  ogTitle="OpenClaw — AI Working For You 24/7 | Increase 35% Revenue"
  ogDescription="AI automation: 24/7 customer replies, content creation, smart CRM. Trusted by 500+ businesses. Start free 14-day trial."
  twitterTitle="OpenClaw — AI Business Automation 24/7"
  twitterDescription="AI automation: 24/7 customer replies, content creation, smart CRM. Increase 35% revenue, save 20+ hours/week."
>

  <!-- HERO -->
  <section style="background:linear-gradient(135deg,#0a0f1a 0%,#1a1040 50%,#0a2030 100%);min-height:90vh;display:flex;align-items:center;position:relative;overflow:hidden;" aria-label="OpenClaw Introduction">
    <!-- Animated mesh orbs (decorative) -->
    <div style="position:absolute;top:15%;left:5%;width:380px;height:380px;border-radius:50%;background:radial-gradient(circle,rgba(0,188,212,0.12),transparent 70%);filter:blur(40px);pointer-events:none;animation:meshDrift 16s ease-in-out infinite alternate;" aria-hidden="true"></div>
    <div style="position:absolute;bottom:10%;right:8%;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(124,77,255,0.1),transparent 70%);filter:blur(40px);pointer-events:none;animation:meshDrift 20s ease-in-out infinite alternate-reverse;" aria-hidden="true"></div>
    <div style="position:absolute;top:60%;left:40%;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(0,188,212,0.06),transparent 70%);filter:blur(30px);pointer-events:none;animation:meshDrift 24s ease-in-out infinite alternate;" aria-hidden="true"></div>

    <div class="container" style="position:relative;z-index:1;padding:80px 24px;">
      <div style="max-width:760px;">
        <div class="badge animate-in" style="margin-bottom:28px;" role="status">✨ AI that replies, sells, and reports — while you sleep</div>
        <h1 class="display animate-in" style="margin-bottom:24px;animation-delay:0.1s;">
          Stop answering<br /><span class="gradient-text">customer messages.</span>
        </h1>
        <p style="font-size:clamp(1rem,2vw,1.2rem);color:var(--md-on-surface-muted);max-width:520px;margin-bottom:16px;" class="animate-in">
          For solo founders and small teams who want to sell more without hiring more. AI handles replies, content, and CRM — automatically.
        </p>
        <!-- Stats row -->
        <div style="display:flex;gap:32px;margin-bottom:24px;flex-wrap:wrap;" class="animate-in" role="list" aria-label="Platform statistics">
          {[['500+', 'businesses'],['1M+', 'messages'],['99.9%', 'uptime']].map(([v,l]) => (
            <div role="listitem">
              <div style="font-family:'Be Vietnam Pro',sans-serif;font-size:1.5rem;font-weight:800;" class="gradient-text">{v}</div>
              <div style="font-size:0.8rem;color:var(--md-on-surface-muted);">{l}</div>
            </div>
          ))}
        </div>
        <!-- Social proof badges -->
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:36px;" class="animate-in" role="list" aria-label="Trust badges">
          <span class="proof-badge" role="listitem"><span class="dot"></span>500+ businesses automated</span>
          <span class="proof-badge" role="listitem">🏆 #1 AI tool in Vietnam 2025</span>
        </div>
        <div style="display:flex;gap:16px;flex-wrap:wrap;" class="animate-in" role="group" aria-label="Quick actions">
          <a href="https://app.agencyos.network/signup" class="btn-primary btn-pulse" style="font-size:1.05rem;" aria-label="Start automating free, no credit card required">Start automating free →</a>
          <a href="#features" class="btn-outline" aria-label="View OpenClaw features">See how it works</a>
        </div>
      </div>

      <!-- Terminal mockup -->
      <div class="terminal animate-on-scroll" style="margin-top:56px;max-width:520px;" aria-label="Example OpenClaw CLI interaction">
        <div style="display:flex;gap:6px;margin-bottom:14px;" aria-hidden="true">
          <span style="width:10px;height:10px;border-radius:50%;background:#FF5F56;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#FFBD2E;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#27C93F;display:inline-block;"></span>
        </div>
        <div style="color:#94a3b8;">$ <span style="color:#00BCD4;">openclaw</span> cook "Reply to customer asking about pricing"</div>
        <div style="color:#64748b;">→ Analyzing request...</div>
        <div style="color:#64748b;">→ Fetching products from CRM...</div>
        <div style="color:#94a3b8;">✓ <span style="color:#4ade80;">Replied:</span> "Starter plan: $49/mo, Pro plan: $149/mo 🚀"</div>
        <div style="color:#64748b;">→ Saved to CRM: lead interested in Pro</div>
        <div style="color:#7C4DFF;">⚡ 1.1s · 1 credit used</div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" style="background:var(--md-surface);">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">Features</div>
        <h2 class="headline">Four things that let you <span class="gradient-text">sell more without doing more</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:480px;margin:16px auto 0;">AI does the repetitive work. You do the important work.</p>
      </div>
      <div class="grid-4">
        {features.map((f, i) => (
          <div class="card-glass animate-on-scroll" style={`animation-delay:${i*0.1}s`}>
            <div class="icon-container">{f.icon}</div>
            <h3 style="font-size:1.1rem;font-weight:600;margin-bottom:10px;">{f.title}</h3>
            <p style="color:var(--md-on-surface-muted);font-size:0.9rem;line-height:1.65;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="background:var(--md-surface-container);">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">Get Started</div>
        <h2 class="headline">Running in <span class="gradient-text">under 10 minutes</span></h2>
      </div>
      <!-- Connector dots (desktop only) -->
      <div style="display:flex;align-items:center;gap:0;margin-bottom:-20px;padding:0 calc(100%/6 - 20px);position:relative;z-index:1;" class="animate-on-scroll">
        <span class="step-dot"></span><span class="step-line"></span>
        <span class="step-dot"></span><span class="step-line"></span>
        <span class="step-dot"></span>
      </div>
      <div class="grid-3">
        {steps.map((s, i) => (
          <div class="card animate-on-scroll" style={`position:relative;overflow:hidden;animation-delay:${i*0.12}s`}>
            <div style="position:absolute;top:16px;right:20px;font-family:'Be Vietnam Pro',sans-serif;font-size:3.5rem;font-weight:800;color:rgba(0,188,212,0.06);line-height:1;user-select:none;">{s.num}</div>
            <div class="badge" style="margin-bottom:16px;font-size:0.78rem;">{s.time}</div>
            <h3 style="font-size:1.2rem;font-weight:700;margin-bottom:10px;">{s.title}</h3>
            <p style="color:var(--md-on-surface-muted);font-size:0.9rem;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PLATFORM POWER -->
  <section style="background:var(--md-surface);position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(0,188,212,0.04),transparent 70%);pointer-events:none;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">Platform</div>
        <h2 class="headline">An AI platform <span class="gradient-text">built for real business scale</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:500px;margin:16px auto 0;">Not a chatbot wrapper. A full automation engine with 540 skills, 17 agents, and 410 pre-built contracts.</p>
      </div>
      <div style="display:flex;justify-content:center;gap:20px;flex-wrap:wrap;">
        {platformStats.map((s, i) => (
          <div class="card-glass animate-on-scroll" style={`text-align:center;min-width:160px;flex:1;max-width:200px;animation-delay:${i*0.08}s`}>
            <div style="font-family:'Be Vietnam Pro',sans-serif;font-size:2.5rem;font-weight:800;line-height:1;" class="gradient-text">{s.value}</div>
            <div style="font-size:0.9rem;font-weight:600;margin:8px 0 4px;">{s.label}</div>
            <div style="font-size:0.78rem;color:var(--md-on-surface-muted);">{s.desc}</div>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top:36px;">
        <a href="https://docs.agencyos.network/guides/all-commands" class="btn-outline" style="font-size:0.9rem;padding:10px 24px;">View all →</a>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section style="background:var(--md-surface-container);">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:48px;">
        <div class="badge" style="margin-bottom:16px;">What customers say</div>
        <h2 class="headline">Real numbers. <span class="gradient-text">Real founders.</span></h2>
      </div>
      <div class="grid-3">
        {testimonials.map((t, i) => (
          <div class="card animate-on-scroll" style={`animation-delay:${i*0.1}s`}>
            <p style="color:var(--md-on-surface-muted);font-size:0.9rem;line-height:1.7;margin-bottom:16px;font-style:italic;">"{t.text}"</p>
            <div style="display:flex;align-items:center;gap:10px;">
              <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#00BCD4,#7C4DFF);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:#fff;">{t.name[0]}</div>
              <div>
                <div style="font-size:0.85rem;font-weight:600;">{t.name}</div>
                <div style="font-size:0.75rem;color:var(--md-on-surface-muted);">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" style="background:var(--md-surface);">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:0;">
        <div class="badge" style="margin-bottom:16px;">Pricing</div>
        <h2 class="headline">Pay for what you use. <span class="gradient-text">Stop when you want.</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:400px;margin:16px auto 32px;">Full 14-day trial, no credit card. 1-click cancel, no questions.</p>
        <!-- Toggle (visual only) -->
        <div style="display:flex;justify-content:center;margin-bottom:48px;">
          <div class="pricing-toggle">
            <span class="toggle-opt active">Monthly</span>
            <span class="toggle-opt">Annual <span style="font-size:0.7rem;color:#4ade80;margin-left:4px;">-20%</span></span>
          </div>
        </div>
      </div>
      <div class="grid-4" style="align-items:start;">
        {plans.map((p, i) => (
          <div class={`animate-on-scroll${p.featured ? ' pricing-featured' : ' card'}`} style={`animation-delay:${i*0.1}s;border-radius:var(--md-radius);padding:28px;position:relative;${!p.featured ? 'background:var(--md-surface-container);border:1px solid var(--md-outline);' : ''}`}>
            {p.tag && (
              <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#00BCD4,#7C4DFF);color:#fff;font-size:0.72rem;font-weight:700;padding:4px 14px;border-radius:100px;white-space:nowrap;">{p.tag}</div>
            )}
            <div style="margin-bottom:20px;">
              <div style="font-size:0.85rem;color:var(--md-on-surface-muted);margin-bottom:6px;">{p.name}</div>
              <div style="display:flex;align-items:baseline;gap:2px;">
                <span style="font-family:'Be Vietnam Pro',sans-serif;font-size:2.2rem;font-weight:800;">{p.price}</span>
                <span style="font-size:0.85rem;color:var(--md-on-surface-muted);">{p.period}</span>
              </div>
            </div>
            <ul style="list-style:none;margin-bottom:24px;display:flex;flex-direction:column;gap:10px;">
              {p.features.map(feat => (
                <li style="font-size:0.875rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;">
                  <span style="color:#00BCD4;flex-shrink:0;font-weight:600;">✓</span>{feat}
                </li>
              ))}
            </ul>
            <a href={p.href} class={p.featured ? 'btn-primary' : 'btn-outline'} style="display:flex;justify-content:center;width:100%;text-align:center;">{p.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" style="background:var(--md-surface-container);">
    <div class="container" style="max-width:720px;">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">FAQ</div>
        <h2 class="headline">Frequently asked <span class="gradient-text">questions</span></h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px;">
        {faqs.map((f, i) => (
          <details class="card animate-on-scroll" style={`animation-delay:${i*0.08}s;padding:0;`} open={i===0}>
            <summary style="padding:20px 24px;cursor:pointer;font-weight:600;font-size:0.975rem;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:12px;">
              {f.q}
              <svg class="chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--md-primary);flex-shrink:0;transition:transform 0.25s ease;"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </summary>
            <div style="padding:0 24px 20px;color:var(--md-on-surface-muted);font-size:0.9rem;line-height:1.7;border-top:1px solid var(--md-outline);">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section style="background:var(--md-surface);">
    <div class="container">
      <div class="animate-on-scroll" style="background:linear-gradient(135deg,rgba(0,188,212,0.08),rgba(124,77,255,0.1));border:1px solid rgba(0,188,212,0.2);border-radius:var(--md-radius);padding:72px 40px;text-align:center;position:relative;overflow:hidden;">
        <div style="position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(124,77,255,0.15),transparent 70%);pointer-events:none;"></div>
        <div style="position:absolute;bottom:-40px;left:-40px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(0,188,212,0.1),transparent 70%);pointer-events:none;"></div>
        <h2 class="headline" style="margin-bottom:16px;position:relative;">Customers are messaging right now. <span class="gradient-text">Is your AI ready?</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:440px;margin:0 auto 40px;position:relative;">
          500+ businesses stopped replying manually. Setup takes 7 minutes. Results start today.
        </p>
        <a href="https://app.agencyos.network/signup" class="btn-primary btn-pulse" style="font-size:1.05rem;padding:16px 44px;position:relative;">Start automating free →</a>
      </div>
    </div>
  </section>

  <style>
    details[open] summary svg { transform: rotate(180deg); }
  </style>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify([softwareAppSchema, faqPageSchema, breadcrumbSchema])} />

</BaseLayout>
