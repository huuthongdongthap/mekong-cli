---
import BaseLayout from '../../layouts/base-layout.astro';
---

<BaseLayout
  title="OpenClaw Community — Discord, GitHub & Social"
  description="Join the OpenClaw community. Connect on Discord, contribute on GitHub, follow on Twitter, and read the blog."
  lang="en"
  canonical="/en/community"
>

  <!-- Hero -->
  <section style="background:linear-gradient(135deg,#0a0f1a,#1a1040 60%,#0a2030);padding:96px 0 64px;text-align:center;">
    <div class="container">
      <div class="badge animate-in" style="margin-bottom:20px;">Community</div>
      <h1 class="display animate-in" style="margin-bottom:16px;">
        OpenClaw <span class="gradient-text">Community</span>
      </h1>
      <p style="color:var(--md-on-surface-muted);max-width:480px;margin:0 auto 0;" class="animate-in">
        Connect with thousands of developers and founders building with OpenClaw. Share, learn, and contribute.
      </p>
    </div>
  </section>

  <!-- Community Cards Grid -->
  <section style="background:var(--md-surface);padding:64px 0;">
    <div class="container">
      <div class="community-grid">

        <!-- Discord Card -->
        <a href="https://discord.gg/openclaw" target="_blank" rel="noopener noreferrer" class="community-card">
          <div class="card-icon" style="background:rgba(88,101,242,0.15);color:#5865F2;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.032.054a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
          </div>
          <h2 class="card-title">Join Discord</h2>
          <p class="card-desc">Chat directly with the community. Ask questions, showcase projects, report bugs, and request features.</p>
          <div class="card-channels">
            <span class="channel-tag">#general</span>
            <span class="channel-tag">#showcase</span>
            <span class="channel-tag">#bugs</span>
            <span class="channel-tag">#feature-requests</span>
          </div>
          <span class="card-cta">Join Discord →</span>
        </a>

        <!-- GitHub Card -->
        <a href="https://github.com/longtho638-jpg/mekong-cli" target="_blank" rel="noopener noreferrer" class="community-card">
          <div class="card-icon" style="background:rgba(255,255,255,0.08);color:#e6edf3;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
          </div>
          <h2 class="card-title">Open Source</h2>
          <p class="card-desc">OpenClaw is open source. Star the repo, open issues, contribute code, and help build the platform.</p>
          <div class="card-channels">
            <span class="channel-tag">⭐ Star repo</span>
            <span class="channel-tag">🐛 Issues</span>
            <span class="channel-tag">🔀 Contribute</span>
          </div>
          <span class="card-cta">View GitHub →</span>
        </a>

        <!-- Twitter/X Card -->
        <a href="https://x.com/openclaw_ai" target="_blank" rel="noopener noreferrer" class="community-card">
          <div class="card-icon" style="background:rgba(255,255,255,0.06);color:#e7e7e7;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </div>
          <h2 class="card-title">Follow @OpenClaw</h2>
          <p class="card-desc">Stay updated with new features, tips & tricks, case studies, and announcements on X (Twitter).</p>
          <div class="card-channels">
            <span class="channel-tag">📢 Announcements</span>
            <span class="channel-tag">💡 Tips</span>
            <span class="channel-tag">🚀 Updates</span>
          </div>
          <span class="card-cta">Follow →</span>
        </a>

        <!-- Blog Card -->
        <a href="/en/blog" class="community-card">
          <div class="card-icon" style="background:rgba(6,182,212,0.12);color:#06b6d4;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h2 class="card-title">Blog & Tutorials</h2>
          <p class="card-desc">In-depth guides, real-world case studies, and insights from the OpenClaw team.</p>
          <div class="card-channels">
            <span class="channel-tag">📝 Tutorials</span>
            <span class="channel-tag">📊 Case Studies</span>
            <span class="channel-tag">🔧 How-to</span>
          </div>
          <span class="card-cta">Read Blog →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- Mission Monday -->
  <section style="background:linear-gradient(135deg,#0a0f1a,#0d1f35);padding:80px 0;">
    <div class="container" style="text-align:center;">
      <div class="badge animate-on-scroll" style="margin-bottom:20px;background:rgba(6,182,212,0.1);border-color:rgba(6,182,212,0.3);color:#06b6d4;">
        Every Monday
      </div>
      <h2 style="font-size:2rem;font-weight:800;margin-bottom:16px;" class="animate-on-scroll">
        Mission <span class="gradient-text">Monday</span>
      </h2>
      <p style="color:var(--md-on-surface-muted);max-width:520px;margin:0 auto 32px;line-height:1.7;" class="animate-on-scroll">
        Every Monday, the OpenClaw community tackles a real-world challenge together —
        from automating workflows, building new agents, to shipping a product in 24 hours.
        Completers earn a badge and get featured on the homepage.
      </p>
      <div class="mission-stats animate-on-scroll">
        <div class="mission-stat">
          <div class="mission-stat-value">Every Monday</div>
          <div class="mission-stat-label">New challenge</div>
        </div>
        <div class="mission-stat">
          <div class="mission-stat-value">24h</div>
          <div class="mission-stat-label">Time to complete</div>
        </div>
        <div class="mission-stat">
          <div class="mission-stat-value">🏆</div>
          <div class="mission-stat-label">Badge & Featured</div>
        </div>
      </div>
      <a href="https://discord.gg/openclaw" target="_blank" rel="noopener noreferrer" class="btn-primary animate-on-scroll" style="margin-top:32px;">
        Join Mission Monday →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .community-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .community-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 32px;
    background: var(--md-surface-container, #111827);
    border: 1px solid var(--md-outline, rgba(255,255,255,0.08));
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .community-card:hover {
    border-color: #06b6d4;
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(6,182,212,0.12);
  }

  .card-icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--md-on-surface, #f1f5f9);
    margin: 0;
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--md-on-surface-muted, #94a3b8);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .card-channels {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .channel-tag {
    font-size: 0.75rem;
    padding: 4px 10px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 100px;
    color: var(--md-on-surface-muted, #94a3b8);
  }

  .card-cta {
    font-size: 0.875rem;
    font-weight: 600;
    color: #06b6d4;
    margin-top: auto;
  }

  .mission-stats {
    display: flex;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
  }

  .mission-stat {
    text-align: center;
  }

  .mission-stat-value {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--md-on-surface, #f1f5f9);
    margin-bottom: 4px;
  }

  .mission-stat-label {
    font-size: 0.8rem;
    color: var(--md-on-surface-muted, #94a3b8);
  }

  @media (max-width: 768px) {
    .community-grid {
      grid-template-columns: 1fr;
    }

    .mission-stats {
      gap: 32px;
    }
  }
</style>
