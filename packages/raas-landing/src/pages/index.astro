  { value: '24/7', label: 'hỗ trợ khách hàng' },
];

const customerLogos = [
  { name: 'FoodTech Startup', icon: '🍜' },
  { name: 'Beauty Brand', icon: '💄' },
  { name: 'Cafe Chain', icon: '☕' },
  { name: 'E-commerce', icon: '🛒' },
  { name: 'SaaS Platform', icon: '💻' },
