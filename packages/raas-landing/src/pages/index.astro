---

<BaseLayout
  title="OpenClaw — AI Làm Việc Thay Bạn 24/7 | Tự Động 100%, Trả Lời Trong 3 Giây"
  description="AI Receptionist cho Zalo & Facebook — CRM thông minh — Tạo content tự động. Miễn phí 14 ngày, không cần thẻ tín dụng. 500+ doanh nghiệp Việt tin dùng. Tăng 35% doanh thu, tiết kiệm 20+ giờ/tuần."
  lang="vi"
  type="website"
  canonical="/"
  keywords="AI tự động hóa, AI Receptionist, Zalo automation, Facebook automation, CRM thông minh, tạo content tự động, trả lời khách 24/7, tăng doanh thu, tiết kiệm thời gian, business automation Vietnam, SaaS Vietnam, Polar.sh"
  ogTitle="OpenClaw — AI Làm Việc Thay Bạn 24/7 | Tăng 35% Doanh Thu"
  ogDescription="AI tự động hóa: trả lời khách 24/7, tạo content, CRM thông minh. 500+ doanh nghiệp Việt tin dùng. Dùng thử miễn phí 14 ngày."
  twitterTitle="OpenClaw — AI Vận Hành Doanh Nghiệp 24/7"
  twitterDescription="AI tự động hóa: trả lời khách 24/7, tạo content, CRM thông minh. Tăng 35% doanh thu, tiết kiệm 20+ giờ/tuần."
>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify([softwareAppSchema, raasServiceSchema, faqPageSchema, breadcrumbSchema])} />

  <!-- HERO -->
  <section class="hero-section" aria-label="Giới thiệu OpenClaw">
    <!-- Enhanced animated mesh gradient orbs (decorative) -->
    <div class="mesh-orb orb-1" aria-hidden="true"></div>
    <div class="mesh-orb orb-2" aria-hidden="true"></div>
    <div class="mesh-orb orb-3" aria-hidden="true"></div>
    <div class="mesh-orb orb-4" aria-hidden="true"></div>

    <div class="container hero-container">
      <div class="hero-content">
        <!-- FOMO Badge - Top Urgency -->
        <div class="fomo-badge-wrapper animate-in" style="margin-bottom:12px;" role="status" aria-live="polite" aria-atomic="true" aria-label="47 doanh nghiệp đăng ký hôm nay">
          <div class="fomo-badge">
            <span class="fomo-icon" aria-hidden="true">🔥</span>
            <span class="fomo-text">47 doanh nghiệp đăng ký hôm nay</span>
            <span class="fomo-live-dot" aria-hidden="true"></span>
          </div>
        </div>

        <!-- Main Hero Badge -->
        <div class="hero-badge animate-in" style="margin-bottom:24px;">
          <span class="badge-icon" aria-hidden="true">✨</span>
          <span class="badge-text">AI trả lời Zalo & Facebook · Tạo content tự động · CRM thông minh</span>
        </div>

        <h1 class="display animate-in" style="margin-bottom:20px;animation-delay:0.1s;">
          <span class="gradient-text">Đừng trả lời khách nữa.</span><br />
          Để AI làm — <span class="gradient-text-highlight">24/7, 3 giây/tin</span>
        </h1>

        <p class="hero-description animate-in" style="margin-bottom:28px;">
          Dành cho chủ shop, founder nhỏ, và team muốn bán nhiều hơn mà không thuê thêm người. Bắt đầu miễn phí, kết quả trong ngày đầu tiên.
        </p>

        <!-- Enhanced CTA Buttons with Stronger Animations -->
        <div class="hero-cta animate-in" style="margin-bottom:24px;" role="group" aria-label="Hành động nhanh">
          <a href="https://app.agencyos.network/signup" class="btn-primary btn-pulse btn-glow btn-cta-primary" aria-label="Bắt đầu miễn phí ngay, không cần thẻ tín dụng">
            <span class="cta-text">Bắt đầu miễn phí ngay</span>
            <svg class="btn-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#features" class="btn-outline btn-ghost btn-demo" aria-label="Xem demo 30 giây">
            <svg class="play-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="5 3 19 12 5 21 5 3"></polygon>
            </svg>
            <span>Xem demo 30s</span>
          </a>
        </div>

        <!-- Trust & Security Badges -->
        <div class="trust-badges animate-in" style="margin-bottom:24px;" role="list" aria-label="Chứng nhận bảo mật">
          <span class="trust-badge" role="listitem">
            <span class="trust-icon" aria-hidden="true">🔐</span>
            <span>SSL Encrypted</span>
          </span>
          <span class="trust-badge" role="listitem">
            <span class="trust-icon" aria-hidden="true">☁️</span>
            <span>Cloudflare Protected</span>
          </span>
          <span class="trust-badge" role="listitem">
            <span class="trust-icon" aria-hidden="true">✓</span>
            <span>Không cần thẻ tín dụng</span>
          </span>
          <span class="trust-badge" role="listitem">
            <span class="trust-icon" aria-hidden="true">⚡</span>
            <span>Setup 2 phút</span>
          </span>
          <span class="trust-badge" role="listitem">
            <span class="trust-icon" aria-hidden="true">🏆</span>
            <span>Top 1 AI VN 2025</span>
          </span>
          <span class="trust-badge" role="listitem">
            <span class="trust-icon" aria-hidden="true">⭐</span>
            <span>4.9/5 từ 500+ reviews</span>
          </span>
        </div>

        <!-- Enhanced Social Proof Counter with Animation -->
        <div class="social-proof-counter animate-in" style="margin-bottom:28px;" aria-label="Thống kê nền tảng">
          <div class="counter-item">
            <div class="counter-value" data-target="500">0</div>
            <div class="counter-suffix">+</div>
            <div class="counter-label">doanh nghiệp Việt</div>
          </div>
          <div class="counter-divider"></div>
          <div class="counter-item">
            <div class="counter-value" data-target="1">0</div>
            <div class="counter-suffix">M+</div>
            <div class="counter-label">tin nhắn đã xử lý</div>
          </div>
          <div class="counter-divider"></div>
          <div class="counter-item">
            <div class="counter-value" data-target="99">0</div>
            <div class="counter-suffix">.9%</div>
            <div class="counter-label">uptime 12 tháng</div>
          </div>
        </div>

        <!-- Customer Logos Carousel -->
        <div class="customer-logos animate-in" style="margin-bottom:28px;">
          <span class="logos-label">Được tin dùng bởi:</span>
          <div class="logos-grid logos-scroll">
            {customerLogos.map((logo, i) => (
              <div class="logo-item" title={logo.name} aria-label={logo.name}>
                <span class="logo-icon" aria-hidden="true">{logo.icon}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Social Proof Badges with Rating -->
        <div class="proof-badges animate-in" style="margin-bottom:24px;">
          <span class="proof-badge featured" role="img" aria-label="Top 1 AI Việt Nam 2025">
            <span class="badge-glow"></span>
            <span>🏆 Top 1 AI VN 2025</span>
          </span>
          <span class="proof-badge proof-rating" role="img" aria-label="4.9 trên 5 sao từ hơn 500 đánh giá">
            <span class="stars" aria-hidden="true">⭐⭐⭐⭐⭐</span>
            <span>4.9/5 từ 500+ reviews</span>
          </span>
        </div>

