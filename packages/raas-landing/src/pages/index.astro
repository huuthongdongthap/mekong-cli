---

<BaseLayout
  title="OpenClaw — AI Vận Hành Doanh Nghiệp Tự Động | Tăng 35% Doanh Thu"
  description="AI tự động hóa doanh nghiệp: trả lời khách 24/7, tạo content, CRM thông minh. Miễn phí 14 ngày. 500+ doanh nghiệp Việt tin dùng. Tăng 35% doanh thu, tiết kiệm 20+ giờ/tuần."
  lang="vi"
  type="website"
  canonical="/"
  keywords="AI tự động hóa, tự động hóa doanh nghiệp, CRM, tạo content, dịch vụ khách hàng, SaaS, AI doanh nghiệp, marketing tự động, Việt Nam, AI Receptionist, Zalo automation, Facebook automation, phần mềm CRM, chatbot Zalo, trả lời tự động, tăng doanh thu, tiết kiệm thời gian, AI marketing, business automation Vietnam"
  ogTitle="OpenClaw — AI Làm Việc Thay Bạn 24/7 | Tăng 35% Doanh Thu"
  ogDescription="AI tự động hóa: trả lời khách 24/7, tạo content, CRM thông minh. 500+ doanh nghiệp Việt tin dùng. Dùng thử miễn phí 14 ngày."
  twitterTitle="OpenClaw — AI Vận Hành Doanh Nghiệp 24/7"
  twitterDescription="AI tự động hóa: trả lời khách 24/7, tạo content, CRM thông minh. Tăng 35% doanh thu, tiết kiệm 20+ giờ/tuần."
>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify([softwareAppSchema, raasServiceSchema, faqPageSchema, breadcrumbSchema])} />

  <!-- HERO -->
  <section class="hero-section" aria-label="Giới thiệu OpenClaw">
    <!-- Enhanced animated mesh gradient orbs (decorative) -->
    <div class="mesh-orb orb-1" aria-hidden="true"></div>
    <div class="mesh-orb orb-2" aria-hidden="true"></div>
    <div class="mesh-orb orb-3" aria-hidden="true"></div>
    <div class="mesh-orb orb-4" aria-hidden="true"></div>

    <div class="container hero-container">
      <div class="hero-content">
        <!-- FOMO Badge - Top Urgency -->
        <div class="fomo-badge-wrapper animate-in" style="margin-bottom:12px;" role="status" aria-label="47 doanh nghiệp đăng ký hôm nay">
          <div class="fomo-badge">
            <span class="fomo-icon" aria-hidden="true">🔥</span>
            <span class="fomo-text">47 doanh nghiệp đăng ký hôm nay</span>
            <span class="fomo-live-dot" aria-hidden="true"></span>
          </div>
        </div>

        <!-- Main Hero Badge -->
        <div class="hero-badge animate-in" style="margin-bottom:24px;">
          <span class="badge-icon" aria-hidden="true">✨</span>
          <span class="badge-text">AI Receptionist cho Zalo & Facebook — Trả lời trong 3 giây</span>
        </div>

        <h1 class="display animate-in" style="margin-bottom:20px;animation-delay:0.1s;">
          <span class="gradient-text">AI Làm Việc Thay Bạn</span><br />
          24/7 <span class="gradient-text-highlight">Tự Động 100%</span>
        </h1>

        <p class="hero-description animate-in" style="margin-bottom:28px;">
          Tiết kiệm <span class="highlight">20+ giờ/tuần</span> · Tăng <span class="highlight">35% doanh thu</span> · CRM thông minh · Tạo content tự động
        </p>

        <!-- Enhanced CTA Buttons with Stronger Animations -->
        <div class="hero-cta animate-in" style="margin-bottom:24px;" role="group" aria-label="Hành động nhanh">
          <a href="https://app.agencyos.network/signup" class="btn-primary btn-pulse btn-glow btn-cta-primary" aria-label="Dùng thử miễn phí 14 ngày, không cần thẻ tín dụng">
            <span class="cta-text">Dùng thử miễn phí 14 ngày</span>
            <svg class="btn-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#features" class="btn-outline btn-ghost btn-demo" aria-label="Xem demo 30 giây">
            <svg class="play-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="5 3 19 12 5 21 5 3"></polygon>
            </svg>
            <span>Xem demo 30s</span>
          </a>
        </div>

        <!-- Trust & Security Badges -->
        <div class="trust-badges animate-in" style="margin-bottom:24px;" role="list" aria-label="Chứng nhận bảo mật">
          <span class="trust-badge" role="listitem">
            <span class="trust-icon" aria-hidden="true">🔐</span>
            <span>SSL Encrypted</span>
          </span>
          <span class="trust-badge" role="listitem">
            <span class="trust-icon" aria-hidden="true">☁️</span>
            <span>Cloudflare Protected</span>
          </span>
          <span class="trust-badge" role="listitem">
            <span class="trust-icon" aria-hidden="true">✓</span>
            <span>Không cần thẻ tín dụng</span>
          </span>
        </div>

        <!-- Enhanced Social Proof Counter with Animation -->
        <div class="social-proof-counter animate-in" style="margin-bottom:28px;" aria-label="Thống kê nền tảng">
          <div class="counter-item">
            <div class="counter-value" data-target="500">0</div>
            <div class="counter-suffix">+</div>
            <div class="counter-label">doanh nghiệp Việt</div>
          </div>
          <div class="counter-divider"></div>
          <div class="counter-item">
            <div class="counter-value" data-target="1">0</div>
            <div class="counter-suffix">M+</div>
            <div class="counter-label">tin nhắn đã xử lý</div>
          </div>
          <div class="counter-divider"></div>
          <div class="counter-item">
            <div class="counter-value" data-target="99">0</div>
            <div class="counter-suffix">.9%</div>
            <div class="counter-label">uptime 12 tháng</div>
          </div>
        </div>

        <!-- Customer Logos Carousel -->
        <div class="customer-logos animate-in" style="margin-bottom:28px;">
          <span class="logos-label">Được tin dùng bởi:</span>
          <div class="logos-grid logos-scroll">
            {customerLogos.map((logo, i) => (
              <div class="logo-item" title={logo.name} aria-label={logo.name}>
                <span class="logo-icon">{logo.icon}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Social Proof Badges with Rating -->
        <div class="proof-badges animate-in" style="margin-bottom:24px;">
          <span class="proof-badge featured" role="img" aria-label="Top 1 AI Việt Nam 2025">
            <span class="badge-glow"></span>
            <span>🏆 Top 1 AI VN 2025</span>
          </span>
          <span class="proof-badge proof-rating" role="img" aria-label="4.9 trên 5 sao từ hơn 500 đánh giá">
            <span class="stars" aria-hidden="true">⭐⭐⭐⭐⭐</span>
            <span>4.9/5 từ 500+ reviews</span>
          </span>
        </div>

        <!-- Trust Indicators -->
        <div class="trust-indicators animate-in">
          <span class="trust-item"><span class="trust-icon" aria-hidden="true">⚡</span>Setup 2 phút</span>
          <span class="trust-item"><span class="trust-icon" aria-hidden="true">💯</span>Free 100% khi bắt đầu</span>
        </div>
      </div>

      <!-- Enhanced Terminal mockup with code highlight -->
      <div class="terminal-wrapper animate-on-scroll" aria-label="Demo terminal OpenClaw">
        <div class="terminal">
          <div class="terminal-header">
            <span class="terminal-dot red" aria-hidden="true"></span>
            <span class="terminal-dot yellow" aria-hidden="true"></span>
            <span class="terminal-dot green" aria-hidden="true"></span>
            <span class="terminal-title">OpenClaw CLI</span>
          </div>
          <div class="terminal-body">
            <div class="terminal-line input">
              <span class="prompt">$</span>
              <span class="command">openclaw</span>
              <span class="args">cook "Trả lời khách hỏi giá bánh mì"</span>
            </div>
            <div class="terminal-line process">
              <span class="arrow">→</span>
              <span class="process-text">Phân tích yêu cầu...</span>
            </div>
            <div class="terminal-line process">
              <span class="arrow">→</span>
              <span class="process-text">Tìm menu trong CRM...</span>
            </div>
            <div class="terminal-line success">
              <span class="check">✓</span>
              <span class="success-text">Đã trả lời:</span>
              <span class="response-text">"Bánh mì thịt nướng 25k, combo 2 cái 45k 🍞"</span>
            </div>
            <div class="terminal-line process">
              <span class="arrow">→</span>
              <span class="process-text">Lưu vào CRM: khách quan tâm combo</span>
            </div>
            <div class="terminal-line stats">
              <span class="bolt">⚡</span>
              <span class="stat-time">1.2s</span>
              <span class="stat-separator">·</span>
              <span class="stat-credits">1 credit used</span>
            </div>
          </div>
        </div>
        <div class="terminal-glow"></div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" style="background:var(--md-surface);">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">Tính năng</div>
        <h2 class="headline">Mọi thứ bạn cần để <span class="gradient-text">bán hàng hiệu quả</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:480px;margin:16px auto 0;">AI làm thay những việc lặp lại, bạn tập trung vào tăng trưởng.</p>
      </div>
      <div class="grid-4">
        {features.map((f, i) => (
          <div class="card-glass animate-on-scroll" style={`animation-delay:${i * 0.1}s`}>
            <div class="icon-container">{f.icon}</div>
            <h3 style="font-size:1.1rem;font-weight:600;margin-bottom:10px;">{f.title}</h3>
            <p style="color:var(--md-on-surface-muted);font-size:0.9rem;line-height:1.65;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="background:var(--md-surface-container);">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">Bắt đầu</div>
        <h2 class="headline">Chỉ <span class="gradient-text">3 bước</span> là xong</h2>
      </div>
      <!-- Connector dots (desktop only) -->
      <div style="display:flex;align-items:center;gap:0;margin-bottom:-20px;padding:0 calc(100%/6 - 20px);position:relative;z-index:1;" class="animate-on-scroll">
        <span class="step-dot"></span><span class="step-line"></span>
        <span class="step-dot"></span><span class="step-line"></span>
        <span class="step-dot"></span>
      </div>
      <div class="grid-3">
        {steps.map((s, i) => (
          <div class="card animate-on-scroll" style={`position:relative;overflow:hidden;animation-delay:${i*0.12}s`}>
            <div style="position:absolute;top:16px;right:20px;font-family:'Be Vietnam Pro',sans-serif;font-size:3.5rem;font-weight:800;color:rgba(0,188,212,0.06);line-height:1;user-select:none;">{s.num}</div>
            <div class="badge" style="margin-bottom:16px;font-size:0.78rem;">{s.time}</div>
            <h3 style="font-size:1.2rem;font-weight:700;margin-bottom:10px;">{s.title}</h3>
            <p style="color:var(--md-on-surface-muted);font-size:0.9rem;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PLATFORM POWER -->
  <section style="background:var(--md-surface);position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(0,188,212,0.04),transparent 70%);pointer-events:none;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">Nền tảng</div>
        <h2 class="headline">Sức mạnh <span class="gradient-text">đằng sau mỗi lệnh</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:500px;margin:16px auto 0;">Hệ sinh thái AI lớn nhất cho vận hành doanh nghiệp — được xây dựng bởi những kỹ sư hàng đầu.</p>
      </div>
      <div style="display:flex;justify-content:center;gap:20px;flex-wrap:wrap;">
        {platformStats.map((s, i) => (
          <div class="card-glass animate-on-scroll" style={`text-align:center;min-width:160px;flex:1;max-width:200px;animation-delay:${i*0.08}s`}>
            <div style="font-family:'Be Vietnam Pro',sans-serif;font-size:2.5rem;font-weight:800;line-height:1;" class="gradient-text">{s.value}</div>
            <div style="font-size:0.9rem;font-weight:600;margin:8px 0 4px;">{s.label}</div>
            <div style="font-size:0.78rem;color:var(--md-on-surface-muted);">{s.desc}</div>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top:36px;">
        <a href="https://docs.agencyos.network/guides/all-commands" class="btn-outline" style="font-size:0.9rem;padding:10px 24px;">Xem toàn bộ →</a>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF - Testimonial Carousel -->
  <section class="testimonials-section">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:48px;">
        <div class="badge" style="margin-bottom:16px;">Testimonials</div>
        <h2 class="headline">Kết quả <span class="gradient-text">thực tế</span> từ founder Việt</h2>
        <p style="color:var(--md-on-surface-muted);max-width:500px;margin:16px auto 0;">
          Những con số biết nói từ doanh nghiệp đã triển khai OpenClaw
        </p>
      </div>

      <!-- Carousel Container -->
      <div class="testimonial-carousel carousel-auto">
        <div class="carousel-track" id="testimonialTrack">
          <!-- Testimonials will be duplicated for seamless loop -->
          {testimonials.map((t, i) => (
            <div class="testimonial-card featured">
              <div class="testimonial-result-badge">{t.result}</div>
              <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
              <p class="testimonial-text">"{t.text}"</p>
              <div class="testimonial-author">
                <div class="testimonial-avatar">{t.avatar}</div>
                <div class="testimonial-info">
                  <div class="testimonial-name">
                    {t.name}
                    {t.verified && (
                      <span class="verified-badge" title="Verified customer">✓</span>
                    )}
                  </div>
                  <div class="testimonial-role">{t.role}</div>
                </div>
              </div>
            </div>
          ))}
          <!-- Duplicate for seamless loop -->
          {testimonials.map((t, i) => (
            <div class="testimonial-card featured">
              <div class="testimonial-result-badge">{t.result}</div>
              <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
              <p class="testimonial-text">"{t.text}"</p>
              <div class="testimonial-author">
                <div class="testimonial-avatar">{t.avatar}</div>
                <div class="testimonial-info">
                  <div class="testimonial-name">
                    {t.name}
                    {t.verified && (
                      <span class="verified-badge" title="Verified customer">✓</span>
                    )}
                  </div>
                  <div class="testimonial-role">{t.role}</div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Carousel Controls -->
        <div class="carousel-controls">
          <button class="carousel-btn prev" id="carouselPrev" aria-label="Previous testimonial">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <div class="carousel-dots" id="carouselDots"></div>
          <button class="carousel-btn next" id="carouselNext" aria-label="Next testimonial">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="text-center" style="margin-top:48px;">
        <a href="https://app.agencyos.network/signup" class="btn-primary">
          Nhận kết quả tương tự →
        </a>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" style="background:var(--md-surface);">
    <div class="container">
      <div class="text-center animate-on-scroll" style="margin-bottom:0;">
        <div class="badge" style="margin-bottom:16px;">Bảng giá</div>
        <h2 class="headline">Minh bạch, <span class="gradient-text">không phí ẩn</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:400px;margin:16px auto 32px;">14 ngày dùng thử miễn phí. Huỷ bất cứ lúc nào.</p>
        <!-- Toggle (visual only) -->
        <div style="display:flex;justify-content:center;margin-bottom:48px;">
          <div class="pricing-toggle">
            <span class="toggle-opt active">Hàng tháng</span>
            <span class="toggle-opt">Hàng năm <span style="font-size:0.7rem;color:#4ade80;margin-left:4px;">-20%</span></span>
          </div>
        </div>
      </div>
      <div class="grid-4" style="align-items:start;">
        {plans.map((p, i) => (
          <div class={`animate-on-scroll${p.featured ? ' pricing-featured' : ' card'}`} style={`animation-delay:${i*0.1}s;border-radius:var(--md-radius);padding:28px;position:relative;${!p.featured ? 'background:var(--md-surface-container);border:1px solid var(--md-outline);' : ''}`}>
            {p.tag && (
              <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#00BCD4,#7C4DFF);color:#fff;font-size:0.72rem;font-weight:700;padding:4px 14px;border-radius:100px;white-space:nowrap;">{p.tag}</div>
            )}
            <div style="margin-bottom:20px;">
              <div style="font-size:0.85rem;color:var(--md-on-surface-muted);margin-bottom:6px;">{p.name}</div>
              <div style="display:flex;align-items:baseline;gap:2px;">
                <span style="font-family:'Be Vietnam Pro',sans-serif;font-size:2.2rem;font-weight:800;">{p.price}</span>
                <span style="font-size:0.85rem;color:var(--md-on-surface-muted);">{p.period}</span>
              </div>
            </div>
            <ul style="list-style:none;margin-bottom:24px;display:flex;flex-direction:column;gap:10px;">
              {p.features.map(feat => (
                <li style="font-size:0.875rem;color:var(--md-on-surface-muted);display:flex;gap:8px;align-items:flex-start;">
                  <span style="color:#00BCD4;flex-shrink:0;font-weight:600;">✓</span>{feat}
                </li>
              ))}
            </ul>
            <a href={p.href} class={p.featured ? 'btn-primary' : 'btn-outline'} style="display:flex;justify-content:center;width:100%;text-align:center;">{p.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" style="background:var(--md-surface-container);">
    <div class="container" style="max-width:720px;">
      <div class="text-center animate-on-scroll" style="margin-bottom:56px;">
        <div class="badge" style="margin-bottom:16px;">FAQ</div>
        <h2 class="headline">Câu hỏi <span class="gradient-text">thường gặp</span></h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px;">
        {faqs.map((f, i) => (
          <details class="card animate-on-scroll" style={`animation-delay:${i*0.08}s;padding:0;`} open={i===0}>
            <summary style="padding:20px 24px;cursor:pointer;font-weight:600;font-size:0.975rem;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:12px;">
              {f.q}
              <svg class="chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--md-primary);flex-shrink:0;transition:transform 0.25s ease;"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </summary>
            <div style="padding:0 24px 20px;color:var(--md-on-surface-muted);font-size:0.9rem;line-height:1.7;border-top:1px solid var(--md-outline);">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section style="background:var(--md-surface);">
    <div class="container">
      <div class="animate-on-scroll" style="background:linear-gradient(135deg,rgba(0,188,212,0.08),rgba(124,77,255,0.1));border:1px solid rgba(0,188,212,0.2);border-radius:var(--md-radius);padding:72px 40px;text-align:center;position:relative;overflow:hidden;">
        <div style="position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(124,77,255,0.15),transparent 70%);pointer-events:none;"></div>
        <div style="position:absolute;bottom:-40px;left:-40px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(0,188,212,0.1),transparent 70%);pointer-events:none;"></div>
        <h2 class="headline" style="margin-bottom:16px;position:relative;">Sẵn sàng để AI <span class="gradient-text">làm việc cho bạn?</span></h2>
        <p style="color:var(--md-on-surface-muted);max-width:440px;margin:0 auto 40px;position:relative;">
          Tham gia cùng 500+ doanh nghiệp đang tiết kiệm 20+ giờ/tuần với OpenClaw.
        </p>
        <a href="https://app.agencyos.network/signup" class="btn-primary btn-pulse" style="font-size:1.05rem;padding:16px 44px;position:relative;">Bắt đầu miễn phí ngay →</a>
      </div>
    </div>
  </section>

  <style>
    details[open] summary svg { transform: rotate(180deg); }
  </style>

</BaseLayout>
