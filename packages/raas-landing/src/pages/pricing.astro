---
import BaseLayout from '../layouts/base-layout.astro';

const rows = [
  { feature: 'MCU / tháng',           free: '5',           starter: '200',          pro: '1.000',                enterprise: '5.000' },
  { feature: 'AI Receptionist',       free: '—',           starter: '24/7',         pro: '24/7 Multi-channel',  enterprise: 'Dedicated AI' },
  { feature: 'Content Creator',       free: '—',           starter: '7 ngày/tuần',  pro: '7 ngày + lịch',       enterprise: 'Toàn quyền tùy chỉnh' },
  { feature: 'CRM',                   free: '—',           starter: 'Không giới hạn',pro: 'Không giới hạn + API',enterprise: 'Enterprise CRM' },
  { feature: 'Báo cáo',               free: '—',           starter: 'Tuần',         pro: 'Thời gian thực',      enterprise: 'Tuỳ chỉnh' },
  { feature: 'Hỗ trợ',                free: '—',           starter: 'Chat ưu tiên', pro: 'Chat + Phone',        enterprise: 'Dedicated manager' },
  { feature: 'API access',            free: '—',           starter: '—',            pro: '✓',                   enterprise: '✓' },
  { feature: 'White-label',           free: '—',           starter: '—',            pro: '—',                   enterprise: '✓' },
  { feature: 'SLA',                   free: '—',           starter: '—',            pro: '99.9%',               enterprise: '99.99%' },
  { feature: 'Onboarding 1-1',        free: '—',           starter: '—',            pro: '—',                   enterprise: '✓' },
];

const plans = [
  { name: 'Free',       price: '$0',   href: 'https://app.agencyos.network/signup',              featured: false },
  { name: 'Starter',   price: '$49/mo', href: 'https://app.agencyos.network/signup?plan=starter', featured: false },
  { name: 'Pro',        price: '$199/mo',href: 'https://app.agencyos.network/signup?plan=pro',    featured: true  },
  { name: 'Enterprise', price: '$499/mo',href: 'mailto:hello@agencyos.network',                  featured: false },
];

// Product JSON-LD for pricing plans
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "OpenClaw",
  "description": "Nền tảng AI tự động hóa doanh nghiệp",
  "brand": {
    "@type": "Organization",
    "name": "OpenClaw",
    "url": "https://agencyos.network"
  },
  "offers": plans.map(plan => ({
    "@type": "Offer",
    "name": `${plan.name} Plan`,
    "price": plan.name === 'Free' ? '0' : plan.name === 'Starter' ? '49' : plan.name === 'Pro' ? '199' : '499',
    "priceCurrency": "USD",
    "priceValidUntil": new Date(new Date().getFullYear() + 1, 0, 1).toISOString().split('T')[0],
    "availability": "https://schema.org/InStock",
    "url": plan.href,
    "category": "SoftwareApplication",
    "description": plan.name === 'Free' ? 'Miễn phí mãi mãi với 50 credits/tháng' :
                  plan.name === 'Starter' ? '500 credits/tháng, AI Receptionist 24/7' :
                  plan.name === 'Pro' ? '2.000 credits/tháng, multi-channel, API access' :
                  'Credits không giới hạn, dedicated AI model, white-label'
  }))
};

// BreadcrumbList JSON-LD for pricing page
const pricingBreadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://agencyos.network"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Pricing",
      "item": "https://agencyos.network/pricing"
    }
  ]
};
---

<BaseLayout title="Bảng giá — OpenClaw" description="So sánh chi tiết các gói OpenClaw. Miễn phí đến Enterprise." lang="vi">

  <!-- Header -->
  <section style="background:linear-gradient(135deg,#0a0f1a,#1a1040 60%,#0a2030);padding:96px 0 64px;text-align:center;">
    <div class="container">
      <div class="badge animate-in" style="margin-bottom:20px;">Bảng giá</div>
      <h1 class="display animate-in" style="margin-bottom:16px;">
        So sánh <span class="gradient-text">tất cả gói</span>
      </h1>
      <p style="color:var(--md-on-surface-muted);max-width:440px;margin:0 auto 32px;" class="animate-in">
        Minh bạch 100%. Không phí ẩn. Huỷ bất cứ lúc nào. 14 ngày thử miễn phí.
      </p>
      <a href="https://app.agencyos.network/signup" class="btn-primary animate-in">Bắt đầu miễn phí →</a>
    </div>
  </section>

  <!-- Comparison table -->
  <section style="background:var(--md-surface);">
    <div class="container" style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;min-width:640px;">
        <thead>
          <tr>
            <th style="text-align:left;padding:16px;color:var(--md-on-surface-muted);font-size:0.85rem;font-weight:500;border-bottom:1px solid var(--md-outline);">Tính năng</th>
            {plans.map(p => (
              <th style={`text-align:center;padding:16px;border-bottom:1px solid var(--md-outline);${p.featured ? 'background:rgba(0,188,212,0.05);' : ''}`}>
                <div style={`font-size:0.95rem;font-weight:700;margin-bottom:4px;${p.featured ? 'color:#00BCD4;' : ''}`}>{p.name}</div>
                <div style="font-size:0.82rem;color:var(--md-on-surface-muted);">{p.price}</div>
                {p.featured && <div style="margin-top:6px;display:inline-block;background:linear-gradient(135deg,#00BCD4,#7C4DFF);color:#fff;font-size:0.7rem;font-weight:700;padding:3px 10px;border-radius:100px;">Phổ biến nhất</div>}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr style={i % 2 === 0 ? 'background:rgba(255,255,255,0.015);' : ''}>
              <td style="padding:14px 16px;font-size:0.875rem;color:var(--md-on-surface-muted);border-bottom:1px solid rgba(255,255,255,0.04);">{row.feature}</td>
              {[row.free, row.starter, row.pro, row.enterprise].map((val, ci) => (
                <td style={`text-align:center;padding:14px 16px;font-size:0.875rem;border-bottom:1px solid rgba(255,255,255,0.04);${ci===2 ? 'background:rgba(0,188,212,0.04);' : ''}color:${val==='—' ? 'var(--md-on-surface-muted)' : 'var(--md-on-surface)'};`}>
                  {val === '✓' ? <span style="color:#00BCD4;font-size:1.1rem;font-weight:700;">✓</span> : val}
                </td>
              ))}
            </tr>
          ))}
          <!-- CTA row -->
          <tr>
            <td style="padding:24px 16px;"></td>
            {plans.map(p => (
              <td style={`text-align:center;padding:24px 16px;${p.featured ? 'background:rgba(0,188,212,0.04);' : ''}`}>
                <a href={p.href} class={p.featured ? 'btn-primary' : 'btn-outline'} style="font-size:0.875rem;padding:10px 20px;justify-content:center;">
                  {p.name === 'Enterprise' ? 'Liên hệ' : 'Chọn gói'}
                </a>
              </td>
            ))}
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Contact -->
  <section style="background:var(--md-surface-container);">
    <div class="container" style="max-width:600px;text-align:center;">
      <h2 class="headline animate-on-scroll" style="margin-bottom:16px;">Còn thắc mắc?</h2>
      <p style="color:var(--md-on-surface-muted);margin-bottom:32px;" class="animate-on-scroll">
        Đội ngũ hỗ trợ sẵn sàng tư vấn miễn phí trong vòng 24 giờ.
      </p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;" class="animate-on-scroll">
        <a href="mailto:hello@agencyos.network" class="btn-primary">Gửi email cho chúng tôi</a>
        <a href="/" class="btn-outline">← Về trang chủ</a>
      </div>
    </div>
  </section>

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify([productSchema, pricingBreadcrumbSchema])} />

</BaseLayout>
