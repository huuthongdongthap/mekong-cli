{
  "name": "@mekong/raas-sdk",
  "version": "1.0.0",
  "description": "Typed TypeScript SDK for the Mekong RaaS Gateway API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mekong",
    "raas",
    "sdk",
    "ai",
    "missions",
    "agencyos"
  ],
  "author": "Mekong CLI",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
