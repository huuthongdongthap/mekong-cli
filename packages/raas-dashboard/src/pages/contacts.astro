---
import DashboardLayout from '../layouts/dashboard-layout.astro';
---
<DashboardLayout title="Khách hàng" activePage="/contacts">
  <h2 style="font-size:18px;margin-bottom:20px">Khách hàng</h2>

  <div class="card">
    <div style="margin-bottom:16px;display:flex;gap:10px">
      <input id="search-input" placeholder="Tìm theo tên hoặc số điện thoại..." style="max-width:320px" />
    </div>
    <div style="overflow-x:auto">
      <table>
        <thead>
          <tr>
            <th>Tên</th>
            <th>Nền tảng</th>
            <th>Lượt ghé thăm</th>
            <th>Liên hệ gần nhất</th>
            <th>Trạng thái</th>
          </tr>
        </thead>
        <tbody id="contacts-body">
          <tr><td colspan="5" style="color:var(--text2);text-align:center;padding:32px">Đang tải...</td></tr>
        </tbody>
      </table>
    </div>
    <div id="contacts-pagination" style="margin-top:12px;color:var(--text2);font-size:12px"></div>
  </div>
</DashboardLayout>

<script>
  const API = 'https://mekong-engine.agencyos-openclaw.workers.dev';
  if (!localStorage.getItem('mk_api_key')) window.location.replace('/signup');

  const key = () => localStorage.getItem('mk_api_key');
  const h = () => ({ Authorization: 'Bearer ' + key() });

  let allContacts = [];

  const PLATFORM_ICON = { zalo: '💙', facebook: '💙', zalo_oa: '💙', instagram: '📸' };

  function renderTable(contacts) {
    const tbody = document.getElementById('contacts-body');
    if (!contacts.length) {
      tbody.innerHTML = '<tr><td colspan="5" style="color:var(--text2);text-align:center;padding:32px">Chưa có khách hàng nào.</td></tr>';
      return;
    }
    tbody.innerHTML = contacts.map(c => `
      <tr>
        <td>
          <div style="font-weight:500">${c.name || 'Ẩn danh'}</div>
          ${c.phone ? `<div style="color:var(--text2);font-size:11px">${c.phone}</div>` : ''}
        </td>
        <td>${PLATFORM_ICON[c.platform] || '💬'} ${c.platform || '—'}</td>
        <td>${c.visit_count ?? '—'}</td>
        <td style="color:var(--text2);font-size:12px">${c.last_contact ? new Date(c.last_contact).toLocaleDateString('vi-VN') : '—'}</td>
        <td><span class="badge ${c.is_active ? 'badge-green' : 'badge-gray'}">${c.is_active ? 'Hoạt động' : 'Không hoạt động'}</span></td>
      </tr>`).join('');
  }

  async function load() {
    try {
      const data = await fetch(API + '/v1/crm/contacts', { headers: h() }).then(r => r.json());
      allContacts = Array.isArray(data) ? data : (data.contacts || []);
      renderTable(allContacts);
      const pg = document.getElementById('contacts-pagination');
      pg.textContent = `Hiển thị ${allContacts.length} khách hàng`;
    } catch {
      document.getElementById('contacts-body').innerHTML =
        '<tr><td colspan="5" style="color:var(--danger);text-align:center;padding:16px">Không thể tải danh sách.</td></tr>';
    }
  }

  document.getElementById('search-input').addEventListener('input', e => {
    const q = e.target.value.toLowerCase();
    renderTable(allContacts.filter(c =>
      (c.name || '').toLowerCase().includes(q) || (c.phone || '').includes(q)
    ));
  });

  load();
</script>
