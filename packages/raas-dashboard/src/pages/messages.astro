---
import DashboardLayout from '../layouts/dashboard-layout.astro';
---
<DashboardLayout title="Tin nhắn" activePage="/messages">
  <h2 style="font-size:18px;margin-bottom:20px">Tin nhắn</h2>

  <div style="display:grid;grid-template-columns:280px 1fr;gap:16px;height:calc(100vh - 160px)">
    <!-- Thread list -->
    <div class="card" style="overflow-y:auto;padding:0">
      <div style="padding:12px 16px;border-bottom:1px solid var(--border)">
        <input id="search-threads" placeholder="Tìm khách hàng..." style="font-size:12px" />
      </div>
      <div id="thread-list">
        <div style="color:var(--text2);font-size:13px;text-align:center;padding:32px">Đang tải...</div>
      </div>
    </div>

    <!-- Message pane -->
    <div class="card" style="display:flex;flex-direction:column;padding:0">
      <div id="msg-header" style="padding:14px 16px;border-bottom:1px solid var(--border);font-weight:600;font-size:14px">
        Chọn cuộc trò chuyện
      </div>
      <div id="msg-body" style="flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px">
        <p style="color:var(--text2);font-size:13px;text-align:center;margin-top:40px">Chọn khách hàng ở bên trái để xem tin nhắn.</p>
      </div>
      <div id="msg-footer" style="padding:12px 16px;border-top:1px solid var(--border);display:none;gap:8px">
        <input id="reply-input" placeholder="Nhập tin nhắn..." style="flex:1" />
        <button class="btn btn-primary btn-sm" id="btn-send">Gửi</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  const API = 'https://mekong-engine.agencyos-openclaw.workers.dev';
  if (!localStorage.getItem('mk_api_key')) window.location.replace('/signup');

  const key = () => localStorage.getItem('mk_api_key');
  const h = () => ({ 'Content-Type': 'application/json', Authorization: 'Bearer ' + key() });

  let threads = [];
  let activeThreadId = null;

  function renderThreads(list) {
    const el = document.getElementById('thread-list');
    if (!list.length) { el.innerHTML = '<div style="color:var(--text2);font-size:13px;text-align:center;padding:32px">Chưa có tin nhắn.</div>'; return; }
    el.innerHTML = list.map(t => `
      <div class="thread-item" data-id="${t.id}" style="padding:12px 16px;border-bottom:1px solid var(--border);cursor:pointer;${activeThreadId===t.id?'background:var(--bg3)':''}">
        <div style="display:flex;justify-content:space-between;margin-bottom:2px">
          <span style="font-weight:500;font-size:13px">${t.contact_name || 'Ẩn danh'}</span>
          <span style="color:var(--text2);font-size:11px">${t.last_time ? new Date(t.last_time).toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'}) : ''}</span>
        </div>
        <div style="color:var(--text2);font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${t.last_message || ''}</div>
        ${t.unread ? `<span class="badge badge-green" style="margin-top:4px">${t.unread} mới</span>` : ''}
      </div>`).join('');
    el.querySelectorAll('.thread-item').forEach(item => item.addEventListener('click', () => loadMessages(item.dataset.id)));
  }

  async function loadMessages(threadId) {
    activeThreadId = threadId;
    const thread = threads.find(t => t.id === threadId);
    document.getElementById('msg-header').textContent = thread?.contact_name || 'Cuộc trò chuyện';
    document.getElementById('msg-footer').style.display = 'flex';
    document.getElementById('msg-body').innerHTML = '<p style="color:var(--text2);font-size:13px;text-align:center">Đang tải...</p>';
    renderThreads(threads);
    try {
      const data = await fetch(API + '/v1/messages/' + threadId, { headers: h() }).then(r => r.json());
      const msgs = Array.isArray(data) ? data : (data.messages || []);
      document.getElementById('msg-body').innerHTML = msgs.length
        ? msgs.map(m => `
          <div style="max-width:75%;align-self:${m.role==='bot'?'flex-start':'flex-end'}">
            <div style="background:${m.role==='bot'?'var(--bg3)':'var(--accent)'};padding:8px 12px;border-radius:12px;font-size:13px">${m.content||''}</div>
            <div style="color:var(--text2);font-size:10px;margin-top:2px;${m.role==='bot'?'':'text-align:right'}">${m.role==='bot'?'🤖 AI':'👤'} · ${m.created_at?new Date(m.created_at).toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'}):''}</div>
          </div>`).join('')
        : '<p style="color:var(--text2);font-size:13px;text-align:center">Chưa có tin nhắn.</p>';
    } catch {
      document.getElementById('msg-body').innerHTML = '<p style="color:var(--danger);font-size:13px;text-align:center">Không thể tải tin nhắn.</p>';
    }
  }

  document.getElementById('btn-send').addEventListener('click', async () => {
    const input = document.getElementById('reply-input');
    const text = input.value.trim();
    if (!text || !activeThreadId) return;
    input.value = '';
    await fetch(API + '/v1/messages/' + activeThreadId + '/reply', { method: 'POST', headers: h(), body: JSON.stringify({ content: text }) }).catch(() => {});
    loadMessages(activeThreadId);
  });

  document.getElementById('search-threads').addEventListener('input', e => {
    const q = e.target.value.toLowerCase();
    renderThreads(threads.filter(t => (t.contact_name || '').toLowerCase().includes(q)));
  });

  async function load() {
    try {
      const data = await fetch(API + '/v1/messages', { headers: h() }).then(r => r.json());
      threads = Array.isArray(data) ? data : (data.threads || []);
      renderThreads(threads);
    } catch {
      document.getElementById('thread-list').innerHTML = '<div style="color:var(--danger);font-size:13px;text-align:center;padding:16px">Lỗi tải dữ liệu.</div>';
    }
  }
  load();
</script>
