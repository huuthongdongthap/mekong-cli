---
import DashboardLayout from '../layouts/dashboard-layout.astro';
---
<DashboardLayout title="Sử dụng" activePage="/usage">
  <div class="page-header">
    <div>
      <h1>Phân tích sử dụng</h1>
      <p class="subtitle">Theo dõi MCU consumption và command usage</p>
    </div>
    <div class="header-actions">
      <select id="period-select" class="period-select">
        <option value="7">7 ngày</option>
        <option value="30" selected>30 ngày</option>
        <option value="90">90 ngày</option>
      </select>
      <button class="btn btn-secondary" id="export-btn">Xuất CSV</button>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="summary-grid">
    <div class="summary-card">
      <div class="summary-label">Tổng MCU đã dùng</div>
      <div class="summary-value" id="total-mcu">—</div>
      <div class="summary-sub" id="avg-daily">Trung bình: —/ngày</div>
    </div>
    <div class="summary-card">
      <div class="summary-label">Commands đã chạy</div>
      <div class="summary-value" id="total-commands">—</div>
      <div class="summary-sub" id="avg-cost">MCU/command: —</div>
    </div>
    <div class="summary-card">
      <div class="summary-label">Chi phí ước tính</div>
      <div class="summary-value" id="estimated-cost">—</div>
      <div class="summary-sub">$0.10/100 MCU</div>
    </div>
    <div class="summary-card">
      <div class="summary-label">Peak usage</div>
      <div class="summary-value" id="peak-day">—</div>
      <div class="summary-sub" id="peak-date">Ngày cao nhất</div>
    </div>
  </div>

  <!-- Main Chart -->
  <div class="card chart-card-large">
    <div class="chart-header">
      <h3>Xu hướng sử dụng MCU</h3>
      <div class="chart-controls">
        <label class="toggle">
          <input type="checkbox" id="show-cumulative" />
          <span class="toggle-label">Hiển thị tích lũy</span>
        </label>
      </div>
    </div>
    <canvas id="usage-trend-chart"></canvas>
  </div>

  <!-- Breakdown Section -->
  <div class="breakdown-row">
    <div class="card">
      <div class="chart-header">
        <h3>Theo loại command</h3>
      </div>
      <canvas id="command-type-chart"></canvas>
      <div id="command-type-list" class="legend-list"></div>
    </div>
    <div class="card">
      <div class="chart-header">
        <h3>Theo giờ trong ngày</h3>
      </div>
      <canvas id="hourly-chart"></canvas>
      <p class="chart-note">Múi giờ: GMT+7</p>
    </div>
  </div>

  <!-- Recent Usage Table -->
  <div class="card">
    <div class="table-header">
      <h3>Lịch sử sử dụng</h3>
      <div class="table-filters">
        <input type="text" id="search-input" placeholder="Tìm command..." class="search-input" />
      </div>
    </div>
    <div class="table-container">
      <table id="usage-table">
        <thead>
          <tr>
            <th>Thời gian</th>
            <th>Command</th>
            <th>MCU</th>
            <th>Status</th>
            <th>Chi tiết</th>
          </tr>
        </thead>
        <tbody id="usage-table-body">
          <tr class="loading-row">
            <td colspan="5">Đang tải dữ liệu...</td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="table-pagination">
      <button class="btn btn-sm btn-secondary" id="prev-page" disabled>← Trước</button>
      <span id="page-info">Trang 1/1</span>
      <button class="btn btn-sm btn-secondary" id="next-page" disabled>Sau →</button>
    </div>
  </div>
</DashboardLayout>

<script>
  const API = 'https://mekong-engine.agencyos.network';
  const apiKey = localStorage.getItem('mk_api_key');
  if (!apiKey) window.location.replace('/login');

  const headers = { 'Content-Type': 'application/json', Authorization: 'Bearer ' + apiKey };

  let currentPeriod = 30;
  let usageData = { daily: [], by_command: {}, by_hour: {}, logs: [] };
  let trendChart = null;
  let typeChart = null;
  let hourlyChart = null;
  let currentPage = 1;
  const pageSize = 20;

  async function load() {
    await loadUsageData(currentPeriod);
    renderAllCharts();
    renderTable();
  }

  async function loadUsageData(days) {
    try {
      const res = await fetch(API + `/v1/usage/stats?days=${days}`, { headers });
      usageData = await res.json().catch(() => ({ daily: [], by_command: {}, by_hour: {}, logs: [] }));
    } catch {
      usageData = { daily: [], by_command: {}, by_hour: {}, logs: [] };
    }
  }

  function renderAllCharts() {
    renderTrendChart();
    renderCommandTypeChart();
    renderHourlyChart();
    renderSummary();
  }

  function renderSummary() {
    const daily = usageData.daily || [];
    const totalMcu = daily.reduce((sum, d) => sum + (d.consumed || 0), 0);
    const totalCommands = daily.reduce((sum, d) => sum + (d.commands || 0), 0);
    const avgDaily = daily.length > 0 ? Math.round(totalMcu / daily.length) : 0;
    const avgCost = totalCommands > 0 ? (totalMcu / totalCommands).toFixed(1) : 0;
    const estimatedCost = (totalMcu / 100 * 0.10).toFixed(2);

    // Find peak day
    let peakMcu = 0;
    let peakDate = '';
    daily.forEach(d => {
      if ((d.consumed || 0) > peakMcu) {
        peakMcu = d.consumed;
        peakDate = d.date || d.day || '';
      }
    });

    document.getElementById('total-mcu').textContent = totalMcu.toLocaleString();
    document.getElementById('avg-daily').textContent = `Trung bình: ${avgDaily.toLocaleString()}/ngày`;
    document.getElementById('total-commands').textContent = totalCommands.toLocaleString();
    document.getElementById('avg-cost').textContent = `MCU/command: ${avgCost}`;
    document.getElementById('estimated-cost').textContent = `$${estimatedCost}`;
    document.getElementById('peak-day').textContent = peakMcu.toLocaleString();
    document.getElementById('peak-date').textContent = peakDate || 'N/A';
  }

  function renderTrendChart() {
    const ctx = document.getElementById('usage-trend-chart').getContext('2d');
    if (trendChart) trendChart.destroy();

    const daily = usageData.daily || [];
    const labels = daily.map(d => d.date || d.day || '');
    const consumed = daily.map(d => d.consumed || 0);
    const cumulative = consumed.reduce((acc, val) => {
      acc.push((acc[acc.length - 1] || 0) + val);
      return acc;
    }, []);

    const showCumulative = document.getElementById('show-cumulative')?.checked || false;

    trendChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'MCU tiêu thụ',
            data: consumed,
            borderColor: '#6366f1',
            backgroundColor: 'rgba(99, 102, 241, 0.1)',
            fill: true,
            tension: 0.4,
            pointRadius: 3,
            pointHoverRadius: 5
          },
          ...(showCumulative ? [{
            label: 'Tích lũy',
            data: cumulative,
            borderColor: '#10b981',
            backgroundColor: 'transparent',
            borderDash: [5, 5],
            tension: 0.4,
            pointRadius: 0
          }] : [])
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: true, labels: { color: '#a3b0c2' } }
        },
        scales: {
          x: { ticks: { color: '#a3b0c2' }, grid: { color: '#2e3248' } },
          y: { ticks: { color: '#a3b0c2' }, grid: { color: '#2e3248' } }
        }
      }
    });
  }

  function renderCommandTypeChart() {
    const ctx = document.getElementById('command-type-chart').getContext('2d');
    if (typeChart) typeChart.destroy();

    const byCommand = usageData.by_command || {};
    const entries = Object.entries(byCommand).sort((a, b) => b[1] - a[1]).slice(0, 10);
    const labels = entries.map(([k]) => k.replace(/_/g, ' '));
    const values = entries.map(([, v]) => v);

    typeChart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          label: 'Commands',
          data: values,
          backgroundColor: '#6366f1',
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { ticks: { color: '#a3b0c2', font: { size: 10 } }, grid: { display: false } },
          y: { ticks: { color: '#a3b0c2' }, grid: { color: '#2e3248' } }
        }
      }
    });

    // Legend list
    const total = values.reduce((a, b) => a + b, 0);
    document.getElementById('command-type-list').innerHTML = entries.map(([k, v], i) => `
      <div class="legend-item">
        <span class="legend-color" style="background: ${getBarColor(i)}"></span>
        <span class="legend-label">${k.replace(/_/g, ' ')}</span>
        <span class="legend-value">${v} (${((v/total)*100).toFixed(1)}%)</span>
      </div>
    `).join('');
  }

  function getBarColor(index) {
    const colors = ['#6366f1', '#10b981', '#f59e0b', '#8b5cf6', '#ef4444', '#06b6d4', '#ec4899', '#84cc16', '#f97316', '#14b8a6'];
    return colors[index % colors.length];
  }

  function renderHourlyChart() {
    const ctx = document.getElementById('hourly-chart').getContext('2d');
    if (hourlyChart) hourlyChart.destroy();

    const byHour = usageData.by_hour || {};
    const labels = Array.from({ length: 24 }, (_, i) => `${i.toString().padStart(2, '0')}:00`);
    const values = labels.map((_, i) => byHour[i] || 0);

    hourlyChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label: 'MCU',
          data: values,
          borderColor: '#06b6d4',
          backgroundColor: 'rgba(6, 182, 212, 0.1)',
          fill: true,
          tension: 0.3,
          pointRadius: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { ticks: { color: '#a3b0c2' }, grid: { color: '#2e3248' } },
          y: { ticks: { color: '#a3b0c2' }, grid: { color: '#2e3248' } }
        }
      }
    });
  }

  function renderTable() {
    const logs = usageData.logs || [];
    const start = (currentPage - 1) * pageSize;
    const end = start + pageSize;
    const pageLogs = logs.slice(start, end);

    const tbody = document.getElementById('usage-table-body');
    if (pageLogs.length === 0) {
      tbody.innerHTML = '<tr class="empty-row"><td colspan="5">Không có dữ liệu</td></tr>';
      return;
    }

    tbody.innerHTML = pageLogs.map(log => `
      <tr>
        <td>${formatDate(log.created_at)}</td>
        <td><code class="command-name">${log.command}</code></td>
        <td>${log.mcu_consumed?.toLocaleString() || 0}</td>
        <td><span class="status-badge ${log.status === 'success' ? 'success' : 'error'}">${log.status || 'success'}</span></td>
        <td><button class="btn btn-sm btn-secondary">Chi tiết</button></td>
      </tr>
    `).join('');

    // Update pagination
    const totalPages = Math.max(1, Math.ceil(logs.length / pageSize));
    document.getElementById('page-info').textContent = `Trang ${currentPage}/${totalPages}`;
    document.getElementById('prev-page').disabled = currentPage <= 1;
    document.getElementById('next-page').disabled = currentPage >= totalPages;
  }

  function formatDate(dateStr) {
    if (!dateStr) return 'N/A';
    const date = new Date(dateStr);
    return date.toLocaleString('vi-VN', {
      day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit'
    });
  }

  // Event listeners
  document.getElementById('period-select')?.addEventListener('change', async (e) => {
    currentPeriod = parseInt(e.target.value);
    await loadUsageData(currentPeriod);
    renderAllCharts();
    renderTable();
  });

  document.getElementById('show-cumulative')?.addEventListener('change', () => {
    renderTrendChart();
  });

  document.getElementById('prev-page')?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderTable();
    }
  });

  document.getElementById('next-page')?.addEventListener('click', () => {
    const logs = usageData.logs || [];
    const totalPages = Math.ceil(logs.length / pageSize);
    if (currentPage < totalPages) {
      currentPage++;
      renderTable();
    }
  });

  document.getElementById('export-btn')?.addEventListener('click', () => {
    const logs = usageData.logs || [];
    const csv = [
      ['Thời gian', 'Command', 'MCU', 'Status'],
      ...logs.map(l => [l.created_at, l.command, l.mcu_consumed, l.status])
    ].map(row => row.join(',')).join('\n');

    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `usage-report-${new Date().toISOString().split('T')[0]}.csv`;
    a.click();
  });

  // Init
  load();
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
  }

  .page-header h1 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 4px 0;
  }

  .subtitle {
    color: var(--text2);
    font-size: 14px;
    margin: 0;
  }

  .header-actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .period-select {
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 8px 16px;
    border-radius: var(--radius);
    font-size: 13px;
  }

  /* Summary Grid */
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .summary-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
  }

  .summary-label {
    color: var(--text2);
    font-size: 12px;
    margin-bottom: 8px;
  }

  .summary-value {
    font-size: 28px;
    font-weight: 700;
  }

  .summary-sub {
    color: var(--text2);
    font-size: 11px;
    margin-top: 6px;
  }

  /* Chart Cards */
  .chart-card-large {
    min-height: 350px;
    margin-bottom: 24px;
  }

  .chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .chart-header h3 {
    font-size: 14px;
    font-weight: 600;
    margin: 0;
  }

  .chart-controls {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text2);
    cursor: pointer;
  }

  .toggle input {
    width: 16px;
    height: 16px;
    accent-color: var(--accent);
  }

  .chart-note {
    color: var(--text2);
    font-size: 12px;
    text-align: center;
    margin-top: 12px;
  }

  /* Breakdown Row */
  .breakdown-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  .legend-list {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 250px;
    overflow-y: auto;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
  }

  .legend-color {
    width: 12px;
    height: 12px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .legend-label {
    flex: 1;
    color: var(--text);
  }

  .legend-value {
    color: var(--text2);
  }

  /* Table */
  .table-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .table-header h3 {
    font-size: 14px;
    font-weight: 600;
    margin: 0;
  }

  .search-input {
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 8px 12px;
    border-radius: var(--radius);
    font-size: 13px;
    width: 200px;
  }

  .table-container {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th, td {
    padding: 12px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
  }

  th {
    color: var(--text2);
    font-weight: 500;
    background: var(--bg3);
  }

  .command-name {
    background: var(--bg3);
    padding: 4px 8px;
    border-radius: 4px;
    font-family: monospace;
    font-size: 12px;
  }

  .status-badge {
    display: inline-block;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 500;
  }

  .status-badge.success {
    background: rgba(16, 185, 129, 0.2);
    color: var(--success);
  }

  .status-badge.error {
    background: rgba(239, 68, 68, 0.2);
    color: var(--danger);
  }

  .loading-row, .empty-row {
    text-align: center;
    color: var(--text2);
  }

  .table-pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px;
    border-top: 1px solid var(--border);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-header {
      flex-direction: column;
      gap: 16px;
    }

    .breakdown-row {
      grid-template-columns: 1fr;
    }
  }
</style>
