---
import DashboardLayout from '../layouts/dashboard-layout.astro';
---
<DashboardLayout title="Missions" activePage="/missions">
  <div class="page-header">
    <div>
      <h1>Missions</h1>
      <p class="subtitle">Submit goals — OpenClaw executes them autonomously</p>
    </div>
    <div class="header-actions">
      <button class="btn btn-primary" id="btn-new-mission">+ New Mission</button>
    </div>
  </div>

  <!-- New Mission Form -->
  <div class="card mission-form-card" id="new-mission-form">
    <h3>New Mission</h3>
    <p class="form-hint">Describe your business goal. OpenClaw will plan, execute, and verify it.</p>
    <div class="form-group">
      <textarea
        id="mission-goal"
        class="mission-textarea"
        placeholder="e.g. Find 10 potential leads in the SaaS industry and draft outreach emails..."
        rows="4"
      ></textarea>
    </div>
    <div class="form-footer">
      <div class="cost-estimate">
        <span class="cost-icon">⚡</span>
        <span>Estimated cost: <strong id="cost-estimate">1–5 MCU</strong></span>
      </div>
      <div class="form-actions">
        <button class="btn btn-secondary" id="btn-cancel-mission">Cancel</button>
        <button class="btn btn-primary" id="btn-submit-mission">
          <span id="submit-label">Submit Mission</span>
          <span id="submit-spinner" style="display:none;">Submitting...</span>
        </button>
      </div>
    </div>
    <div id="form-error" class="form-error" style="display:none;"></div>
  </div>

  <!-- Mission History -->
  <div class="card">
    <div class="section-header">
      <h3>Mission History</h3>
      <button class="btn btn-secondary btn-sm" id="btn-refresh">Refresh</button>
    </div>
    <div id="missions-list">
      <div class="loading">Loading missions...</div>
    </div>
  </div>

  <!-- Low Credits Upgrade CTA -->
  <div class="card upgrade-banner" id="upgrade-banner" style="display:none;">
    <div class="upgrade-banner-body">
      <div class="upgrade-banner-icon">⚡</div>
      <div class="upgrade-banner-content">
        <div class="upgrade-banner-title">Credits đang thấp — nâng cấp để tiếp tục chạy missions</div>
        <div class="upgrade-banner-meta" id="upgrade-banner-meta"></div>
      </div>
    </div>
    <div class="upgrade-banner-actions">
      <a href="/billing" class="btn btn-primary btn-sm">Nâng cấp ngay &rarr;</a>
      <button class="btn btn-secondary btn-sm" id="btn-dismiss-upgrade">Bỏ qua</button>
    </div>
  </div>

  <!-- Mission Result Modal -->
  <div id="result-modal" class="modal-overlay" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="modal">
      <div class="modal-header">
        <h3 id="modal-title">Mission Result</h3>
        <button class="modal-close" id="btn-close-modal" aria-label="Close">&times;</button>
      </div>
      <div class="modal-body">
        <div class="mission-goal-label">Goal</div>
        <div id="modal-goal" class="modal-goal-text"></div>
        <div class="mission-result-label">Result</div>
        <div id="modal-result" class="modal-result-text"></div>
        <div class="mission-meta">
          <span id="modal-status" class="status-badge"></span>
          <span id="modal-cost" class="modal-cost"></span>
          <span id="modal-date" class="modal-date"></span>
        </div>
      </div>
      <!-- Upgrade CTA -->
      <div class="upgrade-cta">
        <div class="upgrade-cta-text">
          Liked this result? <strong>Pro</strong> gives you 1,000 missions/month for $149.
        </div>
        <a href="/billing" class="btn btn-primary btn-sm">Upgrade to Pro &rarr;</a>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  const API = 'https://api.agencyos.network';
  const apiKey = localStorage.getItem('mk_api_key');
  if (!apiKey) window.location.replace('/login');

  const headers = {
    'Content-Type': 'application/json',
    Authorization: 'Bearer ' + apiKey
  };

  // --- UI refs ---
  const missionsList = document.getElementById('missions-list');
  const newMissionForm = document.getElementById('new-mission-form');
  const missionGoalInput = document.getElementById('mission-goal') as HTMLTextAreaElement;
  const formError = document.getElementById('form-error');
  const submitLabel = document.getElementById('submit-label');
  const submitSpinner = document.getElementById('submit-spinner');
  const resultModal = document.getElementById('result-modal');

  // Show/hide form
  document.getElementById('btn-new-mission')?.addEventListener('click', () => {
    newMissionForm.style.display = 'block';
    missionGoalInput.focus();
  });

  document.getElementById('btn-cancel-mission')?.addEventListener('click', () => {
    newMissionForm.style.display = 'none';
    missionGoalInput.value = '';
    hideError();
  });

  // Cost estimate based on goal length
  missionGoalInput?.addEventListener('input', () => {
    const len = missionGoalInput.value.trim().length;
    const el = document.getElementById('cost-estimate');
    if (el) {
      if (len < 50) el.textContent = '1 MCU';
      else if (len < 150) el.textContent = '2–3 MCU';
      else el.textContent = '3–5 MCU';
    }
  });

  // Submit mission
  document.getElementById('btn-submit-mission')?.addEventListener('click', submitMission);

  async function submitMission() {
    const goal = missionGoalInput.value.trim();
    if (!goal) {
      showError('Please enter a mission goal.');
      return;
    }

    setSubmitting(true);
    hideError();

    try {
      const res = await fetch(API + '/v1/missions', {
        method: 'POST',
        headers,
        body: JSON.stringify({ goal })
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        if (res.status === 402) {
          showError('Insufficient MCU credits. Please upgrade your plan.');
        } else {
          showError(err.detail || err.message || 'Failed to submit mission.');
        }
        return;
      }

      missionGoalInput.value = '';
      newMissionForm.style.display = 'none';
      await loadMissions();
    } catch (e) {
      showError('Network error. Please try again.');
    } finally {
      setSubmitting(false);
    }
  }

  // Load mission list
  async function loadMissions() {
    missionsList.innerHTML = '<div class="loading">Loading missions...</div>';
    try {
      const res = await fetch(API + '/v1/missions', { headers });
      if (!res.ok) throw new Error('Failed to load');
      const data = await res.json();
      const missions = Array.isArray(data) ? data : (data.missions || data.items || []);
      renderMissions(missions);
    } catch {
      missionsList.innerHTML = '<div class="error">Could not load missions. Please refresh.</div>';
    }
  }

  function renderMissions(missions: any[]) {
    if (!missions.length) {
      missionsList.innerHTML = '<div class="empty-state">No missions yet. Submit your first mission above.</div>';
      return;
    }

    const rows = missions.map((m: any) => {
      const status = m.status || 'pending';
      const goal = truncate(m.goal || m.description || '—', 80);
      const cost = m.mcu_cost != null ? m.mcu_cost + ' MCU' : '—';
      const date = m.created_at ? new Date(m.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—';
      const hasResult = m.result || m.output;

      return `
        <div class="mission-row" data-id="${m.id}">
          <div class="mission-row-status">
            <span class="status-badge status-${status}">${statusLabel(status)}</span>
          </div>
          <div class="mission-row-goal">${goal}</div>
          <div class="mission-row-cost">${cost}</div>
          <div class="mission-row-date">${date}</div>
          <div class="mission-row-action">
            ${hasResult
              ? `<button class="btn btn-secondary btn-sm btn-view-result" data-id="${m.id}">View Result</button>`
              : `<span class="text-muted">—</span>`}
          </div>
        </div>
      `;
    }).join('');

    missionsList.innerHTML = `
      <div class="missions-table-header">
        <div>Status</div>
        <div>Goal</div>
        <div>Cost</div>
        <div>Date</div>
        <div></div>
      </div>
      ${rows}
    `;

    // Attach view result handlers
    document.querySelectorAll('.btn-view-result').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const mission = missions.find((m: any) => String(m.id) === id);
        if (mission) openResultModal(mission);
      });
    });
  }

  function openResultModal(mission: any) {
    const goal = document.getElementById('modal-goal');
    const result = document.getElementById('modal-result');
    const status = document.getElementById('modal-status');
    const cost = document.getElementById('modal-cost');
    const date = document.getElementById('modal-date');

    if (goal) goal.textContent = mission.goal || mission.description || '—';
    if (result) result.textContent = mission.result || mission.output || 'Result not available yet.';
    if (status) {
      const s = mission.status || 'pending';
      status.textContent = statusLabel(s);
      status.className = `status-badge status-${s}`;
    }
    if (cost) cost.textContent = mission.mcu_cost != null ? mission.mcu_cost + ' MCU used' : '';
    if (date) date.textContent = mission.created_at ? new Date(mission.created_at).toLocaleString() : '';

    resultModal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  document.getElementById('btn-close-modal')?.addEventListener('click', closeModal);
  resultModal?.addEventListener('click', (e) => {
    if (e.target === resultModal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && resultModal.style.display === 'flex') closeModal();
  });

  function closeModal() {
    resultModal.style.display = 'none';
    document.body.style.overflow = '';
  }

  document.getElementById('btn-refresh')?.addEventListener('click', loadMissions);

  // Helpers
  function truncate(str: string, max: number) {
    return str.length > max ? str.slice(0, max) + '…' : str;
  }

  function statusLabel(status: string) {
    const map: Record<string, string> = {
      pending: 'Pending',
      running: 'Running',
      completed: 'Completed',
      failed: 'Failed',
      cancelled: 'Cancelled'
    };
    return map[status] || status;
  }

  function showError(msg: string) {
    formError.textContent = msg;
    formError.style.display = 'block';
  }

  function hideError() {
    formError.style.display = 'none';
  }

  function setSubmitting(loading: boolean) {
    const btn = document.getElementById('btn-submit-mission') as HTMLButtonElement;
    btn.disabled = loading;
    submitLabel.style.display = loading ? 'none' : 'inline';
    submitSpinner.style.display = loading ? 'inline' : 'none';
  }

  // Upgrade CTA — check tier + balance
  const TIER_LIMITS: Record<string, number> = { free: 0, starter: 200, pro: 1000, enterprise: Infinity };
  const DISMISS_KEY = 'upgrade_banner_dismissed';

  async function checkUpgradeCTA() {
    if (sessionStorage.getItem(DISMISS_KEY)) return;
    try {
      const res = await fetch(API + '/v1/tenants/me', { headers });
      if (!res.ok) return;
      const tenant = await res.json();
      const tier: string = (tenant.tier || 'free').toLowerCase();
      const balance: number = tenant.balance ?? tenant.mcu_balance ?? tenant.credits ?? 0;

      if (tier === 'enterprise') return;
      const limit = TIER_LIMITS[tier] ?? 200;
      const threshold = limit > 0 ? limit * 0.2 : 40;

      if (balance < threshold || limit === 0) {
        const meta = document.getElementById('upgrade-banner-meta');
        if (meta) {
          const limitLabel = limit > 0 ? limit + ' MCU/tháng' : 'không có credits';
          meta.textContent = `Số dư: ${balance} MCU · Gói hiện tại: ${tier} (${limitLabel})`;
        }
        const banner = document.getElementById('upgrade-banner');
        if (banner) banner.style.display = 'flex';
      }
    } catch {
      // Silent fail — CTA is non-critical
    }
  }

  document.getElementById('btn-dismiss-upgrade')?.addEventListener('click', () => {
    sessionStorage.setItem(DISMISS_KEY, '1');
    const banner = document.getElementById('upgrade-banner');
    if (banner) banner.style.display = 'none';
  });

  // Init
  loadMissions();
  checkUpgradeCTA();
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
  }

  .page-header h1 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 4px 0;
  }

  .subtitle {
    color: var(--text2);
    font-size: 14px;
    margin: 0;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* Mission Form */
  .mission-form-card {
    margin-bottom: 24px;
    display: none;
  }

  .mission-form-card h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 6px 0;
  }

  .form-hint {
    color: var(--text2);
    font-size: 13px;
    margin: 0 0 16px 0;
  }

  .form-group {
    margin-bottom: 16px;
  }

  .mission-textarea {
    width: 100%;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    padding: 12px;
    font-size: 14px;
    font-family: inherit;
    resize: vertical;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .mission-textarea:focus {
    border-color: #6366f1;
  }

  .form-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .cost-estimate {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text2);
  }

  .cost-icon {
    font-size: 16px;
  }

  .form-actions {
    display: flex;
    gap: 8px;
  }

  .form-error {
    margin-top: 12px;
    padding: 10px 14px;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: var(--radius);
    color: #ef4444;
    font-size: 13px;
  }

  /* Section header */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .section-header h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
  }

  /* Missions Table */
  .missions-table-header,
  .mission-row {
    display: grid;
    grid-template-columns: 100px 1fr 80px 140px 100px;
    gap: 12px;
    align-items: center;
    padding: 12px 0;
  }

  .missions-table-header {
    font-size: 11px;
    font-weight: 600;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
    margin-bottom: 4px;
  }

  .mission-row {
    border-bottom: 1px solid var(--border);
    font-size: 13px;
  }

  .mission-row:last-child {
    border-bottom: none;
  }

  .mission-row-goal {
    color: var(--text);
    line-height: 1.4;
  }

  .mission-row-cost,
  .mission-row-date {
    color: var(--text2);
    font-size: 12px;
  }

  .mission-row-action {
    text-align: right;
  }

  /* Status badges */
  .status-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .status-pending  { background: rgba(99, 102, 241, 0.15); color: #818cf8; }
  .status-running  { background: rgba(245, 158, 11, 0.15); color: #fbbf24; }
  .status-completed { background: rgba(16, 185, 129, 0.15); color: #34d399; }
  .status-failed   { background: rgba(239, 68, 68, 0.15); color: #f87171; }
  .status-cancelled { background: rgba(163, 176, 194, 0.15); color: #a3b0c2; }

  /* Empty / loading states */
  .loading, .error, .empty-state {
    text-align: center;
    padding: 40px 24px;
    color: var(--text2);
    font-size: 14px;
  }

  .error { color: var(--danger, #ef4444); }

  .text-muted { color: var(--text2); font-size: 12px; }

  /* Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 16px;
  }

  .modal {
    background: var(--bg2, #1a1d27);
    border: 1px solid var(--border);
    border-radius: 12px;
    width: 100%;
    max-width: 560px;
    max-height: 80vh;
    overflow-y: auto;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px 0;
  }

  .modal-header h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
  }

  .modal-close {
    background: none;
    border: none;
    color: var(--text2);
    font-size: 22px;
    cursor: pointer;
    padding: 0 4px;
    line-height: 1;
  }

  .modal-close:hover { color: var(--text); }

  .modal-body {
    padding: 16px 24px;
  }

  .mission-goal-label,
  .mission-result-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text2);
    margin-bottom: 6px;
  }

  .mission-result-label {
    margin-top: 16px;
  }

  .modal-goal-text {
    font-size: 14px;
    color: var(--text);
    background: var(--bg3);
    border-radius: var(--radius);
    padding: 10px 14px;
    line-height: 1.5;
  }

  .modal-result-text {
    font-size: 13px;
    color: var(--text);
    background: var(--bg3);
    border-radius: var(--radius);
    padding: 12px 14px;
    line-height: 1.6;
    white-space: pre-wrap;
    max-height: 240px;
    overflow-y: auto;
  }

  .mission-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .modal-cost,
  .modal-date {
    font-size: 12px;
    color: var(--text2);
  }

  /* Upgrade CTA */
  .upgrade-cta {
    margin: 0 24px 24px;
    padding: 16px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.12) 0%, rgba(16, 185, 129, 0.08) 100%);
    border: 1px solid rgba(99, 102, 241, 0.25);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .upgrade-cta-text {
    font-size: 13px;
    color: var(--text2);
    line-height: 1.5;
  }

  .upgrade-cta-text strong {
    color: #818cf8;
  }

  /* Upgrade Banner */
  .upgrade-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    padding: 16px 20px;
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.08) 0%, rgba(99, 102, 241, 0.08) 100%);
    border: 1px solid rgba(245, 158, 11, 0.3);
    flex-wrap: wrap;
  }

  .upgrade-banner-body {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 0;
  }

  .upgrade-banner-icon {
    font-size: 20px;
    flex-shrink: 0;
  }

  .upgrade-banner-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 2px;
  }

  .upgrade-banner-meta {
    font-size: 12px;
    color: var(--text2);
  }

  .upgrade-banner-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-header {
      flex-direction: column;
      gap: 16px;
    }

    .missions-table-header,
    .mission-row {
      grid-template-columns: 80px 1fr 70px;
    }

    /* Hide cost + date columns on mobile */
    .mission-row-cost,
    .mission-row-date,
    .missions-table-header div:nth-child(3),
    .missions-table-header div:nth-child(4) {
      display: none;
    }

    .mission-row-action {
      grid-column: 3;
    }

    .form-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
