---

<MainLayout title="Pricing — OpenClaw" description="Simple, transparent pricing for OpenClaw, Sophia, Algo Trader, and more. Starts at $0. Pay per mission credit (MCU). Cloudflare deployment included on all plans.">
  <div class="pricing-page">
    <header class="pricing-header">
      <h1 class="gradient-text">Simple, transparent pricing</h1>
      <p class="pricing-subtitle">Pick the product that fits your stack. All plans include Cloudflare deployment.</p>
    </header>

    <!-- Pricing Calculator -->
    <section id="calculator" style="background:rgba(34,211,238,0.03);border:1px solid rgba(34,211,238,0.12);border-radius:16px;padding:40px;margin-bottom:var(--spacing-3xl);">
      <h2 style="font-size:1.4rem;font-weight:700;color:#f1f5f9;margin-bottom:8px;">Pricing Calculator</h2>
      <p style="color:#94a3b8;font-size:0.9rem;margin-bottom:32px;">Estimate your monthly cost based on mission volume and complexity.</p>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start;">
        <div style="display:flex;flex-direction:column;gap:24px;">
          <div>
            <label style="display:block;font-size:0.8rem;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">
              Missions per month: <span id="mission-count" style="color:#22d3ee;">20</span>
            </label>
            <input
              type="range"
              min="5"
              max="500"
              value="20"
              id="missions-slider"
              style="width:100%;accent-color:#22d3ee;cursor:pointer;"
            />
            <div style="display:flex;justify-content:space-between;color:#64748b;font-size:0.75rem;margin-top:4px;">
              <span>5</span><span>500</span>
            </div>
          </div>

          <div>
            <label style="display:block;font-size:0.8rem;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">
              Average complexity
            </label>
            <select
              id="complexity-select"
              style="width:100%;background:#1a1a1a;border:1px solid rgba(255,255,255,0.12);border-radius:8px;padding:10px 14px;color:#f1f5f9;font-size:0.9rem;cursor:pointer;outline:none;"
            >
              <option value="1">Simple (1 credit) — short content, quick lookups</option>
              <option value="2" selected>Standard (2 credits) — reports, drafts, analysis</option>
              <option value="3">Complex (3 credits) — multi-step, code, research</option>
            </select>
          </div>
        </div>

        <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:28px;">
          <div style="margin-bottom:20px;">
            <div style="font-size:0.75rem;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px;">Estimated credits</div>
            <div style="font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#22d3ee,#9333ea);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;" id="est-credits">40</div>
            <div style="color:#64748b;font-size:0.8rem;">credits / month</div>
          </div>
          <div style="border-top:1px solid rgba(255,255,255,0.06);padding-top:20px;">
            <div style="font-size:0.75rem;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px;">Recommended tier</div>
            <div style="font-size:1.2rem;font-weight:700;color:#22d3ee;" id="rec-tier">Starter ($29/mo)</div>
            <a id="calc-cta" href="https://landing.agencyos.network#pricing" style="display:inline-block;margin-top:16px;background:linear-gradient(135deg,#22d3ee,#0891b2);color:#0a0a0a;font-weight:700;padding:10px 20px;border-radius:8px;text-decoration:none;font-size:0.85rem;">
              Get Started
            </a>
          </div>
        </div>
      </div>
    </section>

    {PRODUCTS.map((product) => (
      <section class="product-section" id={product.id}>
        <div class="product-header">
          <h2 class="product-name">{product.name}</h2>
          <p class="product-tagline">{product.tagline}</p>
        </div>
        <div class="tiers-grid">
          {product.tiers.map((tier) => (
            <div class:list={['tier-card glass', { 'tier-highlight': tier.highlight }]}>
              {tier.highlight && <div class="popular-badge">Most Popular</div>}
              <div class="tier-header">
                <h3 class="tier-name">{tier.name}</h3>
                <div class="tier-price">
                  <span class="price-amount gradient-text">{tier.price}</span>
                  {tier.price !== '$0' && <span class="price-period">/mo</span>}
                </div>
                <p class="tier-desc">{tier.description}</p>
              </div>
              <ul class="tier-features">
                {tier.features.map((f) => (
                  <li><md-icon class="check-icon">check_circle</md-icon>{f}</li>
                ))}
              </ul>
              <div class="tier-cta">
                {tier.highlight
                  ? <md-elevated-button onclick={`location.href='${tier.ctaHref}'`}>{tier.cta}</md-elevated-button>
                  : <md-filled-tonal-button onclick={`location.href='${tier.ctaHref}'`}>{tier.cta}</md-filled-tonal-button>
                }
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</MainLayout>

<style>
  .pricing-page { max-width: 1200px; margin: 0 auto; padding: var(--spacing-3xl) var(--spacing-lg); }
  .pricing-header { text-align: center; margin-bottom: var(--spacing-3xl); }
  .pricing-header h1 { font-size: var(--md-sys-typescale-display-small-size); font-weight: 800; margin-bottom: var(--spacing-md); }
  .pricing-subtitle { color: var(--md-sys-color-on-surface-variant); font-size: 1.1rem; }

  .product-section { margin-bottom: var(--spacing-3xl); }
  .product-header { margin-bottom: var(--spacing-xl); }
  .product-name { font-size: var(--md-sys-typescale-headline-medium-size); font-weight: 700; color: var(--md-sys-color-primary); }
  .product-tagline { color: var(--md-sys-color-on-surface-variant); margin-top: var(--spacing-xs); }

  .tiers-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--spacing-md); }

  .tier-card { padding: var(--spacing-xl); position: relative; transition: transform 0.2s; }
  .tier-card:hover { transform: translateY(-4px); }
  .tier-highlight { border-color: var(--md-sys-color-primary) !important; box-shadow: 0 0 0 1px var(--md-sys-color-primary), 0 8px 32px rgba(0,188,212,0.15); }

  .popular-badge {
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    background: linear-gradient(135deg, #00BCD4, #9C27B0);
    color: white; font-size: 0.7rem; font-weight: 700;
    padding: 2px 12px; border-radius: 12px; white-space: nowrap;
  }

  .tier-header { margin-bottom: var(--spacing-lg); }
  .tier-name { font-size: 1rem; font-weight: 600; margin-bottom: var(--spacing-xs); color: var(--md-sys-color-on-surface-variant); text-transform: uppercase; letter-spacing: 0.05em; }
  .tier-price { display: flex; align-items: baseline; gap: 2px; margin-bottom: var(--spacing-xs); }
  .price-amount { font-size: 2rem; font-weight: 800; }
  .price-period { color: var(--md-sys-color-on-surface-variant); font-size: 0.9rem; }
  .tier-desc { color: var(--md-sys-color-on-surface-variant); font-size: 0.85rem; }

  .tier-features { list-style: none; display: flex; flex-direction: column; gap: var(--spacing-sm); margin-bottom: var(--spacing-xl); }
  .tier-features li { display: flex; align-items: center; gap: var(--spacing-sm); font-size: 0.875rem; }
  .check-icon { color: var(--md-sys-color-primary); font-size: 1rem; }

  .tier-cta { margin-top: auto; }

  @media (max-width: 900px) { .tiers-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .tiers-grid { grid-template-columns: 1fr; } }
  @media (max-width: 640px) { #calculator > div:last-of-type { grid-template-columns: 1fr !important; } }
</style>

<script>
  // Tier definitions: [label, maxCredits, price, ctaHref]
  const TIERS = [
    ['Free ($0/mo)',       10,   0,   'https://landing.agencyos.network'],
    ['Starter ($29/mo)',   50,   29,  'https://landing.agencyos.network#pricing'],
    ['Pro ($99/mo)',       200,  99,  'https://landing.agencyos.network#pricing'],
    ['Agency ($199/mo)',   500,  199, 'https://landing.agencyos.network#pricing'],
    ['Master ($399/mo)',   1000, 399, 'https://landing.agencyos.network#pricing'],
  ] as const;

  function calcRecommendedTier(credits: number) {
    for (const tier of TIERS) {
      if (credits <= tier[1]) return tier;
    }
    return TIERS[TIERS.length - 1];
  }

  function updateCalculator() {
    const missions = parseInt((document.getElementById('missions-slider') as HTMLInputElement).value);
    const complexity = parseInt((document.getElementById('complexity-select') as HTMLSelectElement).value);
    const credits = missions * complexity;

    (document.getElementById('mission-count') as HTMLElement).textContent = String(missions);
    (document.getElementById('est-credits') as HTMLElement).textContent = String(credits);

    const tier = calcRecommendedTier(credits);
    (document.getElementById('rec-tier') as HTMLElement).textContent = tier[0];
    (document.getElementById('calc-cta') as HTMLAnchorElement).href = tier[3];
  }

  document.getElementById('missions-slider')?.addEventListener('input', updateCalculator);
  document.getElementById('complexity-select')?.addEventListener('change', updateCalculator);
</script>
