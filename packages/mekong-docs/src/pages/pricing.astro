---

<MainLayout title="Pricing — OpenClaw" description="Simple, transparent pricing for OpenClaw, Sophia, Algo Trader, and more. Starts at $0. Pay per mission credit (MCU). Cloudflare deployment included on all plans.">
  <div class="pricing-page">
    <header class="pricing-header">
      <h1 class="gradient-text">Simple, transparent pricing</h1>
      <p class="pricing-subtitle">Pick the product that fits your stack. All plans include Cloudflare deployment.</p>
    </header>

    {PRODUCTS.map((product) => (
      <section class="product-section" id={product.id}>
        <div class="product-header">
          <h2 class="product-name">{product.name}</h2>
          <p class="product-tagline">{product.tagline}</p>
        </div>
        <div class="tiers-grid">
          {product.tiers.map((tier) => (
            <div class:list={['tier-card glass', { 'tier-highlight': tier.highlight }]}>
              {tier.highlight && <div class="popular-badge">Most Popular</div>}
              <div class="tier-header">
                <h3 class="tier-name">{tier.name}</h3>
                <div class="tier-price">
                  <span class="price-amount gradient-text">{tier.price}</span>
                  {tier.price !== '$0' && <span class="price-period">/mo</span>}
                </div>
                <p class="tier-desc">{tier.description}</p>
              </div>
              <ul class="tier-features">
                {tier.features.map((f) => (
                  <li><md-icon class="check-icon">check_circle</md-icon>{f}</li>
                ))}
              </ul>
              <div class="tier-cta">
                {tier.highlight
                  ? <md-elevated-button onclick={`location.href='${tier.ctaHref}'`}>{tier.cta}</md-elevated-button>
                  : <md-filled-tonal-button onclick={`location.href='${tier.ctaHref}'`}>{tier.cta}</md-filled-tonal-button>
                }
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</MainLayout>

<style>
  .pricing-page { max-width: 1200px; margin: 0 auto; padding: var(--spacing-3xl) var(--spacing-lg); }
  .pricing-header { text-align: center; margin-bottom: var(--spacing-3xl); }
  .pricing-header h1 { font-size: var(--md-sys-typescale-display-small-size); font-weight: 800; margin-bottom: var(--spacing-md); }
  .pricing-subtitle { color: var(--md-sys-color-on-surface-variant); font-size: 1.1rem; }

  .product-section { margin-bottom: var(--spacing-3xl); }
  .product-header { margin-bottom: var(--spacing-xl); }
  .product-name { font-size: var(--md-sys-typescale-headline-medium-size); font-weight: 700; color: var(--md-sys-color-primary); }
  .product-tagline { color: var(--md-sys-color-on-surface-variant); margin-top: var(--spacing-xs); }

  .tiers-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--spacing-md); }

  .tier-card { padding: var(--spacing-xl); position: relative; transition: transform 0.2s; }
  .tier-card:hover { transform: translateY(-4px); }
  .tier-highlight { border-color: var(--md-sys-color-primary) !important; box-shadow: 0 0 0 1px var(--md-sys-color-primary), 0 8px 32px rgba(0,188,212,0.15); }

  .popular-badge {
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    background: linear-gradient(135deg, #00BCD4, #9C27B0);
    color: white; font-size: 0.7rem; font-weight: 700;
    padding: 2px 12px; border-radius: 12px; white-space: nowrap;
  }

  .tier-header { margin-bottom: var(--spacing-lg); }
  .tier-name { font-size: 1rem; font-weight: 600; margin-bottom: var(--spacing-xs); color: var(--md-sys-color-on-surface-variant); text-transform: uppercase; letter-spacing: 0.05em; }
  .tier-price { display: flex; align-items: baseline; gap: 2px; margin-bottom: var(--spacing-xs); }
  .price-amount { font-size: 2rem; font-weight: 800; }
  .price-period { color: var(--md-sys-color-on-surface-variant); font-size: 0.9rem; }
  .tier-desc { color: var(--md-sys-color-on-surface-variant); font-size: 0.85rem; }

  .tier-features { list-style: none; display: flex; flex-direction: column; gap: var(--spacing-sm); margin-bottom: var(--spacing-xl); }
  .tier-features li { display: flex; align-items: center; gap: var(--spacing-sm); font-size: 0.875rem; }
  .check-icon { color: var(--md-sys-color-primary); font-size: 1rem; }

  .tier-cta { margin-top: auto; }

  @media (max-width: 900px) { .tiers-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .tiers-grid { grid-template-columns: 1fr; } }
</style>
