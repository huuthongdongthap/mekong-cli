{
  "id": "deploy",
  "version": "1.0.0",
  "layer": "engineering",
  "chapter": "軍爭 — Military Contention",
  "display": {
    "name_en": "Deploy",
    "icon": "",
    "description_en": "Deploy to production — build, push, verify CI/CD, confirm green"
  },
  "execution": {
    "agents": [
      "devops"
    ],
    "hub": "engineering-hub",
    "complexity": "standard",
    "timeout_ms": 300000,
    "credit_cost": 3,
    "requires_approval": true
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string",
        "description": "Deployment target or description"
      },
      "environment": {
        "type": "string",
        "enum": [
          "staging",
          "production"
        ],
        "default": "production"
      },
      "platform": {
        "type": "string",
        "enum": [
          "cloudflare",
          "vercel",
          "docker"
        ]
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "deploy_url": {
        "type": "string",
        "format": "uri"
      },
      "commit_sha": {
        "type": "string"
      },
      "ci_status": {
        "type": "string",
        "enum": [
          "success",
          "failure",
          "pending"
        ]
      },
      "http_status": {
        "type": "integer"
      },
      "deploy_time_seconds": {
        "type": "number"
      }
    }
  },
  "cascade": {
    "triggers": [
      {
        "pattern": ".*",
        "suggest": "audit",
        "target_layer": "engineering"
      }
    ]
  },
  "validation": {
    "output_must_contain": [
      "deploy_url",
      "ci_status"
    ],
    "min_output_length": 50,
    "max_credit_cost": 7
  }
}
