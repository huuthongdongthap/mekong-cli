{
  "id": "fix",
  "version": "1.0.0",
  "layer": "engineering",
  "chapter": "軍爭 — Military Contention",
  "display": {
    "name_en": "Fix",
    "icon": "",
    "description_en": "Debug and fix bugs with root cause analysis"
  },
  "execution": {
    "agents": [
      "debugger",
      "fullstack-developer"
    ],
    "hub": "engineering-hub",
    "complexity": "standard",
    "timeout_ms": 120000,
    "credit_cost": 2,
    "requires_approval": false
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string",
        "description": "Bug description or error message"
      },
      "logs": {
        "type": "string"
      },
      "file_path": {
        "type": "string"
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "root_cause": {
        "type": "string"
      },
      "fix_description": {
        "type": "string"
      },
      "files_modified": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "tests_added": {
        "type": "integer"
      },
      "verified": {
        "type": "boolean"
      }
    }
  },
  "cascade": {
    "triggers": [
      {
        "pattern": ".*",
        "suggest": "test",
        "target_layer": "engineering"
      }
    ]
  },
  "validation": {
    "output_must_contain": [
      "root_cause",
      "fix_description"
    ],
    "min_output_length": 50,
    "max_credit_cost": 5
  }
}
