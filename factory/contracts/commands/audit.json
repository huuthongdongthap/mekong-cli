{
  "id": "audit",
  "version": "1.0.0",
  "layer": "ops",
  "chapter": "九變 — Nine Variations",
  "display": {
    "name_en": "Audit",
    "icon": "",
    "description_en": "Security and code quality audit — deps, secrets, OWASP checks"
  },
  "execution": {
    "agents": [
      "security-reviewer",
      "code-reviewer"
    ],
    "hub": "ops-hub",
    "complexity": "standard",
    "timeout_ms": 120000,
    "credit_cost": 2,
    "requires_approval": false
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string",
        "description": "Audit scope"
      },
      "audit_type": {
        "type": "string",
        "enum": [
          "security",
          "code",
          "dependency",
          "full"
        ]
      },
      "severity_threshold": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high",
          "critical"
        ]
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "score": {
        "type": "number",
        "minimum": 0,
        "maximum": 10
      },
      "findings": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "severity": {
              "type": "string"
            },
            "category": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "fix": {
              "type": "string"
            }
          }
        }
      },
      "critical_count": {
        "type": "integer"
      },
      "high_count": {
        "type": "integer"
      },
      "recommendations": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "cascade": {
    "triggers": []
  },
  "validation": {
    "output_must_contain": [
      "score",
      "findings"
    ],
    "min_output_length": 100,
    "max_credit_cost": 5
  }
}
