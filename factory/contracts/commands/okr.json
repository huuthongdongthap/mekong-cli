{
  "id": "okr",
  "version": "1.0.0",
  "layer": "founder",
  "chapter": "始計 — Initial Calculations",
  "display": {
    "name_en": "Okr",
    "icon": "",
    "description_en": "Set OKRs — objectives with measurable key results"
  },
  "execution": {
    "agents": [
      "strategist"
    ],
    "hub": "founder-hub",
    "complexity": "standard",
    "timeout_ms": 120000,
    "credit_cost": 2,
    "requires_approval": false
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string"
      },
      "quarter": {
        "type": "string"
      },
      "focus_areas": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "objectives": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "objective": {
              "type": "string"
            },
            "key_results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "metric": {
                    "type": "string"
                  },
                  "target": {
                    "type": "number"
                  },
                  "current": {
                    "type": "number"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "cascade": {
    "triggers": [
      {
        "pattern": ".*",
        "suggest": "sprint",
        "target_layer": "founder"
      }
    ]
  },
  "validation": {
    "output_must_contain": [],
    "min_output_length": 50,
    "max_credit_cost": 5
  }
}
