{
  "id": "test",
  "version": "1.0.0",
  "layer": "engineering",
  "chapter": "軍爭 — Military Contention",
  "display": {
    "name_en": "Test",
    "icon": "",
    "description_en": "Run test suite with coverage analysis and failure diagnosis"
  },
  "execution": {
    "agents": [
      "tester"
    ],
    "hub": "engineering-hub",
    "complexity": "simple",
    "timeout_ms": 120000,
    "credit_cost": 1,
    "requires_approval": false
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string",
        "description": "Test scope or specific file"
      },
      "test_type": {
        "type": "string",
        "enum": [
          "unit",
          "integration",
          "e2e",
          "all"
        ]
      },
      "coverage_threshold": {
        "type": "number",
        "default": 80
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "total_tests": {
        "type": "integer"
      },
      "passed": {
        "type": "integer"
      },
      "failed": {
        "type": "integer"
      },
      "skipped": {
        "type": "integer"
      },
      "coverage_percent": {
        "type": "number"
      },
      "failures": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "test": {
              "type": "string"
            },
            "error": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "cascade": {
    "triggers": [
      {
        "pattern": ".*",
        "suggest": "deploy",
        "target_layer": "engineering"
      }
    ]
  },
  "validation": {
    "output_must_contain": [
      "total_tests",
      "passed"
    ],
    "min_output_length": 50,
    "max_credit_cost": 5
  }
}
