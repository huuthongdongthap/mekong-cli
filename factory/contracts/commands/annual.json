{
  "id": "annual",
  "version": "1.0.0",
  "layer": "founder",
  "chapter": "始計 — Initial Calculations",
  "display": {
    "name_en": "Annual",
    "icon": "",
    "description_en": "Annual business plan — vision, goals, financials, milestones"
  },
  "execution": {
    "agents": [
      "strategist",
      "cfo"
    ],
    "hub": "founder-hub",
    "complexity": "standard",
    "timeout_ms": 120000,
    "credit_cost": 3,
    "requires_approval": false
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string"
      },
      "year": {
        "type": "integer"
      },
      "current_mrr": {
        "type": "number"
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "vision": {
        "type": "string"
      },
      "goals": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "revenue_target": {
        "type": "number"
      },
      "milestones": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "quarter": {
              "type": "string"
            },
            "target": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "cascade": {
    "triggers": [
      {
        "pattern": ".*",
        "suggest": "okr",
        "target_layer": "founder"
      }
    ]
  },
  "validation": {
    "output_must_contain": [],
    "min_output_length": 50,
    "max_credit_cost": 5
  }
}
