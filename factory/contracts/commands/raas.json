{
  "id": "raas",
  "version": "1.0.0",
  "layer": "ops",
  "chapter": "九變 — Nine Variations",
  "display": {
    "name_en": "Raas",
    "icon": "",
    "description_en": "AGI RaaS Command Router  chn ng command cho tng tnh hung"
  },
  "execution": {
    "agents": [
      "devops"
    ],
    "hub": "ops-hub",
    "complexity": "trivial",
    "timeout_ms": 10000,
    "credit_cost": 0,
    "requires_approval": false
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string",
        "description": "Natural language task description"
      },
      "services": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Target services"
      },
      "environment": {
        "type": "string",
        "enum": [
          "local",
          "staging",
          "production"
        ]
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "summary": {
        "type": "string"
      },
      "status": {
        "type": "string",
        "enum": [
          "healthy",
          "degraded",
          "down",
          "completed"
        ]
      },
      "findings": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "actions_taken": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "cascade": {
    "triggers": []
  },
  "validation": {
    "output_must_contain": [],
    "min_output_length": 50,
    "max_credit_cost": 2
  }
}
