{
  "id": "debug",
  "version": "1.0.0",
  "layer": "engineering",
  "chapter": "軍爭 — Military Contention",
  "display": {
    "name_en": "Debug",
    "icon": "",
    "description_en": "Systematic debugging with log analysis and root cause identification"
  },
  "execution": {
    "agents": [
      "debugger"
    ],
    "hub": "ops-hub",
    "complexity": "standard",
    "timeout_ms": 120000,
    "credit_cost": 2,
    "requires_approval": false
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string",
        "description": "Error or symptom description"
      },
      "logs": {
        "type": "string"
      },
      "stack_trace": {
        "type": "string"
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "root_cause": {
        "type": "string"
      },
      "affected_files": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "severity": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high",
          "critical"
        ]
      },
      "fix_suggestion": {
        "type": "string"
      },
      "related_issues": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "cascade": {
    "triggers": [
      {
        "pattern": ".*",
        "suggest": "fix",
        "target_layer": "engineering"
      }
    ]
  },
  "validation": {
    "output_must_contain": [],
    "min_output_length": 50,
    "max_credit_cost": 5
  }
}
