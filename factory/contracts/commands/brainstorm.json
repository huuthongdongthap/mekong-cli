{
  "id": "brainstorm",
  "version": "1.0.0",
  "layer": "product",
  "chapter": "謀攻 — Attack by Stratagem",
  "display": {
    "name_en": "Brainstorm",
    "icon": "",
    "description_en": "Brainstorm solutions with trade-off analysis"
  },
  "execution": {
    "agents": [
      "planner",
      "researcher"
    ],
    "hub": "product-hub",
    "complexity": "standard",
    "timeout_ms": 120000,
    "credit_cost": 1,
    "requires_approval": false
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string"
      },
      "constraints": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "max_options": {
        "type": "integer",
        "default": 5
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "options": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "pros": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "cons": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "effort": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            }
          }
        }
      },
      "recommendation": {
        "type": "string"
      }
    }
  },
  "cascade": {
    "triggers": [
      {
        "pattern": ".*",
        "suggest": "plan",
        "target_layer": "product"
      }
    ]
  },
  "validation": {
    "output_must_contain": [],
    "min_output_length": 50,
    "max_credit_cost": 5
  }
}
