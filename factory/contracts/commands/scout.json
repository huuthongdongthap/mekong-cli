{
  "id": "scout",
  "version": "1.0.0",
  "layer": "ops",
  "chapter": "九變 — Nine Variations",
  "display": {
    "name_en": "Scout",
    "icon": "",
    "description_en": "Codebase scouting — file discovery, task context, architecture analysis"
  },
  "execution": {
    "agents": [
      "researcher"
    ],
    "hub": "ops-hub",
    "complexity": "simple",
    "timeout_ms": 120000,
    "credit_cost": 1,
    "requires_approval": false
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string"
      },
      "scope": {
        "type": "string",
        "enum": [
          "file",
          "module",
          "full"
        ]
      },
      "pattern": {
        "type": "string"
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "files_found": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "architecture_summary": {
        "type": "string"
      },
      "key_patterns": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "dependencies": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "cascade": {
    "triggers": [
      {
        "pattern": ".*",
        "suggest": "plan",
        "target_layer": "ops"
      }
    ]
  },
  "validation": {
    "output_must_contain": [],
    "min_output_length": 50,
    "max_credit_cost": 5
  }
}
