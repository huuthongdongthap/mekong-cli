{
  "id": "scope",
  "version": "1.0.0",
  "layer": "product",
  "chapter": "謀攻 — Attack by Stratagem",
  "display": {
    "name_en": "Scope",
    "icon": "",
    "description_en": "Scope definition — boundaries, requirements, acceptance criteria"
  },
  "execution": {
    "agents": [
      "pm",
      "planner"
    ],
    "hub": "product-hub",
    "complexity": "standard",
    "timeout_ms": 120000,
    "credit_cost": 1,
    "requires_approval": false
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string"
      },
      "scope_type": {
        "type": "string",
        "enum": [
          "feature",
          "sprint",
          "project"
        ]
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "in_scope": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "out_of_scope": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "acceptance_criteria": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "effort_estimate": {
        "type": "string"
      }
    }
  },
  "cascade": {
    "triggers": [
      {
        "pattern": ".*",
        "suggest": "plan",
        "target_layer": "product"
      }
    ]
  },
  "validation": {
    "output_must_contain": [],
    "min_output_length": 50,
    "max_credit_cost": 5
  }
}
