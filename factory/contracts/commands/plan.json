{
  "id": "plan",
  "version": "1.0.0",
  "layer": "product",
  "chapter": "謀攻 — Attack by Stratagem",
  "display": {
    "name_en": "Plan",
    "icon": "",
    "description_en": "Create implementation plan with phases, dependencies, and estimates"
  },
  "execution": {
    "agents": [
      "planner",
      "researcher"
    ],
    "hub": "product-hub",
    "complexity": "standard",
    "timeout_ms": 30000,
    "credit_cost": 2,
    "requires_approval": false
  },
  "input": {
    "type": "object",
    "required": [
      "goal"
    ],
    "properties": {
      "goal": {
        "type": "string",
        "description": "Feature or system to plan"
      },
      "constraints": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Technical/business constraints"
      },
      "deadline": {
        "type": "string",
        "format": "date",
        "description": "Target completion date"
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "plan_path": {
        "type": "string",
        "description": "Path to plan.md file"
      },
      "phases": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "effort_hours": {
              "type": "number"
            },
            "dependencies": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "total_effort_hours": {
        "type": "number"
      },
      "risk_level": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high"
        ]
      }
    }
  },
  "cascade": {
    "triggers": [
      {
        "pattern": ".*",
        "suggest": "cook",
        "target_layer": "product"
      }
    ]
  },
  "validation": {
    "output_must_contain": [
      "plan_path",
      "phases"
    ],
    "min_output_length": 100,
    "max_credit_cost": 3
  }
}
