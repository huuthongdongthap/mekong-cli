# =============================================================================
# Mekong CLI v5.0 — Environment Configuration
# =============================================================================

# LLM Provider (pick one — any OpenAI-compatible endpoint)
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-yourkey
# LLM_MODEL=anthropic/claude-sonnet-4

# Or provider-specific key (auto-detect):
# OPENROUTER_API_KEY=sk-or-v1-...          # 300+ models, $5 free
# DASHSCOPE_API_KEY=sk-...                 # Qwen Coding Plan ~$10/mo
# DEEPSEEK_API_KEY=sk-...                  # DeepSeek cheap
# ANTHROPIC_API_KEY=sk-ant-...             # Claude direct
# OPENAI_API_KEY=sk-...                    # GPT direct
# GOOGLE_API_KEY=AI...                     # Gemini

# Or local LLM (free, offline):
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5-coder

# RaaS (optional — for credit billing via Polar.sh)
# Get API key from: https://docs.polar.sh/api
# Get webhook secret from: Polar Dashboard → Settings → Webhooks
POLAR_API_KEY=sk_live_YOUR_POLAR_API_KEY
POLAR_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
POLAR_SUCCESS_URL=https://agencyos.network/success
POLAR_CANCEL_URL=https://agencyos.network/pricing

# Mekong CLI Products (create at polar.sh/mekong-cli/checkout)
POLAR_STARTER_PRODUCT_ID=prod_starter
POLAR_PRO_PRODUCT_ID=prod_pro
POLAR_ENTERPRISE_PRODUCT_ID=prod_enterprise

# LiteLLM Proxy (unified LLM gateway — optional)
# LITELLM_MASTER_KEY=sk-mekong-local
# LITELLM_URL=http://localhost:4000
# LITELLM_DB_URL=sqlite:///litellm.db

# =============================================================================
# CashClaw — Polymarket Prediction Trading (optional)
# =============================================================================

# Polymarket API keys (required for live trading)
# POLYMARKET_PRIVATE_KEY=0x...
# POLYMARKET_API_KEY=your-api-key

# Local LLM for predictions (default: Ollama with DeepSeek R1)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=deepseek-r1

# Trading database
# DATABASE_PATH=data/algo-trade.db

# Safety: ALWAYS default to paper trading
PAPER_TRADING=true
# CAPITAL_USDC=200

# Telegram monitoring (optional)
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
