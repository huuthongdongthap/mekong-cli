#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const { spawn, execSync } = require('child_process');
const readline = require('readline');

// --- CONFIG ---
// Auto-detect MEKONG_DIR relative to this script (bin/oc -> ../)
const MEKONG_DIR = path.resolve(__dirname, '..');
const TASKS_DIR = path.join(MEKONG_DIR, 'tasks');
const PROCESSED_DIR = path.join(MEKONG_DIR, 'processed'); 

const LOG_FILE = path.join(MEKONG_DIR, 'tom_hum_cto.log');

// --- COLORS ---
const C = {
  reset: "\x1b[0m",
  green: "\x1b[32m",
  yellow: "\x1b[33m",
  blue: "\x1b[34m",
  red: "\x1b[31m",
  cyan: "\x1b[36m",
  dim: "\x1b[2m",
  bold: "\x1b[1m"
};

// --- MAIN ---
async function main() {
  const args = process.argv.slice(2);
  const command = args[0];

  if (!command || command === 'help') {
    console.log(`${C.bold}OpenClaw CLI (OC) v1.0${C.reset}`);
    console.log(`Usage:`);
    console.log(`  oc cook "Your instruction here"   -> Start a mission`);
    console.log(`  oc status                         -> Check queue`);
    process.exit(0);
  }

  if (command === 'cook') {
    const instruction = args.slice(1).join(' ');
    if (!instruction) {
      console.error(`${C.red}Error: No instruction provided.${C.reset}`);
      process.exit(1);
    }
    await startMission(instruction);
  } else if (command === 'status') {
    showStatus();
  } else {
    console.log(`${C.red}Unknown command: ${command}${C.reset}`);
  }
}

async function startMission(instruction) {
  // 1. Generate Task
  const timestamp = Date.now();
  // Create a slug from instruction (first 5 words)
  const slug = instruction.replace(/[^a-zA-Z0-9 ]/g, '').split(' ').slice(0, 5).join('-').toLowerCase() || 'mission';
  const missionFile = `mission_${timestamp}_${slug}.txt`;
  const reviewFile = `review_${timestamp}_${slug}.txt`;
  const missionPath = path.join(TASKS_DIR, missionFile);
  const reviewPath = path.join(TASKS_DIR, reviewFile);

  console.log(`${C.cyan}🚀 Launching Mission: ${C.bold}${missionFile}${C.reset}`);
  console.log(`${C.dim}Instruction: ${instruction}${C.reset}`);

  // Write file
  const content = `/cook "${instruction}"`;
  fs.writeFileSync(missionPath, content);
  
  console.log(`${C.green}✅ Task queued.${C.reset} Watching logs...`);
  console.log(`${C.dim}(Press Ctrl+C to detach logging - task will continue running)${C.reset}\n`);

  // 2. Tail Logs
  const tail = spawn('tail', ['-f', '-n', '0', LOG_FILE]);
  
  tail.stdout.on('data', (data) => {
    const line = data.toString();
    if (line.includes(slug) || line.includes(missionFile) || line.includes('QA CHECK')) {
      process.stdout.write(`${C.dim}${line}${C.reset}`);
    }
    if (line.includes('ERROR') || line.includes('FAILED')) {
        process.stdout.write(`${C.red}${line}${C.reset}`);
    }
  });

  // 3. Poll for Review
  const checkInterval = setInterval(async () => {
    if (fs.existsSync(reviewPath)) {
      clearInterval(checkInterval);
      tail.kill();
      await handleReview(reviewPath, missionFile, instruction);
    }
  }, 2000);

  // Handle exit
  process.on('SIGINT', () => {
    tail.kill();
    console.log(`\n${C.yellow}Detached from logs. Task is still running in background.${C.reset}`);
    process.exit(0);
  });
}

async function handleReview(reviewPath, missionFile, instruction) {
  console.log(`\n${C.green}✅ Mission Complete! Review generated.${C.reset}`);
  console.log(`\n${C.bold}--- REVIEW (Opus/Auto-CTO) ---${C.reset}\n`);
  
  const content = fs.readFileSync(reviewPath, 'utf8');
  console.log(content);
  console.log(`\n${C.bold}------------------------------${C.reset}\n`);

  // Interactive Prompt
  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout
  });

  const question = (q) => new Promise(resolve => {
    rl.question(q, resolve);
  });

  while (true) {
    const answer = (await question(`${C.cyan}Action? [A]pprove (Archive) / [R]eject (Create fix task) / [C]ancel: ${C.reset}`)).trim().toUpperCase();
    
    if (answer === 'A') {
        const dest = path.join(PROCESSED_DIR, path.basename(reviewPath));
        if (fs.existsSync(reviewPath)) {
            try {
                fs.renameSync(reviewPath, dest);
                console.log(`${C.green}Archived. Mission Success! 🏁${C.reset}`);
            } catch (e) {
                console.log(`${C.yellow}Task already processed (likely by P0 Brain). Done.${C.reset}`);
            }
        } else {
             console.log(`${C.yellow}Task file gone (processed by P0). Mission Success! 🏁${C.reset}`);
        }

        // --- DEPLOYMENT TRIGGER (Moved outside) ---
        const targetProject = detectProject(instruction, missionFile);
        if (targetProject) {
            const deployAns = (await question(`${C.yellow}🚀 Deploy ${targetProject.name} to Production? [Y/n]: ${C.reset}`)).trim().toUpperCase();
            if (deployAns === 'Y' || deployAns === '') { // Default Yes
                await deployProject(targetProject);
            }
        }
        // ---------------------------

        break;
    } else if (answer === 'R') {
        const fixFile = `fix_${missionFile}`;
        const fixPath = path.join(TASKS_DIR, fixFile);
        
        const details = await question(`${C.yellow}Describe output/error for the fix: ${C.reset}`);
        const prompt = `/fix "Fix issues in ${missionFile}. Details: ${details}"`;
        fs.writeFileSync(fixPath, prompt);
        console.log(`${C.green}created ${fixFile}. Queued for P1-3.${C.reset}`);
        
        const dest = path.join(PROCESSED_DIR, path.basename(reviewPath));
        if (fs.existsSync(reviewPath)) {
            fs.renameSync(reviewPath, dest);
        }
        process.exit(0);
        
    } else if (answer === 'C') {
        console.log(`${C.yellow}Cancelled. Review file left in tasks/. P0 might pick it up.${C.reset}`);
        break;
    }
  }
  rl.close();
  process.exit(0);
}

function detectProject(instruction, missionFile) {
    const appsDir = path.join(MEKONG_DIR, 'apps');
    const projectsDir = path.join(MEKONG_DIR, 'projects');
    
    let candidates = [];
    if (fs.existsSync(appsDir)) candidates.push(...fs.readdirSync(appsDir).map(n => ({name: n, path: path.join(appsDir, n)})));
    if (fs.existsSync(projectsDir)) candidates.push(...fs.readdirSync(projectsDir).map(n => ({name: n, path: path.join(projectsDir, n)})));

    candidates = candidates.filter(c => fs.statSync(c.path).isDirectory());

    const searchStr = (instruction + ' ' + missionFile).toLowerCase();

    for (const p of candidates) {
        if (searchStr.includes(p.name.toLowerCase())) {
            return p;
        }
    }
    return null;
}

async function deployProject(project) {
    console.log(`${C.cyan}🚀 Deploying ${project.name}...${C.reset}`);
    console.log(`${C.dim}Dir: ${project.path}${C.reset}`);

    const pkgPath = path.join(project.path, 'package.json');
    let cmd = 'npx vercel --prod'; 
    
    if (fs.existsSync(pkgPath)) {
        try {
            const pkg = JSON.parse(fs.readFileSync(pkgPath, 'utf8'));
            if (pkg.scripts && pkg.scripts.deploy) {
                cmd = 'npm run deploy';
            }
        } catch (e) {}
    }

    console.log(`${C.yellow}$ ${cmd}${C.reset}`);
    
    return new Promise((resolve) => {
        const [bin, ...args] = cmd.split(' ');
        const child = spawn(bin, args, {
            cwd: project.path,
            stdio: 'inherit',
            shell: true
        });

        child.on('close', (code) => {
            if (code === 0) {
                console.log(`\n${C.green}✅ Deployment Successful!${C.reset}\n`);
            } else {
                console.log(`\n${C.red}❌ Deployment Failed (Exit Code: ${code})${C.reset}\n`);
            }
            resolve();
        });
    });
}

function showStatus() {
    const tasks = fs.readdirSync(TASKS_DIR).filter(f => f.endsWith('.txt'));
    console.log(`${C.bold}Queue Status:${C.reset}`);
    if (tasks.length === 0) {
        console.log("No pending tasks.");
    } else {
        tasks.forEach(t => console.log(`- ${t}`));
    }
}

main();
