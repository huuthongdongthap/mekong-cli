# ClaudeKit Context Exclusion Rules
# Files matching these patterns are excluded from LLM context injection

# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/
dist/
build/
*.egg-info/

# Large generated files
package-lock.json
poetry.lock
yarn.lock
pnpm-lock.yaml

# Binary and media
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.woff
*.woff2
*.ttf
*.eot
*.mp4
*.mp3

# Build artifacts
.next/
.nuxt/
.output/
coverage/
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets and environment
.env
.env.*
*.pem
*.key
*.cert

# IDE
.vscode/
.idea/
*.swp
*.swo

# Private directories (never send to LLM)
apps/
mekong/daemon/
mekong/hooks/

# Large data files
*.csv
*.parquet
*.sqlite
*.db

# Logs
*.log
logs/
